ios."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Tratamiento diario."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Acelera la regeneración celular desde el interior, disminuye las arrugas del contorno de los ojos, labios y líneas de expresión, tensa la piel y restaura la firmeza. Aclara el tono de la piel y redensifica la piel fina y frágil."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Aplicar mañana y noche mediante ligeros toques en el contorno de los ojos y labios perfectamente desmaquillados.  Adecuado para ojos sensibles y usuarias de lentes de contacto."}]}]},{"id":"CaracteristicasGenerales","type":"GROUPING","children":[{"id":"TipoArticulo","type":"LOOKUP_TABLE","featureGroupID":"10119","id_Ext":"238928090","value":"Tratamiento"},{"id":"Genero","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"10112","id_Ext":"201926090","value":"Femenino"},{"id":"TipoProductoBelleza","type":"LOOKUP_TABLE","featureGroupID":"10118","id_Ext":"12538518090","value":"Contornos de ojos"}]},{"id":"Tratamiento","type":"GROUPING","children":[{"id":"TexturaTratamiento","type":"LOOKUP_TABLE","featureGroupID":"10120","id_Ext":"238914090","value":"Crema"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"123567222"}]}],"stores":[{"id":"\/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20120810_152623"},{"id":"NovedadWWW","type":"FLAG","value":"false"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20120810_152623"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"false"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"123567222"}]}],"prices":[{"product