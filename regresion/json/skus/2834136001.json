n redes sociales. Además, cuenta con sistema de objetivos intercambiables, así podrás elegir qué quieres utilizar en cada momento. Tu opción más profesional en un diseño compacto."},{"id":"Titular LTC","type":"STRING","value":"Un diseño irresistible con la tecnología más avanzada"},{"id":"Fecha de Publicacion","type":"DATE","value":"20140327_160503"},{"id":"Fecha de Despublicacion","type":"DATE","value":"20160526_000000"},{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"233768090","value":"011"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20140327_160503"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"Foto","type":"FLAG","value":"true"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"136583509"}]},{"id":"/Hipercor_ISS","type":"SPEC","children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"MostrarSoloRebajado","type":"FLAG","value":"false"},{"id":"FechaDePublicacionHPR","type":"DATE","value":"20170226_000000"},{"id":"FechaDespublicacionHPR","type":"DATE","value":"20170227_000000"},{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"MotivoPubDesHPR","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"233768090","value":"011"},{"id":"FechaDePrimeraPublicacionHPR","type":"DATE","value":"20160412_000000"},{"id":"NovedadHPR","type":"FLAG","value":"false"},{"id":"PublicarAutomaticamenteHPR","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"false"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"136583509"}]},{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorMarg