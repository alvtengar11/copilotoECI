					]
				},
				{
					"id": "DescripcionLarga",
					"ocurrence": 1,
					"type": "GROUPING",
					"children": [
						{
							"id": "Titulo_OLD",
							"type": "STRING",
							"value": "Seguridad:"
						},
						{
							"id": "Titulo",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Seguridad:"
								}
							]
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 0,
							"type": "STRING",
							"value": "La galardonada Stokke Flexi Bath y el soporte para recién nacidos crean un ambiente cómodo y seguro para bañar al bebé. Sin embargo, asegúrese de nunca dejar al niño solo."
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 1,
							"type": "STRING",
							"value": "Stokke Flexi Bath tiene una base antideslizante para que el niño no resbale o se deslice."
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 2,
							"type": "STRING",
							"value": "Stokke Flexi Bath ha sido exhaustivamente testada. Además de cumplir con todas las normas de seguridad pertinentes, es extremadamente resistente."
						},
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "La galardonada Stokke ® Flexi Bath y el Soporte para recién nacidos crean un ambiente cómodo y seguro para bañar al bebé, adaptarse a la forma del cuerpo del bebé. Sin embargo, asegúrese de nunca dejar al niño solo. Cuando se está bañando al bebé, se asemeja al soporte de un brazo firme, asegurando comodidad y seguridad, al tiempo que ofrece al bebé una completa libertad de movimiento."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Stokke ® Flexi Bath tiene una base antideslizante para que el niño no resbale o se deslice."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Stokke ® Flexi Bath ha sido exhaustivamente testada. Además de cumplir con todas las normas de seguridad pertinentes, es extremadamente resistente."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Hecha de plásticos totalmente libres de sustancias nocivas, la Bañera es segura, flexible y cómoda para un niño en crecimiento."
								}
							]
						}
					]
				},
