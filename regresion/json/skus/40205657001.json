ype":"STRING","value":"0"},{"id":"StockInfinito","type":"FLAG","value":"false"},{"id":"ReferenciaGenerica","type":"FLAG","value":"false"},{"id":"PeticionPrecioDeVenta","type":"FLAG","value":"true"},{"id":"ReferenciaDigital","type":"FLAG","value":"false"},{"id":"AnillosDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8517140000"},{"id":"Atue","type":"STRING","value":"22J"},{"id":"TipoAcuerdoServicio","type":"STRING","value":"N"},{"id":"CertificadoCE","type":"FLAG","value":"false"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0904813"},{"id":"NombreProveedor","type":"STRING","value":"APPLE DISTRIBUTION INTERNATIONAL"},{"id":"Fabricante","type":"STRING","value":"0904813"},{"id":"DescripcionFabricante","type":"STRING","value":"APPLE DISTRIBUTION INTERNATIONAL"},{"id":"Marca","type":"STRING","value":"APPLE"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Apple","groupID":"391","id_Ext":"124603056"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"IPHONE A - 128 - 2"}]},{"id":"DescripcionLargaDelProducto","type":"GROUPING","ocurrence":0,"children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Apple iPhone 13 móvil libre"},{"id":"en_GB","type":"STRING","value":"Apple iPhone 13 128GB"},{"id":"fr_FR","type":"STRING","value":"Apple iPhone 13 128Go"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","type":"STRING","ocurrence":0,"value":"O seu novo super poder."},{"id":"pt_PT","type":"STRING","ocurrence":1,"value":"Frente e traseira resistentes. De cima para baixo. Ceramic Shield, mais duro do que qualquer vidro de smartphone.  Desenho robusto com bordas planas"},{"id":"pt_PT","type":"STRING","ocurrence":2,"value":"Ecrã Super Retina XDR, 6,1 polegadas (15,40 cm) visor OLED diagonal, resolução de 2532 por 1170 pixels a 460 ppi"},{"id":"pt_PT","type":"STRING","ocurrence":3,"value":"Modo Cinematográfico: O cinema é uma técnica que utiliza a mudança selectiva de foco para dirigir a atenção do público para o tema principal de cada cena. E agora com o iPhone pode usar este mesmo instrumento narrativo nos seus vídeos."},{"id":"pt_PT","type":"STRING","ocurrence":4,"value":"Tirar uma fotografia sem mexer um dedo. A câmara TrueDepth tem todas as suas características favoritas de câmara traseira: Modo Cinematográfico, Estilos Fotográficos, gravação de vídeo HDR com Dolby Vision, Modo Retrato, Modo Nocturno selfies, Smart HDR 4, Deep Fusion e muito mais para novos selfies estratosféricos."},{"id":"pt_PT","type":"STRING","ocurrence":5,"value":"Classificação IP68 em conformidade com a IEC 60529 (até 6 metros de profundidade por até 30 minutos)"},{"id":"pt_PT","type":"STRING","ocurrence":6,"value":"Sistema mais avançado de câmara dupla de 12 Mpx com grande angular e ultra grande angular; Grande angular: ƒ/1.6 abertura; Ultra grande angular: ƒ/2.4 abertura e  campo de visão de 120°."},{"id":"es_ES","type":"STRING","ocurrence":0,"value":"Tu nuevo superpoder."},{"id":"es_ES","type":"STRING","ocurrence":1,"value":"Resistente por delante y por detrás. De arriba abajo. Ceramic Shield, más duro que cualquier vidrio de smartphone.  Diseño robusto con bordes planos"},{"id":"es_ES","type":"STRING","ocurrence":2,"value":"El chip que hace morder el polvo a la competencia. (A15)"},{"id":"es_ES","type":"STRING","ocurrence":3,"value":"Pantalla Super Retina XDR, Pantalla OLED de 6,1 pulgadas (15,40 cm) en diagonal, Resolución de 2.532 por 1.170 píxeles a 460 p/p"},{"id":"es_ES","type":"STRING","ocurrence":4,"value":"Presentamos el modo Cine: En el cine se utiliza una técnica que consiste en cambiar el enfoque de manera selectiva para dirigir la atención del público hacia el sujeto protagonista de cada escena. Y ahora con el iPhone puedes usar este mismo recurso narrativo en tus vídeos. Érase una vez Hollywood, pero para todos los públicos."},{"id":"es_ES","type":"STRING","ocurrence":5,"value":"Haz un fotón sin mover un dedo. La cámara TrueDepth tiene todas tus prestaciones favoritas de las cámaras traseras: Modo Cine, Estilos Fotográficos, Grabación de vídeo en HDR con Dolby Vision, Modo Retrato, Selfies en modo Noche, HDR Inteligente 4, Deep Fusion y mucho más para unos nuevos selfies estratosféricos."},{"id":"es_ES","type":"STRING","ocurrence":6,"value":"Calificación IP68 según la norma IEC 60529 (hasta 6 metros de profundidad durante un máximo de 30 minutos)"},{"id":"es_ES","type":"STRING","ocurrence":7,"value":"Sistema de cámara dual más avanzado de 12 Mpx con gran angular y ultra gran angular; Gran angular: apertura de ƒ/1,6; Ultra gran angular: apertura de ƒ/2,4 y campo de visión de 120°"},{"id":"es_ES","type":"STRING","ocurrence":8,"value":"*Compruebe la disponibilidad del servicio 5G con su operador de telefonía."},{"id":"en_GB","type":"STRING","ocurrence":0,"value":"Your new superpower.\nTough front and back. From top to bottom. Ceramic Shield, harder than any smartphone glass. Rugged design with flat edges.\nThe chip that bites the competition in the dust. (A15)\nSuper Retina XDR display, 6.1-inch (15.40 cm) diagonal OLED display, 2532 by 1170 pixel resolution at 460 ppi."},{"id":"en_GB","type":"STRING","ocurrence":1,"value":"Introducing Cinema Mode: Cinema is a technique of selectively shifting focus to direct the audience's attention to the main subject of each scene. And now with iPhone you can use this same narrative device in your videos. Once upon a time Hollywood, but for everyone."},{"id":"en_GB","type":"STRING","ocurrence":2,"value":"Get a great shot without lifting a finger. The TrueDepth camera has all your favourite rear camera features: Cinema Mode, Photo Styles, HDR video recording with Dolby Vision, Portrait Mode, Night Mode Selfies, Smart HDR 4, Deep Fusion and more for stratospheric new selfies."},{"id":"en_GB","type":"STRING","ocurrence":3,"value":"IP68 rating according to IEC 60529 (up to 6 meters depth for up to 30 minutes)\nMost advanced 12 Mpx dual camera system with wide-angle and ultra wide-angle; Wide-angle: ƒ/1.6 aperture; Ultra wide-angle: ƒ/2.4 aperture and 120° field of view"},{"id":"en_GB","type":"STRING","ocurrence":4,"value":"*Check 5G service availability with your phone operator."},{"id":"fr_FR","type":"STRING","ocurrence":0,"value":"Votre nouveau super pouvoir.\nDur devant et derrière. De haut en bas. Bouclier en céramique, plus dur que n'importe quel verre de smartphone. Conception robuste avec des bords plats.\nLa puce qui fait mordre la poussière à la concurrence. (A15)\nÉcran Super Retina XDR, écran OLED de 6,1 pouces (15,40 cm) de diagonale, résolution de 2532 par 1170 pixels à 460 ppi."},{"id":"fr_FR","type":"STRING","ocurrence":1,"value":"Présentation du mode cinéma : le cinéma est une technique qui consiste à changer sélectivement la mise au point pour diriger l'attention du public sur le sujet principal de chaque scène. Et maintenant, avec l'iPhone, vous pouvez utiliser ce même dispositif narratif dans vos vidéos. Il était une fois Hollywood, mais pour tout le monde."},{"id":"fr_FR","type":"STRING","ocurrence":2,"value":"Réalisez de superbes clichés sans lever le petit doigt. L'appareil photo TrueDepth est doté de toutes les fonctions préférées de l'appareil photo arrière : mode cinéma, styles de photo, enregistrement vidéo HDR avec Dolby Vision, mode portrait, selfies en mode nuit, Intelligent HDR 4, Deep Fusion et bien d'autres encore pour des selfies d'une qualité stratosphérique."},{"id":"fr_FR","type":"STRING","ocurrence":3,"value":"Indice IP68 selon la norme IEC 60529 (jusqu'à 6 mètres de profondeur pendant 30 minutes)\nSystème de double caméra 12 Mpx le plus avancé avec grand angle et ultra grand angle ; Grand angle : ouverture ƒ/1.6 ; ultra grand angle : ouverture ƒ/2.4 et champ de vision de 120°."},{"id":"fr_FR","type":"STRING","ocurrence":4,"value":"*Vérifiez la disponibilité du service 5G auprès de votre opérateur téléphonique."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"1N"},{"id":"TipoDeGestion","type":"STRING","value":"00"}]},{"id":"DimensionesYPeso","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm","featureGroupID":"204","id_Ext":"347186090"},{"id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g","featureGroupID":"206","id_Ext":"347187090"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml","featureGroupID":"213","id_Ext":"347188090"},{"id":"PUM","type":"GROUPING","children":[{"id":"CantidadProducto","type":"NUMBER","value":"0.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}]}]},{"id":"ColoresYTallas","type":"GROUPING","children":[{"id":"IndicadorBalanza","type":"FLAG","value":"false"},{"id":"ColorFabricante","type":"STRING","value":"BLANCO ESTRELLA"},{"id":"DescripcionDelColor","type":"LOOKUP_TABLE","value":"Blanco estrella","featureGroupID":"135","id_Ext":"40171165090"},{"id":"ColorBasico","type":"LOOKUP_TABLE","value":"Blancos","featureGroupID":"1