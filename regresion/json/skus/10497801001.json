									"children": [
										{
											"id": "es_ES",
											"ocurrence": 0,
											"type": "STRING",
											"value": "- Dos amplificadores digitales clase D perfectamente ajustados para una integración total con los altavoces y la arquitectura acústica"
										},
										{
											"id": "es_ES",
											"ocurrence": 1,
