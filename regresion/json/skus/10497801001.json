											"id": "es_ES",
											"ocurrence": 9,
											"type": "STRING",
											"value": "- Configuración sencilla y actualizaciones de software automáticas y gratuitas"
										},
										{
											"id": "es_ES",
											"ocurrence": 10,
											"type": "STRING",
											"value": "- Botones del panel superior: Volumen y Reproducir/Pausar,\nPulsa Reproducir/Pausar (una vez para iniciar o detener la música y dos veces para saltar a la siguiente pista)"
										},
