										},
										{
											"id": "es_ES",
											"ocurrence": 2,
											"type": "STRING",
											"value": "- Convierte dos PLAY:1s en dos altavoces de canal izquierdo y derecho separados para crear un sonido mayor y más profundo"
										},
										{
											"id": "es_ES",
											"ocurrence": 3,
											"type": "STRING",
											"value": "- Compatibilidad con archivos de música comprimidos de formato MP3, iTunes Plus, WMA, AAC (MPEG4), AAC+, Ogg Vorbis, Audible (formato 4), Apple Lossless, FLAC, así como archivos sin comprimir de formato WAV y AIFF"
										},
										{
											"id": "es_ES",
											"ocurrence": 4,
											"type": "STRING",
											"value": "- Servicios de música compatibles: 7 Digital, 8Tracks, Amazon Cloud Player, Bandcamp, Batanga, Beats Music, Blinkbox, CalmRadio, Concert Vault, Dar. fm, Daytrotter, Deezer, Duoban, Duomi, Google Play Music, Hearts of Space, Hotelradio.fm, Hype Machine, iHeartRADIO, JB Hi-Fi NOW, JUKE, Live365, MLB.com Gameday, Murfie, Napster, Pandora,\nQobuz, QQ, Radionomy, RadioPup, Rdio, Rhapsody, Rusc, Shuffler. fm, Simfy, SiriusXM, Slacker Radio, Songl, Songza, SoundCloud, Spotify, Stitcher SmartRadio, TDC Play, TuneIn, WiMP y YouMusic. La disponibilidad del servicio varía según la región"
										},
										{
											"id": "es_ES",
											"ocurrence": 5,
											"type": "STRING",
											"value": "- Sistemas operativos para archivos almacenados: Windows XP SP3 y posterior, Mac OS X v10.6.8 y superior, dispositivos NAS (almacenamiento conectado a red) compatibles con CIFS"
										},
										{
											"id": "es_ES",
											"ocurrence": 6,
											"type": "STRING",
											"value": "- Modos de reproducción: Fundir, aleatorio, repetir"
										},
										{
											"id": "es_ES",
											"ocurrence": 7,
											"type": "STRING",
											"value": "- Carátula compatible: JPEG, PNG, BMP, GIF"
										},
										{
											"id": "es_ES",
											"ocurrence": 8,
											"type": "STRING",
											"value": "- Controlable desde dispositivos iOS, Android, Mac o PC"
										},
