  "specificAttribs": [
    {
      "id": "/Videojuegos_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "CaracteristicasGenerales",
          "type": "GROUPING",
          "children": [
            {
              "id": "CaracteristicasDelJuego",
              "ocurrence": 0,
              "type": "GROUPING",
              "children": [
                {
                  "id": "CaracteristicasDelJuego",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "ocurrence": 0,
                      "type": "STRING",
                      "value": "The Last of Us Remasterizado llegará a PlayStation 4 en verano de 2014."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 1,
                      "type": "STRING",
                      "value": "El reconocido como Mejor Juego de 2013 dará el salto a la nueva generación de PlayStation a calidad 1080p. La acción y la tensión de la historia protagonizada por Joel y Ellie llegará junto a  todos los contenidos adicionales del aclamado título de Naughty Dog."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 2,
                      "type": "STRING",
                      "value": "Madrid, 10 de abril de 2014. Un mundo devastado, una población diezmada por una plaga moderna, un viaje a través de Estados Unidos en busca de la salvación."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 3,
                      "type": "STRING",
                      "value": "The Last of Us, el reconocido como Juego del Año de 2013 y que ha sido galardonado con más de 200 premios del sector, dará el salto a PS4 en una edición especial remasterizada que mantendrá toda la acción y la tensión de la edición de PS3 pero ahora en calidad 1080p."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 4,
                      "type": "STRING",
                      "value": "La potente arquitectura de PS4  ha permitido al equipo de desarrollo, Naughty Dog, mejorar múltiples aspectos técnicos y dar un salto en el apartado visual a la aventura que protagonizan Joel y Ellie. Estas mejoras incluyen una mayor resolución en el modelado de los personajes, perfeccionamiento de los sistemas de luces y sombras, texturas mejoradas y mucho más."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 5,
                      "type": "STRING",
                      "value": "La nueva edición, incorpora además, un contenido adicional dedicado al apartado cinemático del juego con comentarios de director creativo y guionista, Neil Druckmann, el director del juego, Bruce Straley, el actor de doblaje, Troy Baker que protagoniza a Joel, y la ganadora de un Bafta a la mejor actriz de doblaje, Ashley Johnson que interpreta a Ellie."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 6,
                      "type": "STRING",
                      "value": "The Last of Us Remasterizado incluirá, además, todos los contenidos adicionales lanzados."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 7,
                      "type": "STRING",
                      "value": "Los jugadores podrán disfrutar de The Last of Us: Left Behind, la ampliación del modo campaña que profundiza en la vida de Ellie, la joven y carismática protagonista, durante los años anteriores a la aventura que vive en el título."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 8,
                      "type": "STRING",
                      "value": "También incluirá el pack de mapas multijugador Territorios abandonados, así como un futuro pack para el modo multijugador que llegará próximamente."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 9,
                      "type": "STRING",
                      "value": "Este nuevo título, que servirá para conmemorar el reconocimiento como Juego del Año, podrá reservarse próximamente con exclusivos beneficios(consultar condiciones de cada establecimiento) como un pack de descarga que incluye puntos extra para el modo Facciones, dos trajes especiales para Joel y Ellie que se desbloquearán al superar el modo campaña, aumento de la velocidad de curación y la creación de armas en el modo un jugador y mejora de las capacidades de varias armas."
                    }
                  ]
                }
