				"type": "STRING",							"value": "0068643"						},						{							"id": "DescripcionFabricante",							"type": "STRING",							"value": "LEGO, S.A."						},						{							"id": "MarcaMostradaEnWeb",							"type": "RELATIONSHIP",							"groupID": "391",							"id_Ext": "126499056",							"value": "LEGO"						}					]				},				{					"id": "DescripcionCorta",					"type": "GROUPING",					"children": [						{							"id": "DescripcionTicket",							"type": "STRING",							"value": "CONSTRUCCIONE"						}					]				},				{					"id": "DescripcionLargaDelProducto",					"ocurrence": 0,					"type": "GROUPING",					"children": [						{							"id": "DescripcionPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"ocurrence": 0,									"type": "STRING",									"value": "Bienvenido al Badulaque: ¡el mejor lugar para comprar cómodamente a precios incómodos! Esta detallada y emblemática versión Lego de la tienda de The Simpsons tiene más detalles, colores y accesorios que velas tiene la tarta de cumpleaños del Sr. Burns."								},								{									"id": "es_ES",									"ocurrence": 1,									"type": "STRING",									"value": "Pasa bajo la gran entrada del Badulaque y acompaña a Homer, Marge y Bart mientras recorren los pasillos llenos de productos de belleza, pañales, comida para perros, pasteles, fruta y verdura; ¡incluso encontrarás los cereales Krusty-O's y la sopa para uno del Chef Corazón Solitario!"								},								{									"id": "es_ES",									"ocurrence": 2,									"type": "STRING",									"value": "Dirígete entonces a los expositores refrigerados, donde encontrarás Buzz Cola, batido de chocolate y otras bebidas y aperitivos, ¡y a Jesper congelado! También hay dispensadores de Buzz Cola y zumos, una máquina de café, videojuegos, un cajero automático y todas las barritas energéticas Powersauce que quieras."								},								{									"id": "es_ES",									"ocurrence": 3,									"type": "STRING",									"value": "En el mostrador, Apu te tentará con sus revistas, cómics, tarjetas, perritos de tofu, donuts recién caducados y su siempre popular fresisuis alucinógeno. En la parte de atrás encontrarás un almacén con una rata y una salida. Sube al tejado y descubrirás el huerto secreto de Apu."								},								{									"id": "es_ES",									"ocurrence": 4,									"type": "STRING",									"value": "Por fuera, este asombroso modelo cuenta con paredes de color amarillo, 2 cabinas telefónicas, una pila de cajas violeta y una zona de residuos con un grafiti de 'El Barto' y un contenedor de basura azul que se abre. También puedes desmontar el tejado y abrir las paredes traseras para acceder fácilmente al interior."								},								{									"id": "es_ES",									"ocurrence": 5,									"type": "STRING",									"value": "El set incluye también a Snake (alias Jailbird), cuyo pasatiempo favorito es robar tarjetas y atracar el Badulaque... ¡aunque esta vez el Jefe Wiggum lo atrapará en su coche de policía! Captura al bandido y devuelve la paz a la ciudad de Springfield y el asombroso Badulaque."								},								{									"id": "es_ES",									"ocurrence": 6,									"type": "STRING",									"value": "El set incluye 6 minifiguras con diferentes accesorios: Homer Simpson, Bart Simpson, Marge Simpson, Apu Nahasapeemapetilon, el Jefe Wiggum y Snake (alias Jailbird)."								},								{									"id": "es_ES",									"ocurrence": 7,									"type": "STRING",									"value": "Cuenta con paredes traseras abatibles, tejado desmontable con huerto secreto, letrero característico del Badulaque, paredes de color azul claro, suelos de color azul ceniza, alfombra de bienvenida de color turquesa, estantes, expositores refrigerados, mostrador, dispensadores de Buzz Cola y zumos, una máquina de café, 2 videojuegos, un cajero automático, cajas de barritas energéticas Powersauce, cámaras de vigilancia y almacén trasero con una rata, queso, un agujero de rata y puerta de salida."								},								{									"id": "es_ES",									"ocurrence": 8,									"type": "STRING",									"value": "Los estantes contienen productos de belleza, pañales, comida para perros, pasteles, frutas y verduras, así como los cereales Krusty-O's y la sopa para uno del Chef Corazón Solitario. Los expositores refrigerados contienen diferentes bebidas, como latas de Buzz Cola... ¡y a Jasper congelado!"								},								{									"id": "es_ES",									"ocurrence": 9,									"type": "STRING",									"value": "El mostrador cuenta con caja registradora, una revista y un expositor de tarjetas, una máquina de lotería, un horno de perritos calientes, un expositor de donuts y un dispensador de fresisuis con 2 fresisuis."								},								{									"id": "es_ES",									"ocurrence": 10,									"type": "STRING",									"value": "Incluye también el coche de policía del Jefe Wiggum con maletero abatible, techo desmontable y espacio para 3 minifiguras. Accesorios incluidos: pintura en espray de Bart, cesta de la compra de Marge, cepillo de Apu, y esposas y porra del Jefe Wiggum."								},								{									"id": "es_ES",									"ocurrence": 11,									"type": "STRING",									"value": "Snake (alias Jailbird) es exclusivo de este set en otoño de 2015. El tejado desmontable cuenta con ladrillos de color naranja oscuro difíciles de encontrar. Levanta el tejado y abre las paredes traseras para acceder fácilmente al interior."								},								{									"id": "es_ES",									"ocurrence": 12,									"type": "STRING",									"value": "¡Disfruta de un fresisuis y siente el subidón de azúcar! ¡Atrapa a Snake antes de que vuelva a robar! Reabastece los estantes y sube bien los precios. ¡Descubre la figura de Jasper congelado!"								},								{									"id": "es_ES",									"ocurrence": 13,									"type": "STRING",									"value": "Relájate en el utópico huerto de Apu. Saborea un donut. Mmm... ¡dooonuts!"								},								{									"id": "es_ES",									"ocurrence": 14,									"type": "STRING",									"value": "El Badulaque mide más de 14 cm de altura, 38 cm de ancho y 27 cm de profundidad. El coche de policía mide más de 6 cm de altura, 6 cm de ancho y 15 cm de profundidad."								}							]						}					]				},				{					"id": "GestionComprasStock",					"type": "GROUPING",					"children": [						{							"id": "Calificacion1",							"type": "STRING",							"value": "A"						},						{							"id": "Calificacion2",							"type": "STRING",							"value": "O"						},						{							"id": "Calificacion4",							"type": "STRING",							"value": "VV"						},						{							"id": "Calificacion5",							"type": "STRING",							"value": "B"						},						{							"id": "TipoDeGestion",							"type": "STRING",							"value": "06"						}					]				},				{					"id": "DimensionesYPeso",					"type": "GROUPING",					"children": [						{							"id": "UOM!Dimensiones!Unidad",							"type": "LOOKUP_TABLE",							"featureGroupID": "204",							"id_Ext": "347186090",							"value": "cm"						},						{							"id": "UOM!PesoBruto!Unidad",							"type": "LOOKUP_TABLE",							"featureGroupID": "206",							"id_Ext": "347187090",							"value": "g"						},						{							"id": "UOM!VolumenContenidoNeto!VolumenContenidoNeto",							"type": "NUMBER",							"value": "0.0"						},						{							"id": "UOM!VolumenContenidoNeto!Unidad",							"type": "LOOKUP_TABLE",							"featureGroupID": "213",							"id_Ext": "347188090",							"value": "ml"						}					]				},				{					"id": "ColoresYTallas",					"type": "GROUPING",					"children": [						{							"id": "TamanoHorma",							"type": "STRING",							"value": "SIMPSONS"						},						{							"id": "Dibujo",							"type": "STRING",							"value": "1508"						}					]				},				{					"id": "Variantes",					"type": "GROUPING",					"children": [						{							"id": "CodigoVarianteWeb",							"type": "STRING",							"value": "A15990764"						},						{							"id": "VariantesTallas",							"type": "FLAG",							"value": "false"						},						{							"id": "VariosCol