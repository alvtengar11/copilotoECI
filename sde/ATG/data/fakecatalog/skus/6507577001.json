uenta de que es la única que lo entiende. Es la única capaz de calmarle... él la necesita. Pero el secreto que esconde es tan grande que Hardin se aleja cada vez más de todo y de todos, incluso de la que parece ser su alma gemela?</p>"}]}]},{"id":"Ficcion","type":"FLAG","value":"false"},{"id":"CodigoSituacion","type":"STRING","value":"FV"}]},{"id":"NombreAutor","type":"STRING","value":"ANNA_TODD_"},{"id":"Autor","ocurrence":0,"type":"GROUPING","children":[{"id":"CodigoAutor","type":"RELATIONSHIP","groupID":"2002","id_Ext":"3436313051","value":"13043850"}]},{"id":"OtrasCaracteristicas","type":"GROUPING","children":[{"id":"Traductor","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Traducciones Imposibles, S. L."}]}]},{"id":"Estilos","type":"GROUPING","children":[{"id":"Estilo1","type":"STRING","value":"001"},{"id":"Estilo2","type":"STRING","value":"002"},{"id":"Estilo3","type":"STRING","value":"000"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20150816_000000"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"233767090","value":"010"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20150324_000000"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"XPUBLICA","type":"STRING","value":"D"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"true"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER"}]},{"id":"/Carteleria_ISS","type":"SPEC","chil