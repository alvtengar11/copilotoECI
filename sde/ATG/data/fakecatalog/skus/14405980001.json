						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "El cepillo de dientes eléctrico Oral-B Stages Power Kids, con los divertidos y simpáticos personajes de Frozen de Disney, permite que los pequeños también disfruten de una excelente limpieza bucal."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Este cepillo eléctrico recargable incorpora filamentos extrasuaves para la boca de los más pequeños y es compatible con la aplicación Disney MagicTimer de Oral-B. Descarga la aplicación para que tus hijos se cepillen durante los dos minutos que recomiendan los dentistas, y adquieran hábitos de cuidado bucodental saludables que les serán útiles toda la vida."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Beneficios:"
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "El cabezal giratorio alcanza, rodea y limpia en profundidad múltiples superficies."
								},
								{
									"id": "es_ES",
									"ocurrence": 4,
									"type": "STRING",
									"value": "Filamentos extrasuaves que limpian los dientes con la misma suavidad que un cepillo manual suave."
								},
								{
									"id": "es_ES",
									"ocurrence": 5,
									"type": "STRING",
									"value": "Elimina más placa que un cepillo manual normal."
								},
								{
									"id": "es_ES",
									"ocurrence": 6,
									"type": "STRING",
									"value": "Consigue que el cepillado sea más divertido con los personajes de Frozen de Disney."
								},
								{
									"id": "es_ES",
									"ocurrence": 7,
									"type": "STRING",
									"value": "Compatible con la aplicación Disney MagicTimer de Oral-B para que. los niños se cepillen los dientes durante más tiempo"
								},
								{
									"id": "es_ES",
									"ocurrence": 8,
									"type": "STRING",
									"value": "Batería recargable que dura hasta 5 días."
								}
							]
						}
