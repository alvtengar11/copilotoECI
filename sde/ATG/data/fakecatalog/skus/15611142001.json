e":"true"},{"id":"ReferenciaDigital","type":"FLAG","value":"false"},{"id":"AnillosDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"false"},{"id":"PartidaArancelaria","type":"STRING","value":"8418108099"},{"id":"Atue","type":"STRING","value":"22K"},{"id":"CertificadoCE","type":"FLAG","value":"false"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0239061"},{"id":"NombreProveedor","type":"STRING","value":"SAMSUNG ELECTRONICS IBERIA, S.A."},{"id":"Fabricante","type":"STRING","value":"0239061"},{"id":"DescripcionFabricante","type":"STRING","value":"SAMSUNG ELECTRONICS IBERIA, S.A."},{"id":"Marca","type":"STRING","value":"SAMSUNG"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Samsung","groupID":"391","id_Ext":"122381056"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"TituloNombreDescripcionArticuloWeb","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"A+, altura 163,5 cm, blanco"}]},{"id":"DescripcionTicket","type":"STRING","value":"G.ELECTRODOM."}]},{"id":"DescripcionLargaDelProducto","type":"GROUPING","ocurrence":0,"children":[{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","type":"STRING","ocurrence":0,"value":"Mantém a frescura dos alimentos com elevados níveis de humidade\nO sistema Twin Cooling Plus™, com arrefecimento independente de cada compartimento permite que o ar fresco circule em todos os cantos do equipamento, mantendo a temperatura uniforme e constante, de forma a preservar os alimentos frescos com um nível de humidade de até 70%, face aos 30% de um combinado convencional*. Assim, os alimentos permanecem frescos durante mais tempo."},{"id":"pt_PT","type":"STRING","ocurrence":1,"value":"Alimentos congelados, saborosos e sem odor\nNos equipamentos com 1 evaporador, os odores do frigorífico passam para os alimentos congelados, uma vez que os compartimentos estão interligados. O sistema Twin Cooling Plus tem 2 Evaporadores (1 para o frigorífico e 1 para o Congelador) permitindo um arrefecimento independente de cada compartimento. Desta forma, impede a passagem de ar entre os dois compartimentos, mantendo o sabor original dos alimentos congelados."},{"id":"pt_PT","type":"STRING","ocurrence":2,"value":"Smart Conversion (Frigorífico 4-em-1)\nMáxima flexibilidade. Converta facilmente o seu congelador num frigorífico para manter frescos todos os alimentos que precisa guardar para diferentes estações ou ocasiões especiais. Pode também mudar para o modo de desligado* para poupar energia, dependendo das especificações."},{"id":"pt_PT","type":"STRING","ocurrence":3,"value":"Durabilidade, Eficiência e Menor Ruído\nA tecnologia Digital Inverter ajusta automaticamente a velocidade do compressor para 7 níveis diferentes, de acordo com a necessidade de refrigeração. Consome menos energia, diminui o ruído e tem maior durabilidade, a qual é reforçada pelos 10 anos de garantia."},{"id":"pt_PT","type":"STRING","ocurrence":4,"value":"Iluminação LED\nA iluminação LED de elevada eficácia é mais discreta, mais fria e energeticamente mais eficaz do que a iluminação convencional Samsung."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"R"},{"id":"Calificacion3","type":"STRING","value":"B5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AE"},{"id":"TipoDeGestion","type":"STRING","value":"00"}]},{"id":"DimensionesYPeso","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm","featureGroupID":"204