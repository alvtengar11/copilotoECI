G","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EsAlcohol","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"PartidaArancelaria","type":"STRING","value":"8517699000"},{"id":"Atue","type":"STRING","value":"208"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0203612"},{"id":"NombreProveedor","type":"STRING","value":"GARMIN IBERIA, S.A.U."},{"id":"Fabricante","type":"STRING","value":"0203612"},{"id":"DescripcionFabricante","type":"STRING","value":"GARMIN IBERIA, S.A.U."},{"id":"Marca","type":"STRING","value":"GARMIN"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"123748056","value":"GARMIN"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"NOVEDAD 12"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Reloj inteligente para carrera con GPS y funciones de entrenamiento avanzadas"},{"id":"en_GB","type":"STRING","value":"Smart running watch with GPS and advanced training features"},{"id":"fr_FR","type":"STRING","value":"Montre intelligente de course avec GPS et fonctions d'entraînement avancées"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Evalúa tu estado de entrenamiento para indicar si te conviene otra sesión esta semana o si te has ejercitado en exceso y necesitas un día de descanso; ofrece funciones de seguimiento del rendimiento adicionales"},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Recibe planes de entrenamiento adaptables gratuitos gracias al Garmin Coach o crea tus propias sesiones de entrenamiento personalizadas en nuestra comunidad virtual de deporte Garmin Connect(TM)"},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Proporciona datos de dinámica de carrera avanzados, incluidos el equilibrio de tiempo de contacto con el suelo, la longitud de zancada o el ratio vertical, entre otros"},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Funciones de seguridad y seguimiento, como la detección de incidencias integrada, te permiten compartir tu ubicación con facilidad"},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Personaliza tu reloj con pantallas gratuitas, aplicaciones y mucho más de nuestra Tienda Connect IQ(TM)"},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"Autonomía de la batería: hasta 7 días en modo reloj inteligente; hasta 24 horas en modo GPS"},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"Tú te encargas de correr. Y el Forerunner 245 de pensar. Este reloj inteligente con GPS no solo te indica por dónde has estado corriendo. Realiza un seguimiento de tus estadísticas, procesa los datos y averigua todo sobre tu rendimiento, técnica, historial de entrenamiento e, incluso, tus objetivos personales. Solo te tendrás que preocupar de ir colocando un pie delante de otro."},{"id":"en_GB","ocurrence":0,"type":"STRING","value":"Evaluates your training status to show you whether another training session this week is a good idea or if you have exercised excessively and need a rest day; features additional performance tracking functions"},{"id":"fr_FR","ocurrence":0,"type":"STRING","value":"Évaluez votre état d'entraînement pour indiquer si vous avez besoin d'une autre séance cette semaine ou si vous avez trop entraîné et avez besoin d'un jour de repos ; comprend des fonctions de suivi du rendement supplémentaires"}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Análisis de rendimiento avanzado"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"¿Cuánto entrenamiento es apropiado para ti? Forerunner 245 ofrece un entrenamiento individualizado y consejos para la recuperación con los que podrás tomar mejores decisiones en cuanto al entrenamiento y te ayudará a prepararte para la próxima carrera. Controla el VO2 máximo y entiende cómo afectan al rendimiento el calor y la altitud. Cuanto mayor sea este número, más probabilidades tendrás de alcanzar un buen rendimiento, que es exactamente lo que indica la condición de rendimiento . El estado de entrenamiento evalúa automáticamente tu historial de ejercicio reciente y tus indicadores de rendimiento, para que sepas si tu entrenamiento es productivo, si has llegado a tu pico de forma o si estás realizando un sobreesfuerzo. Comprueba cómo influyen tus entrenamientos en el desarrollo de la resistencia, la velocidad y la potencia con información de Training Effect aeróbico y anaeróbico . El tiempo de recuperación te ayuda a maximizar los beneficios de tu esfuerzo prediciendo cuándo te encontrarás en condiciones de enfrentarte al siguiente desafío. También puedes ver tu carga de entrenamiento general, que mide el volumen de ejercicio de los últimos 7 días y lo compara con el intervalo óptimo para tu condición física y tu historial de entrenamiento reciente."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":2,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"Más formas de entrenar"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Si lo que te gusta es correr, entrena de forma más inteligente con las herramientas disponibles en nuestra comunidad virtual de deporte Garmin Connect . Crea tus propios entrenamientos personalizados o descarga entrenamientos gratuitos para sincronizarlos directamente con el reloj. O, si tienes un objetivo específico en mente para tu próximo 5K, prueba el Garmin Coach. Con la orientación de expertos entrenadores y planes de entrenamiento gratuitos que se adaptan a ti y a tus metas, resulta un método infalible para llegar a la línea de meta. Como parte del plan de entrenamiento, puede incluso ayudarte a predecir tu tiempo de carrera. ¿Qué ocurre cuando quieras un cambio? Forerunner 245 también cuenta con perfiles de actividad para ciclismo, natación en piscina, ejercicios con ergómetro e incluso para entrenar con elíptica o escaladora."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":3,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Analiza tu técnica de carrera"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"El reloj con GPS Forerunner 245 además ofrece las herramientas que necesitas para mejorar tu técnica de carrera. Mide métricas de carrera importantes como la cadencia, la longitud de zancada, el equilibrio y el tiempo de contacto con el suelo, la oscilación vertical y el ratio vertical. Estas medidas son la clave para comprender tu técnica, por lo que podrás dar lo mejor de ti en cada carrera y en cada competición. El Forerunner 245 puede iniciar el seguimiento de estas métricas si añades una correa de frecuencia cardiaca compatible o el compacto Running Dynamics Pod, que se engancha cómodamente en la cinturilla del pantalón."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":4,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Sigue conectado mientras corres"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Forerunner 245 te permite correr sin dejar de lado funciones inteligentes importantes. Cuando lo hayas vinculado con tu smartphone compatible, podrás recibir mensajes de texto, así como ver las novedades en tus redes sociales o los mensajes de correo electrónico, entre otras posibilidades, directamente en tu muñeca. Las nuevas funciones de seguimiento y seguridad facilitarán que compartas tu ubicación con los contactos que elijas en caso de que necesites ayuda, de forma manual o automática, con la tecnología de detección de incidencias integrada, si es necesario. Así que ponte las zapatillas y sal a hacer deporte con un poco más de tranquilidad."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":5,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Comparte y compite"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"El reloj inteligente Forerunner 245 incluye herramientas para ayudarte a mantener el control de tu bienestar general y el sueño. Estas herramientas proporcionan información esencial para maximizar tu entrenamiento. Por ejemplo, es nuestro primer reloj de carrera que incluye un pulsioxímetro. Este sensor efectúa mediciones en la muñeca y permite estimar la saturación de oxígeno en sangre para medir cómo absorbe el oxígeno tu cuerpo, sobre todo mientras duermes. Y para optimizar la energía de tu cuerpo, el monitor de energía Body Battery(TM) calcula tus reservas de energía en cualquier momento gracias a los datos recopilados, para que puedas planificar tu jornada y optimizar los tiempos de actividad y descanso."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":6,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Contenido de la caja:"},{"id":"en_GB","type":"STRING","value":"Box content:"},{"id":"fr_FR","type":"STRING","value":"Contenu de la caisse :"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Forerunner 245, Cable cargador/datos y Documentación"}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":7,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Nota importante:"},{"id":"en_GB","type":"STRING","value":"Warning:"},{"id":"fr_FR","type":"STRING","value":"Remarque importante :"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Los smartphones y otros dispositivos no van incluidos, se venden por separado."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"E5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AC"},{"id":"Calificacion6","type":"STRING","value":"BA"},{"id":"TipoDeGestion","type":"STRING","value":"00"}]},{"id":"DimensionesYPeso","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","featureGroupID":"204","id_Ext":"347186090","value":"cm"},{"id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","featureGroupID":"206","id_Ext":"347187090","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","featureGroupID":"213","id_Ext":"347188090","value":"ml"}]},{"id":"ColoresYTallas","type":"GROUPING","children":[{"id":"ColorFabricante","type":"STRING","value":"BLACK/SLATE"},{"id":"DescripcionDelColor","type":"LOOKUP_TABLE","featureGroupID":"135","id_Ext":"347149090","value":"Negro"},{"id":"ColorBasico","type":"LOOKUP_TABLE","featureGroupID":"10153","id_Ext":"21366602090","value":"Negros"},{"id":"TamanoHorma","type":"STRING","value":"PV191"}]},{"id":"Variantes","type":"GROUPING","children":[{"id":"CodigoVarianteWeb","type":