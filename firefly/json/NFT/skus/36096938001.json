romiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8517620000"},{"id":"Atue","type":"STRING","value":"218"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0233700"},{"id":"NombreProveedor","type":"STRING","value":"VINZEO TECHNOLOGIES SA"},{"id":"Fabricante","type":"STRING","value":"0233700"},{"id":"DescripcionFabricante","type":"STRING","value":"VINZEO TECHNOLOGIES SA"},{"id":"Marca","type":"STRING","value":"XIAOMI"},{"idExt":"15759673056","id_Ext":"15759673056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"XIAOMI"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"XIAOMI TV STICK"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Xiaomi Mi TV Stick. El contenido va contigo"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Este pequeno aparelho transforma a sua TV antiga numa Smart TV, oferecendo a oportunidade de transmitir conteúdo de streaming no ecrã grande e até mesmo jogar com as suas aplicações favoritas."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Uma das razões pelas quais devemos comprar a Xiaomi Mi Stick TV é o seu design. À primeira vista, pode parecer um tanto insignificante, mas neste produto faz todo o sentido, pois este aparelho com dimensões pequenas oferece o mesmo que uma TV Box em termos de funções, embora acrescente muitas mais vantagens, devido às suas características estéticas."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"Uma das vantagens é a simplicidade da sua portabilidade. Poderá colocá-la em qualquer bolso e levá-lo para o apartamento do seu amigo para ver um filme juntos ou na casa da praia para desfrutar ainda mais das férias. Não vai precisar de mais nada, uma vez que a Mi Stick TV é conectado diretamente à porta HDMI da TV, que fica escondido por detrás da sua TV e acaba com a diversão do seu gato em destruir cabos. Claro, também possui o design minimalista e elegante da Xiaomi, desta vez em preto."},{"ocurrence":3,"id":"pt_PT","type":"STRING","value":"E, agora, vamos com a sua principal utilidade. Com a Xiaomi Mi Stick TV, pode ter acesso direto ao conteúdo de streaming das suas plataformas favoritas, e o Amazon Prime Video e o Netflix já vêm pré-instalados. Só terá que pressionar um botão no seu comando para ter acesso diretamente a estes dois serviços."},{"ocurrence":4,"id":"pt_PT","type":"STRING","value":"No entanto, a Xiaomi Mi Stick TV inclui a Google Play Store para descarregar as aplicações que deseja, do YouTube e Spotify até vários jogos. Tudo isto fornecido pelo sistema operacional Android TV 9.0, que melhora o desempenho da nossa TV Xiaomi Mi Stick. Um sistema inteligente para entretenimento inteligente."},{"ocurrence":5,"id":"pt_PT","type":"STRING","value":"Se estiver cansado demais após um longo dia, agarre apenas o comando da sua Xiaomi Mi Stick TV, deite-se no sofá com uma bebida fresca e pressione o botão no microfone. Desta forma, vai \"acordar\" o assistente do Google, que ajuda a controlar todo o sistema simplesmente usando a sua voz."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Reproductor portatil de contenidos streaming. Desarrollado en Android TV. Con Google Assistant y Smart Cast"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Con menos de 30g, el Mi Tv Stick es lo suficientemente pequeño como para caber en tu bolsillo. ¡Olvídate de los cables, conéctalo a cualquier TV, monitor o proyector con un puerto HDMI para convertirlo en una smart TV!"},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Configura tu Mi TV Stick en un instante. Con sólo tres sencillos pasos puedes empezar a disfrutar de todo lo que ofrece el Mi TV Stick en un abrir y cerrar de ojos"},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Utiliza Google Play Store para descargar tus aplicaciones de streaming y de juegos favoritas y permanece entretenido durante horas. Cuenta con botones de acceso rápido a Netflix y Prime Video"},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"Mi TV Stick funciona con Android TV 9.0, que es compatible con la búsqueda por voz y con Chromecast"},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"Con el Chromecast incorporado puedes fácilmente emitir videos y otros contenidos de tu teléfono, tablet o portátil directamente a la pantalla del televisor en 1080p."},{"ocurrence":6,"id":"es_ES","type":"STRING","value":"Mi TV Stick es compatible con la decodificación de audio HD multicanal DTS. El resultado es un sonido envolvente estéreo más suave, dinámico, inmersivo y realista durante la reproducción de vídeo Blu-ray ultra HD"}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Especificaciones"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"CPU Cortex-A53 de cuatro núcleos"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"GPU ARM Mali-450"},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"RAM 1 GB"},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Almacenamiento 8GB"},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"Sistema operativo Android 9.0"},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"Wi-Fi 802.11a/b/g/n/ac 2.4GHz/5GHz"},{"ocurrence