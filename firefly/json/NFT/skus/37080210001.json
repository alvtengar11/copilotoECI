G","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternet","type":"FLAG","value":"true"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8518210000"},{"id":"Atue","type":"STRING","value":"213"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0233700"},{"id":"NombreProveedor","type":"STRING","value":"VINZEO TECHNOLOGIES SA"},{"id":"Fabricante","type":"STRING","value":"0233700"},{"id":"DescripcionFabricante","type":"STRING","value":"VINZEO TECHNOLOGIES SA"},{"id":"Marca","type":"STRING","value":"XIAOMI"},{"idExt":"15759673056","id_Ext":"15759673056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"XIAOMI"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"XIAOMI MI SMART LED B"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Bombilla inteligente Xiaomi Mi LED Smart Bulb Essential (Blanco y Color) 9W E27"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Conexão Wi-Fi\n\nConecte-se à sua rede Wi-Fi para poder controlá-la facilmente a partir do seu smartphone a qualquer momento e em qualquer lugar. Não há necessidade de um centro adicional de controlo de aplicações inteligentes."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Controlo remoto via Xiaomi Home APP / Mi Home App\n\nSuporta funções inteligentes, como configuração de hora, controlo de vários grupos de luzes, modo nascer do sol, etc. Pode conectar-se aos dispositivos mais inteligentes através da aplicação My Home."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"Controlo de voz inteligente\n\nTrabalhe com o Google Assistant, Alexa. Use a sua voz para ativar ou desativar a luz, alterar a cor, a temperatura da cor e o brilho."},{"ocurrence":3,"id":"pt_PT","type":"STRING","value":"Eficiência energética e longa vida útil\n\nÉ muito eficiente em termos energéticos e tem uma vida útil de até 25.000 horas. Isto significa que, com 3 horas por dia de uso, a lâmpada pode durar até 22,8 anos."},{"ocurrence":4,"id":"pt_PT","type":"STRING","value":"Brilho ajustável. Brilho ajustável de 80 a 950 lm"},{"ocurrence":5,"id":"pt_PT","type":"STRING","value":"Temperatura de cor ajustável. Definir temperatura da cor... entre 1700 e 6500 k"},{"ocurrence":6,"id":"pt_PT","type":"STRING","value":"Cores ajustáveis deslumbrantes\n\nA iluminação em cores RGB permite que o Mi Smart LED Bulb forneça várias cores para qualquer situação."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Llena tu casa de luz con la bombilla Xiaomi Mi LED Smart Bulb Essential. Control inteligente e iluminación personalizada."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Mi LED Smart Bulb ha sido diseñada, ante todo, para ser una bombilla práctica; desde su forma hasta sus materiales cuidadosamente seleccionados. Su sencillo diseño en forma de cruz le da una apariencia elegante a la vez que asegura que el calor se disipe fácilmente."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Conexión Wi-Fi (sin puentes). Conéctate a tu red Wi-Fi para que puedes controlarla fácilmente desde tu smartphone en cualquier momento, desde cualquier lugar"},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Control remoto a través de Xiaomi Home APP/Mi Home App"},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"Control de voz inteligente. Trabaja con Google Assistant. Usa la voz para encender o apagar la luz, cambiar el color, la temperatura del color y el brillo.\nEficiencia energética y larga vida útil. Es muy eficiente en cuanto a la energía y tiene un vida útil de hasta 25.000 horas. Eso significa que con 3 horas por día de uso, la bombilla puede durar hasta 22,8 años"},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"Brillo ajustable. Brillo regulable desde 80 a 950 lm\nTemperatura de color ajustable. Establecer la temperatura de color... en cualquier lugar entre 1700k a 6500k\nDeslumbrantes colores ajustables. La iluminación de color RGB permite a Mi Bombilla LED inteligente para proporcionar varios colores para cualquier situación"}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Fluxo luminoso até 950 lm\nTemperatura de cor 1700 - 6500 k\nAdaptador da lâmpada E27\nEntrada nominal 220 - 240 V ~ 50/60 Hz, 0,07A\nPotência nominal 9w\nDimensões 50 x 50 x 120mm\nVida útil aprox. 25000 horas\nOn / off 12500 ciclos\nConectividade sem fio IEEE 802.11b / g / n 2.4 GHz Wi-Fi\nCompatível com Android 4.4, iOS 9.0 ou superior"}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"E"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"WW"},{"id":"TipoDeGestion","type":"STRING","value":"06"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type