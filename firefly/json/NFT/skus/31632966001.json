odificacion","type":"FLAG","value":"false"},{"id":"EsAlcohol","type":"FLAG","value":"false"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"9504500000"},{"id":"Atue","type":"STRING","value":"19D"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0002625"},{"id":"NombreProveedor","type":"STRING","value":"MERIDIEM GAMES SLU"},{"id":"Fabricante","type":"STRING","value":"0002625"},{"id":"DescripcionFabricante","type":"STRING","value":"MERIDIEM GAMES SLU"},{"idExt":"10229140056","id_Ext":"10229140056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"MERIDIEM GAMES"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"TOKI"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"¡Toki vuelve a la aventura! El mítico juego de acción/plataformas, publicado inicialmente en 1989 para máquinas recreativas, regresa en una nueva versión de lo más simiesca."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Para salir de esta, deberás apañártelas con lo que tienes. ¡Afortunadamente, Toki sabe caminar, saltar, nadar, trepar y escupir! Es precisamente su saliva, hábilmente utilizada, la que permitirá a Toki librarse de sus enemigos... «Insert coin»\u2026 ¡Una y otra vez hasta llegar al final de la aventura! ¿Te dejaste una fortuna en las máquinas recreativas? Ha llegado el momento de tomarte la revancha jugando en condiciones más cómodas, pero con un estilo de juego igual de exigente. ¡Deja inscrito tu nombre entre las máximas puntuaciones! Y para los recién llegados, también existe un nuevo modo más asequible."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"El juego ha sido completamente redibujado a mano por Philippe Dessoly, ilustrador de mangas tan célebres como Capitán Harlock y UFO Robot Grendizer, y dibujante de diversos cómics y videojuegos. Allá por 1991, ya había participado en la versión Amiga de Toki, y también dibujó para el juego Mr. Nutz (1992). Ahora, sus trazos hacen posible que Toki regrese más guapo y más chiflado que nunca."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"La música, íntegramente reorquestada por el compositor Raphaël Gesqua, promete una aventura salpicada de notas retro a la par que modernas. Este galardonado músico ha sido autor de composiciones para cerca de un centenar de videojuegos."},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"A nivel técnico, la proeza que supone esta palpitante experiencia se la debemos al inmenso trabajo de Pierre Adane. Este desarrollador trabajó principalmente en Mr. Nutz (1992), además de crear el juego de tenis Top Spin (2003)."},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"Incluye un modo Speedrun, sistema de guardado rápido y 5 filtros extra para disfrutar de la experiencia más arcade."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"E"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"B"},{"id":"Calificacion6","type":"STRING","value":"MW"},{"id":"TipoDeGestion","type":"STRING","value":"06"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!Vol