dificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"417533485"}],"id":"/Product_CPS","type":"SPEC"}],"unlink":[],"specificAttribs":[{"children":[{"children":[{"children":[{"id":"es_ES","type":"STRING","value":"LITERATURA"}],"id":"Tema","type":"STRING"},{"children":[{"id":"es_ES","type":"STRING","value":"ERÓTICA"}],"id":"Materia","type":"STRING"},{"id":"Titulo","type":"STRING","value":"En los zapatos de valeria (saga valeria 1)"},{"children":[{"idExt":"31455845053","id_Ext":"31455845053","groupID":"2004","id":"TipoColeccion","type":"RELATIONSHIP","value":"20190224022049"},{"ocurrence":0,"id":"Numero","type":"STRING","value":"026200"}],"id":"Coleccion","type":"GROUPING"},{"children":[{"idExt":"347421090","featureGroupID":"418","id_Ext":"347421090","id":"TipoFormato","type":"LOOKUP_TABLE","value":"Bolsillo"},{"idExt":"347421090","featureGroupID":"418","ocurrence":0,"id_Ext":"347421090","id":"FormatoEncuadernacion","type":"LOOKUP_TABLE","value":"Bolsillo"},{"idExt":"10121051090","featureGroupID":"418","ocurrence":1,"id_Ext":"10121051090","id":"FormatoEncuadernacion","type":"LOOKUP_TABLE","value":"Tapa blanda"},{"idExt":"9651455090","featureGroupID":"420","id_Ext":"9651455090","id":"Encuadernacion","type":"LOOKUP_TABLE","value":"Tapa blanda"}],"id":"Formato","type":"GROUPING"},{"id":"Edicion","type":"INTEGER","value":"1"},{"children":[{"id":"UOM!Dimensiones!Alto","type":"NUMBER","value":"19.1"},{"id":"UOM!Dimensiones!Ancho","type":"NUMBER","value":"12.7"},{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"id":"UOM!Peso!Peso","type":"INTEGER","value":"332"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!Peso!Unidad","type":"LOOKUP_TABLE","value":"g"}],"id":"Dimensiones","type":"GROUPING"},{"id":"NumPaginas","type":"NUMBER","value":"480.0"},{"idExt":"347423090","featureGroupID":"157","ocurrence":0,"id_Ext":"347423090","id":"Idioma","type":"LOOKUP_TABLE","value":"Castellano"},{"idExt":"347423090","featureGroupID":"157","id_Ext":"347423090","id":"IdiomaOriginal","type":"LOOKUP_TABLE","value":"Castellano"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"<p><B>Engánchate al fenómeno <I>Valeria<\/I> de @BetaCoqueta, una saga altamente divertida, emotiva y sensual.<\/B><\/P> <p><B>¡Te vas a enamorar!<\/B><\/P> <P>Valeria es escritora de historias de amor.<BR>Valeria vive el amor de forma sublime.<BR>Valeria tiene tres amigas: Nerea, Carmen y Lola.<BR>Valeria vive en Madrid.<BR>Valeria ama a Adrián hasta que conoce a Víctor.<BR>Valeria necesita sincerarse consigo misma.<BR>Valeria llora, Valeria ríe, Valeria camina...<BR>Pero el sexo, el amor y los hombres no son objetivos fáciles.<BR>Valeria es especial.<BR><B>Como tú.<\/B><\/P> <P><B><I>En los zapatos de Valeria<\/I><\/B> es el primer libro de la <B>«Saga Valeria»<\/B>, la primera obra de <B>Elísabet Benavent<\/B>, que inició su  carrera literaria autopublicándose y que en poco tiempo conquistó a  cientos de lectores y se situó en los primeros puestos de la lista de más vendidos de ficción.<\/P> <P>Posteriormente la autora, también conocida por sus fans como <B>@BetaCoqueta<\/B>, ha continuado cosechando grandes éxitos con la  publicación de su <B>«Saga Silvia»<\/B>, la trilogía <B>«Mi elección»<\/B>, la bilogía <B>«Horizonte Martina»<\/B>, la bilogía «Canciones y recuerdos»  y las novelas <I><B>Mi isla<\/B><\/I>, <I><B>Toda la verdad de mis mentiras<\/B><\/I>, <I><B>Un cuento perfecto<\/B><\/I> y <I><B>El arte de engañar al karma<\/B><\/I>.<\/P> <p><B>Más de 3.000.000 de ejemplares vendidos.<\/B><BR><B>«Elísabet Benavent es la voz masiva de una generación».<\/B><BR><B>Jesús Ruiz Mantilla,  <I>El País<\/I><\/B><\/P> <P><B>La crítica ha dicho...<\/B><BR>«Divertida, sensual, tierna [...]. Una oportunidad de descubrir el amor  y soñar con la vida que cada una nos merecemos.»<BR><I>Revista AR<\/I><\/P> <P>«No sé cómo me ha secuestrado Benavent pero exijo un duelo al amanecer  por las horas que me ha robado o, en su defecto, las siguientes peripecias de estas mujeres.»<BR>Web <I>Mideclipse<\/I><\/P> <P>«Sentiremos en nuestras carnes las vidas de las cuatro mujeres que  campan a sus anchas por las páginas y nos veremos identificados: nos  reiremos porque todos hemos cometido alguna de las estupideces que nos  propone Elísabet Benavent, se nos encogerá el puño cuando veamos lo que  sufren las protagonistas, y cerraremos el libro esperando mucho más de  estas cuatro amigas que luchan entre la jauría madrileña para ser  felices, para labrarse un futuro, y para sentirse ellas mismas, incluso  cuando la vida es tan puñetera que parece que no hay salida.»<BR>Web <I>Librosyliteratura<\/I><\/P> <P><B>En los blogs...<\/B><BR>«Está siendo un fenómeno literario [...]. Es divertida, fresca,  adictiva, tierna, pasional... lo tiene todo.»<BR>Blog <I>Inés y sus libros<\/I><\/P> <P>«Encontraréis elementos que harán la novela irresistible. Hay amor,  pasión, erotismo [...], también habrá situaciones de mucho humor.»<BR>Blog <I>Promesas de amor<\/I><\/P> <P>«Este es un libro muy fresco, divertido, rápido de leer y"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"que te deja con ganas de más. [...] Un libro que me ha sorprendido.»<BR>Blog  <I>Cazadoras del romance<\/I><\/P> <P>«<I>En los zapatos de Valeria<\/I> ha sido toda una revelación, una novela  muy entretenida, fresca, aparentemente divertida pero que  guarda  muchísimos sentimientos y escenas tan cercanas que cualquiera de nosotras podría sentirse identificada.»<BR>Blog <I>Paisajes románticos<\/I><\/P> <P>«Un libro fresco, moderno, divertido, entretenido y ameno que nos hará pasar un momento estupendo entre sus páginas.»<BR>Blog  <I>Momentos de silencio compartido<\/I><\/P>"}],"id":"Descripcion","type":"STRING"}],"id":"Descripcion","type":"GROUPING"},{"id":"Ficcion","type":"FLAG","value":"false"},{"id":"CodigoSituacion","type":"STRING","value":"FV"}],"id":"CaracteristicasGenerales","type":"GROUPING"},{"ocurrence":0,"children":[{"idExt":"1773189051","id_Ext":"1773189051","groupID":"2002","id":"CodigoAutor","type":"RELATIONSHIP","value":"24021625"}],"id":"Autor","type":"GROUPING"},{"children":[{"id":"Estilo1","type":"STRING","value":"001"},{"id":"Estilo2","type":"STRING","value":"020"},{"id":"Estilo3","type":"STRING","value":"000"}],"id":"Estilos","type":"GROUPING"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"417533485"}],"id":"/Libros_ISS","type":"SPEC"}],"stores":[{"children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20200529_000000"},{"idExt":"233767090","featureGroupID":"10110","id_Ext":"233767090","id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","value":"010"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20190109_000000"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"true"}],"id":"Fechas","type":"GROUPING"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"417533485"}],"id":"/Fechas_WWW_ISS","type":"SPEC"},{"children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"MostrarSoloRebajado","type":"FLAG","value":"false"},{"id":"FechaDePublicacionHPR","type":"DATE","value":"20200529_000000"},{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"idExt":"233767090","featureGroupID":"10110","id_Ext":"233767090","id":"MotivoPubDesHPR","type":"LOOKUP_TABLE","value":"010"},{"id":"FechaDePrimer