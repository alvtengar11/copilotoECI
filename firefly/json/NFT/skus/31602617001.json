								{
									"id": "pt_PT",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Drivers: 50 mm, com ímanes de neodímio\nResposta de frequência: 12 Hz - 28 kHz\nImpedância: 32 ? @ 1 kHz\nSensibilidade (@1 kHz): 109 dB\nInput power: 30 mW (Max)\nConexão: Jack 3,5m\nComprimento do cabo: 1,3 metros\nPeso do produto: 322 g"
								},
								{
									"id": "pt_PT",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Microfone:\n\nResposta de frequência: 100 Hz - 10 kHz\nRelação sinal-ruído: > 60 dB\nSensibildiade (@1 kHz): -45 ± 3 dB\nPadrão de captação: ECM boom unidirecional"
								}
