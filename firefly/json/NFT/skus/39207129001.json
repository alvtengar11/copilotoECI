sDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8443310000"},{"id":"Atue","type":"STRING","value":"21D"},{"id":"TipoAcuerdoServicio","type":"STRING","value":"N"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0054791"},{"id":"NombreProveedor","type":"STRING","value":"TECH DATA ESPAÑA, S.L. UNIP."},{"id":"Fabricante","type":"STRING","value":"0609586"},{"id":"DescripcionFabricante","type":"STRING","value":"HP PRINTING AND COMPUTING SOLUTIONS"},{"id":"Marca","type":"STRING","value":"HP"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"124619056","value":"HP"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"HP OFFICEJET 8015E"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Impresora Multifunción tinta HP OfficeJet Pro 8015e - 6 meses gratis de impresión Instant Ink con HP+"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"LA MEJOR OPCIÓN PARA LAS PYMES Y LA OFICINA DOMÉSTICA. Imprime, copia y escanea tanto en blanco y negro como en color. \nVelocidad de impresión de 18/10 ppm (negro/color). \nImpresión automática a doble cara. \nTrabaja rápido y en el modo de manos libres gracias al alimentador automático de 35 páginas.\nReduce las interrupciones con la conexión Wi-Fi™ con capacidades de recuperación automática que te mantiene conectado. \nAccede e imprime con una red inalámbrica. \nMás del 15% del peso de eta impresora es plástico reciclado.\nBandeja de entrada de 225 hojas. \nImpresora compatible con los cartuchos de tinta originales HP 912 y con el servicio HP Instant Ink. \nDESCUBRE HP+, la solución de impresión más inteligente. CÓMODA: la impresora solicita tinta automáticamente antes de que se agote; SEGURA y SENCILLA: es más segura y te permite ser más productivo gestionando todo fácilmente, incluso desde el móvil, gracias a la app HP Smart;  SOSTENIBLE: utiliza cartuchos ecodiseñados, +80 % de los cartuchos de Tinta Original HP contienen plástico reciclado.\nELIGE HP+ en la configuración y OBTÉN 1 AÑO ADICIONAL DE GARANTÍA y 6 MESES DE INSTANT INK INCLUIDOS, si te registras a Instant Ink en los 7 días posteriores a la configuración de la impresora. Instant Ink es un servicio de impresión con el que recibes los cartuchos en casa, antes de quedarte sin tinta, con reciclaje incluido y sin preocuparte de nada. Incluye la tinta, el envío y el reciclaje desde solo 0,99 €/mes. \nHP+ requiere una cuenta de HP, una conexión permanente a Internet y el uso exclusivo de Tinta Original HP durante toda la vida útil de la impresora. Más información legal en elcorteingles.es/electronica/hp-plus/"},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Libertad para trabajar en cualquier parte"},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Los costes de los cartuchos de tinta y los gastos de envío se incluyen en el precio del plan mensual. Incluye 2 meses de prueba de Instant Ink"},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Incrementa la productividad con soluciones avanzadas de escaneado y de escaneado rápido a doble cara. 2 meses gratis Instant Ink"},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Elimina pasos en tareas repetitivas con las tareas inteligentes. Escanea en la nube y correo electrónico, entre otras muchas opciones, con un simple toque."},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"Controla los trabajos de impresión, escaneado y copia con tan solo pulsar y deslizar el dedo en la pantalla táctil en color."},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"Crea gráficos en colores intensos y de calidad profesional perfectos para utilizarlos en la oficina y en presentaciones. Independientemente de si imprimes textos o fotos en  lanco y negro o en color, el coste es el mismo."},{"id":"es_ES","ocurrence":7,"type":"STRING","value":"Incluidos 6 meses gratis de Instant Ink HP + y 1 año extra de garantía"}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"HP Instant Ink"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Esta impresora es compatible con el servicio automático de tinta a domicilio HP Instant Ink, un innovador servicio con el que descubrirás una nueva forma de imprimir, mucho más cómoda y asequible\nY es que con Instant Ink, obtienes cartuchos de Tinta Original a un precio mucho más económico y HP te los entrega automáticamente en tu casa u oficina, antes de que se agoten los que estás usando e incluso recicla los antiguos\nExisten planes de impresión flexibles que puedes cambiar o cancelar cuando quieras dependiendo de tus necesidades de impresión de cada momento. Los planes mensuales incluyen la tinta, el envío y el reciclaje de los cartuchos usados"}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Califica