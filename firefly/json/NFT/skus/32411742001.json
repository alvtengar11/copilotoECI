                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Zapato de piel de ante sintético."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Parte superior de cuero de ante sintético robusto, transpirable, parte articulada de cuero suave, inserciones de malla transpirable. Interior de tejido funcional D-Tech tridimensional, transpirable, absorbente de sudor y de secado rápido para un clima agradable de los pies.\nPlantilla antiestática, transpirable y antibacteriana, cama de pies completa en todo momento.\nCierre por cordones."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Puntera de composite para una mayor ligereza, resistente hasta 200 julios. Forro tridimensional, resistente y transpirable. Plantilla textil anti perforación, ligera, flexible y anti magnética."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Suela de onstrucción semisellada eva / nitril con suela Dunlop y suela antiperforazión de kevlar. Antideslizante SRC. Certificación HRO. Ligera y cómoda."
                }
              ]
            }
