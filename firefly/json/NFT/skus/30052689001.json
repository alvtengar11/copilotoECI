:"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"false"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"PartidaArancelaria","type":"STRING","value":"8715009000"},{"id":"Atue","type":"STRING","value":"21J"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0901908"},{"id":"NombreProveedor","type":"STRING","value":"COLUMBUS TRADING PARTNERS GMBH&CO.K"},{"id":"Fabricante","type":"STRING","value":"0901908"},{"id":"DescripcionFabricante","type":"STRING","value":"COLUMBUS TRADING PARTNERS GMBH&CO.K"},{"id":"Marca","type":"STRING","value":"CYBEX"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"134593056","value":"CYBEX"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"PRIAM ESTRUCTURA SILL"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","ocurrence":0,"type":"STRING","value":"Priam Chassis para carrinho de passeio, com detalhes em cromado e castanho. O novo luxo de viagem."},{"id":"pt_PT","ocurrence":1,"type":"STRING","value":"Os requisitos que a Cybex estabelece para o desenvolvimento de um carro são baseados num objetivo simples: oferecer aos pais modernos o melhor produto possível. O novo Priam é o nosso cartão de visita. Inspirado nos designs limpos e intemporais de Ray e Charles Eames, a Cybex desenvolveu um carrinho de passeio que é, não apenas especialmente prático e robusto, como também uma peça de verdadeiro design."},{"id":"pt_PT","ocurrence":2,"type":"STRING","value":"Com os seus produtos, a Cybex permite que os pais transmitam o seu estilo de vida. Por isso, a Cybex criou o novo Priam com um visual sofisticado, linhas estéticas e materiais de elevada qualidade. Como um verdadeiro elemento de design, o novo Priam também se distingue pelo seu sentido prático. O seu novo Travel System 4-em-1 pode ser personalizado usando apenas um único chassis. Com a alcofa leve e confortável do Lite Cot ou a alcofa Lux Carrycot, o sistema transforma-se numa acolhedora cama sobre rodas para o bebé. Em combinação com as premiadas cadeiras auto Cybex, transforma-se num carrinho ágil e confortável. Mais tarde, o Priam é um companheiro de viagem seguro para crianças pequenas, cuja cadeira pode ser colocada voltada para os pais ou voltada para a frente, para o mundo."},{"id":"pt_PT","ocurrence":3,"type":"STRING","value":"O carrinho Priam é fácil de dobrar com uma única mão: dobra-se junto ao chassis, e transforma-se num pacote plano e compacto. Graças a seu dobramento estável, este carrinho pode ser discretamente guardado num restaurante, nos transportes públicos ou em casa. O Priam Lux Seat é reversível e reclina-se com uma única mão até ficar numa posição horizontal, transformando a cadeira numa cama confortável longe de casa."},{"id":"pt_PT","ocurrence":4,"type":"STRING","value":"A nova suspensão de 4 rodas garante um passeio suave, tranquilo e confortável para pais e filhos. A altura do assento está perfeitamente alinhada com a altura média de uma mesa (80 cm), por isso pode ser usada como uma cadeira alta em restaurantes ou cafés. O Cybex Priam tem uma cesta de armazenamento grande e de fácil acesso que pode ser dobrada quando necessário."},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Chasis Priam para Silla de paseo Chrome with brown details, en cromado y marrón. El nuevo lujo de viajar."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Los requisitos que Cybex establece para el desarrollo de un Coche se basan en un simple propósito: ofrecer a los padres modernos el mejor producto posible. El nuevo Priam es nuestra tarjeta de presentación. Inspirado en los diseños nítidos y atemporales de Ray y Charles Eames, Cybex ha desarrollado un cochecito que no sólo es especialmente práctico y robusto, sino que además es una verdadera pieza de diseño."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Con sus productos, Cybex permite que los padres transmitan su estilo de vida. Por ello, Cybex ha diseñado el nuevo Priam con un look sofisticado, líneas estéticas y gran calidad en los materiales. Como auténtico elemento de diseño, el nuevo Priam se distingue también por su sentido práctico. Su nuevo Travel System 4-en-1 puede personalizarse usando sólo un único chasis. Con el cómodo capazo ligero Lite Cot o el Capazo Lux Carrycot, el sistema se transforma en una acogedora cama sobre ruedas para el bebé. En combinación con los galardonados portabebés de Cybex, se convierte en un Coche ágil y cómodo. Más tarde, el Priam sirve a los niños pequeños como un compañero de viaje seguro, cuyo asiento puede ajustarse en dirección hacia los padres o hacia el mundo."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"El Priam es fácil de plegar con una sola mano: su asiento se dobla junto al chasis, convirtiéndose en un paquete plano y compacto. Gracias a su plegado estable, este Coche puede guardarse discretamente en un restaurante, en el transporte público o en casa. El Priam Lux Seat es reversible y se reclina con una sola mano hasta alcanzar una posición horizontal, convirtiendo a la silla en una cómoda cama lejos del hogar."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"La nueva suspensión en las 4 ruedas garantiza un paseo suave, tranquilo y cómodo tanto para los padres como para el niño. La altura del asiento está perfectamente alineada con la altura media de una mesa (80 cm), así que puede utilizarse como trona en restaurantes o cafés. El Priam de Cybex dispone de una amplia cesta portaobjetos de fácil acceso que puede plegarse cuando es necesario."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"pt_PT","type":"STRING","value":"Características:"},{"id":"es_ES","type":"STRING","value":"Características:"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","ocurrence":0,"type":"STRING","value":"Travel System 4-em-1 (Carrinho de passeio, Alcofa Mios Lux, Berço Lite Cot e Carrinho de Bebé Cybex ou Gb)."},{"id":"pt_PT","ocurrence":1,"type":"STRING","value":"Dobra-se com uma única mão."},{"id":"pt_PT","ocurrence":2,"type":"STRING","value":"Cadeira reversível."},{"id":"pt_PT","ocurrence":3,"type":"STRING","value":"Reclina-se com uma única mão."},{"id":"pt_PT","ocurrence":4,"type":"STRING","value":"Suspensão às 4 rodas."},{"id":"pt_PT","ocurrence":5,"type":"STRING","value":"Função de cadeira alta."},{"id":"pt_PT","ocurrence":6,"type":"STRING","value":"Cesta de armazenamento de tamanho XL."},{"id":"pt_PT","ocurrence":7,"type":"STRING","value":"Diâmetro da rodas: 30 cm trás, 19 cm frente."},{"id":"pt_PT","ocurrence":8,"type":"STRING","value":"Dimensões Cadeira Aberta ajustáveis: 40-60 x 96,5-116 x 82,5-92,5 (largura x altura x profundidade) cm."},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Travel System 4-en-1 (Silla de paseo, Capazo Mios Lux, Lite Cot y Portabebés Cybex o Gb)."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Sistema de plegado con una sola mano."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Unidad de asiento reversible."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Reclinado con una sola mano."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Suspensión en las 4 ruedas."},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"Función Trona."},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"Cesta portaobjetos extra grande."},{"id":"es_ES","ocurrence":7,"type":"STRING","value":"Diámetro ruedas: 30 cm. traseras, 19 cm. de