:"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"9504500000"},{"id":"Atue","type":"STRING","value":"21J"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0396952"},{"id":"NombreProveedor","type":"STRING","value":"NINTENDO IBERICA, S.A."},{"id":"Fabricante","type":"STRING","value":"0396952"},{"id":"DescripcionFabricante","type":"STRING","value":"NINTENDO IBERICA, S.A."},{"idExt":"126938056","id_Ext":"126938056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Nintendo"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"NINTENDO SWITCH GRIS"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Vive a experiência de uma consola de videojogos doméstica mesmo sem um ecrã de TV. A Nintendo Switch tem a capacidade de se adequar à tua situação, permitindo-te assim jogar o que quiseres independentemente do tempo de que disponhas. Estamos numa nova era em que já não precisas de ajustar o teu dia a dia para jogar. Agora é a tua consola que se ajusta aos teus horários e necessidades. Joga quando, onde e como quiseres."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Três modos de jogo:"},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"Modo TV - Reúne amigos e familiares em torno da TV. Coloca a Nintendo Switch na base para jogares em HD na tua TV."},{"ocurrence":3,"id":"pt_PT","type":"STRING","value":"Modo de superfície estável - Partilha o ecrã e a diversão. Vira o suporte para partilhares o ecrã e partilha depois a diversão num título multijogadores."},{"ocurrence":4,"id":"pt_PT","type":"STRING","value":"Modo portátil - Leva um ecrã impressionante para onde quer que vás. Pega na consola e joga com os Joy-Con encaixados."},{"ocurrence":5,"id":"pt_PT","type":"STRING","value":"A Nintendo Switch conta com dois comandos que podem ser utilizados em conjunto: os Joy-Con. Se colocares os dois comandos Joy-Con no seu suporte, funcionarão como um só comando tradicional. Sem este suporte, cada um deles funciona como um comando individual, de forma autónoma."},{"ocurrence":6,"id":"pt_PT","type":"STRING","value":"Cooperação local - Joga com amigos no ecrã da TV lá de casa (poderão ser necessários comandos adicionais, à venda em separado)."},{"ocurrence":7,"id":"pt_PT","type":"STRING","value":"Sem fios local - É possível sincronizar até oito consolas Nintendo Switch ou Nintendo Switch Lite e participar em títulos com opções multijogadores em cooperação ou competição."},{"ocurrence":8,"id":"pt_PT","type":"STRING","value":"Multijogadores online - Se subscreveres o serviço Nintendo Switch Online, poderás jogar com amigos ou utilizadores de qualquer parte do mundo, aceder a um catálogo de jogos NES em expansão com mais opções de jogo online ou usufruir de ofertas exclusivas como TETRIS® 99 e o programa de vouchers para jogos da Nintendo Switch, entre muito mais!"},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"La consola doméstica que se hace portátil. Disfruta de una experiencia de consola doméstica incluso sin televisor. ¿Alguna vez has dejado un juego por falta de tiempo?"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"La consola Nintendo Switch puede transformarse para adaptarse a tu situación, de modo que puedes jugar a los juegos que tú quieras por muy ocupado que estés."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Es una nueva era en la que no tienes que adaptar tu vida a los videojuegos: ahora es la consola la que se adapta a tu vida. Disfruta de tus juegos cuando quieras, donde quieras y como quieras con modos de juego flexibles."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Nintendo Switch plantea tres modos de juego que permiten al usuario seguir su partida en cualquier momento y lugar: modo televisor, modo portátil y modo tabletop."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Como consola doméstica se conecta en modo televisor a través de la base Nintendo Switch. Pero en cualquier momento el usuario puede sacar la consola de la base Nintendo Switch y seguir con su partida con completa autonomía en modo portátil."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"En el modo portátil, el usuario juega en una pantalla de 6,2 pulgadas multitáctil con una resolución de 1280 x 720."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Nintendo Switch ofrece las mismas prestaciones multijugador que una consola portátil."},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"El modo tabletop permite que esa pantalla portátil se convierta en un dispositivo multijugador usando los mandos Joy-Con."},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"Batería que ofrece mejor y mayor autonomía.Aproximadamente de 4,5 a 9 horas. La duración de la batería dependerá del programa que estés usando."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AA"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","va