so del tiempo se deforme por el peso. Los largueros y travesaños tienen un grosor de 19 mm."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Su sencillo sistema de apertura impide los roces con el cabecero. Su anclaje con una rótula de bola directamente a la base de la tapa nos ofrece mejor resistencia y respuesta al movimiento lateral."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"NS"},{"id":"Calificacion2","type":"STRING","value":"I"},{"id":"Calificacion3","type":"STRING","value":"E"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AF"},{"id":"Calificacion6","type":"STRING","value":"HH"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"},{"children":[{"id":"CantidadProducto","type":"NUMBER","value":"0.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}],"id":"PUM","type":"GROUPING"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"id":"ColorFabricante","type":"STRING","value":"UNICO"},{"idExt":"347181090","featureGroupID":"135","id_Ext":"347181090","id":"DescripcionDelColor","type":"LOOKUP_TABLE","value":"Blanco"},{"idExt":"351845090","featureGroupID":"10153","id_Ext":"351845090","id":"ColorBasico","type":"LOOKUP_TABLE","value":"Blancos"},{"idExt":"20621838090","featureGroupID":"393","id_Ext":"20621838090","id":"Tallas","type":"LOOKUP_TABLE"