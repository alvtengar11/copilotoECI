mpromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternet","type":"FLAG","value":"true"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"PartidaArancelaria","type":"STRING","value":"8443321000"},{"id":"Atue","type":"STRING","value":"20M"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0233700"},{"id":"NombreProveedor","type":"STRING","value":"VINZEO TECHNOLOGIES SA"},{"id":"Fabricante","type":"STRING","value":"0609586"},{"id":"DescripcionFabricante","type":"STRING","value":"HP PRINTING AND COMPUTING SOLUTIONS"},{"id":"Marca","type":"STRING","value":"HP"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"124619056","value":"HP"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"ACC. INF.SOFW"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Impresora Multifunción tinta HP Envy Photo 6232, Wi-Fi, copia, escanea, compatible con Instant Ink"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Imprime, copia y escanea documentos diarios tanto en blanco y negro como en color a una gran velocidad sin interrumpir tus tareas.\nImprime fotografías con calidad de laboratorio y una versatilidad aumentada.\nImpresión automática a doble cara. \nImpresión sin bordes (hasta 216x297mm). \nImpresión en modo silencioso. \nBandeja de entrada principal de 125 hojas y bandeja de salida de hasta 25 hojas.\nConectividad inalámbrica sin complicaciones. \nImprime fotografías y documentos cotidianos desde cualquier dispositivo gracias a la aplicación HP Smart. \nImpresora compatible con los cartuchos de tinta originales HP 303 y con el servicio HP Instant Ink. Esta impresora incluye 5 meses gratis de Instant Ink si te registras en los 7 días posteriores a la configuración de la impresora."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"HP Instant Ink"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"HP Instant Ink es un servicio automático de tinta a domicilio que te permite imprimir de una manera mucho más cómoda y asequible. Y es que con Instant Ink, no tendrás que volver a preocuparte por quedarte sin tinta, ya que HP se encarga de enviarte los cartuchos a la dirección que elijas antes de que se agoten los que estás usando.\nAdemás, existen distintos planes de impresión para que puedas escoger el que mejor se adapte a tus necesidades, con total flexibilidad para cambiar de plan o cancelar el servicio sin ningún tipo de penalización. Los planes de impresión mensual se basan en la cantidad de páginas que imprimes y no en el volumen de tinta que consumes. Existen 5 planes diferentes a elegir con los que podrás ahorrar hasta un 70% en tinta desde tan solo 0,99€ al mes. \nLa cuota mensual de los planes incluye la tinta, el envío y el reciclaje de cartuchos."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"C2"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"11"},{"id":"TipoDeGestion","type":"STRING","value":"00"}]},{"id":"D