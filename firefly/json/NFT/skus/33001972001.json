":"es_ES","type":"STRING","value":"<p>Son las siete de la mañana. Los Bantry se despiertan con una desagradable sorpresa: el cuerpo inerte de una joven mujer desconocida en su biblioteca. Lleva un vestido de noche y bastante maquillaje, que ahora embadurna sus mejillas.<\/p> <p>Pero, ¿quién es ella? ¿Cómo llegó allí? ¿Y cuál es la conexión con otra chica muerta, cuyos restos carbonizados más tarde se descubrió en una cantera abandonada? Los respetables Bantry invitan a Miss, Marple, amiga de la señora Bantry, a resolver el misterio con su increíble intuición antes de que las malas lenguas empiecen a trabajar.<\/p>"}],"id":"Descripcion","type":"STRING"}],"id":"Descripcion","type":"GROUPING"},{"id":"CodigoSituacion","type":"STRING","value":"FV"}],"id":"CaracteristicasGenerales","type":"GROUPING"},{"ocurrence":0,"children":[{"idExt":"335210051","id_Ext":"335210051","groupID":"2002","id":"CodigoAutor","type":"RELATIONSHIP","value":"0051670"}],"id":"Autor","type":"GROUPING"},{"children":[{"children":[{"id":"es_ES","type":"STRING","value":"López Hipkiss, Guillermo"}],"id":"Traductor","type":"STRING"}],"id":"OtrasCaracteristicas","type":"GROUPING"},{"children":[{"id":"Estilo1","type":"STRING","value":"001"},{"id":"Estilo2","type":"STRING","value":"011"},{"id":"Estilo3","type":"STRING","value":"000"}],"id":"Estilos","type":"GROUPING"}],"id":"/Libros_ISS","type":"SPEC"}],"stores":[{"children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20210805_000000"},{"idExt":"233767090","featureGroupID":"10110","id_Ext":"233767090","id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","value":"010"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20200211_000000"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":