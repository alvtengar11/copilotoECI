abios."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"La primera laca de labios mate."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Beneficios:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Color Intenso y mate aterciopelado lleno de luz."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":2,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Modo de aplicación:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Aplica la barra de labios sobre tu labio inferior y junta ambos labios para lograr una aplicación uniforme. Si quieres potenciar el color aplica de nuevo sobre ambos labios."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"1"},{"id":"Calificacion2","type":"STRING","value":"I"},{"id":"Calificacion3","type":"STRING","value":"N5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"A"},{"id":"Calificacion6","type":"STRING","value":"CG"},{"id":"TipoDeGestion","type":"STRING","value":"14"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"},{"children":[{"id":"CantidadProducto","type":"NU