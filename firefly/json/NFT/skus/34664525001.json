:"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"9504500000"},{"id":"Atue","type":"STRING","value":"218"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0396952"},{"id":"NombreProveedor","type":"STRING","value":"NINTENDO IBERICA, S.A."},{"id":"Fabricante","type":"STRING","value":"0396952"},{"id":"DescripcionFabricante","type":"STRING","value":"NINTENDO IBERICA, S.A."},{"id":"Marca","type":"STRING","value":"NINTENDO"},{"idExt":"126938056","id_Ext":"126938056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Nintendo"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"SWITCH LITE CORAL"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Criada especificamente para a consola portátil, a Nintendo Switch Lite tinge-se de coral e vem juntar-se à paleta de cores já disponíveis: amarelo, turquesa e cinzento. Ideal para usar na rua nesta Primavera, a Nintendo Switch Lite coral destina-se a jogos portáteis, tornando ainda mais fácil desfrutar de uma vasta gama de jogos Nintendo Switch em qualquer lugar.\nAlgumas das opções perfeitas para desfrutar no modo portátil com a Nintendo Switch Lite são The Legend of Zelda: Link's Awakening, onde poderá explorar um mundo misterioso habitado por um elenco diversificado de personagens e masmorras cheias de quebra-cabeças; Pokémon Sword and Pokémon Shield, onde poderá descobrir a região de Galar e capturar novos Pokémon; ou Animal Crossing: New Horizons.\nComo sistema portátil, a Nintendo Switch Lite tem comandos integrados e é mais pequena do que a versão pioneira Nintendo Switch, mas é compatível com todos os jogos portáteis do catálogo do sistema. Podes encontrar toda a informação acerca dos jogos e do sistema no website Nintendo Switch.\nA Nintendo Switch possui três modos de jogo que permitem aos utilizadores acompanhar o seu jogo a qualquer momento e em qualquer lugar: modo TV, modo portátil e modo Tabletop.\nComo consola doméstica, liga-se em modo TV através da base Nintendo Switch. Mas em qualquer altura, o utilizador pode tirar a consola da base Nintendo Switch e continuar a jogar com total autonomia no modo portátil.\nNo modo portátil, o utilizador joga num ecrã multitouch de 6,2 polegadas com uma resolução de 1280 x 720.\nA Nintendo Switch oferece as mesmas funcionalidades multiplayer que uma consola portátil.\nO modo Tabletop permite que esse ecrã portátil seja transformado num dispositivo multiplayer utilizando os controladores Joy-Con."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Diseñada específicamente para el juego portátil, la Nintendo Switch Lite se tiñe de coral y se suma a los colores ya disponibles: amarillo, turquesa y gris.Ideal para lucir por la calle esta primavera, la Nintendo Switch Lite coral está enfocada al juego portátil, facilitando aún más al jugador el poder disfrutar de una amplia gama de juegos de Nintendo Switch allá donde vayan.\nAlgunas opciones perfectas para disfrutar en modo portátil con Nintendo Switch Lite son The Legend of Zelda: Link's Awakening, un juego en el que explorarás un misterioso mundo habitado por un elenco de personajes de lo más variopinto y mazmorras llenas de puzles; Pokémon Espada y Pokémon Escudo, donde descubrirás la región de Galar y capturarás nuevos Pokémon; o Animal Crossing: New Horizons.\nComo consola portátil, Nintendo Switch Lite tiene los controles integrados y es más pequeña que la versión insignia de Nintendo Switch, pero es compatible con todos los juegos del catálogo de la consola que cuentan con juego portátil. Tienes toda la información sobre los juegos y la consola en la páginaweb de Nintendo Switch."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Nintendo Switch plantea tres modos de juego que permiten al usuario seguir su partida en cualquier momento y lugar: modo televisor, modo portátil y modo tabletop.\nComo consola doméstica se conecta en modo televisor a través de la base Nintendo Switch. Pero en cualquier momento el usuario puede sacar la consola de la base Nintendo Switch y seguir con su partida con completa autonomía en modo portátil.\nEn el modo portátil, el usuario juega en una pantalla de 6,2 pulgadas multitáctil con una resolución de 1280 x 720.\nNintendo Switch ofrece las mismas prestaciones multijugador que una consola portátil.\nEl modo tabletop permite que esa pantalla portátil se convierta en un dispositivo multijugador usando los mandos Joy-Con."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AG"},{"id":"TipoDeGestion","type":"STRING","value":"14"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"},{"children":[{"id":"CantidadProducto","type":"NUMBER","value":"0.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}],"id":"PUM","type":"GROUPING"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"id":"ColorFabricante","type":"STRING","value":"CONSOLAS2D