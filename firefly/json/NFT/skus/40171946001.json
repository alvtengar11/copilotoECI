":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"9506590000"},{"id":"Atue","type":"STRING","value":"21J"},{"id":"TipoAcuerdoServicio","type":"STRING","value":"N"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0665992"},{"id":"NombreProveedor","type":"STRING","value":"DROP SHOT SL"},{"id":"Fabricante","type":"STRING","value":"0665992"},{"id":"DescripcionFabricante","type":"STRING","value":"DROP SHOT SL"},{"id":"Marca","type":"STRING","value":"DROP SHOT"},{"idExt":"225694056","id_Ext":"225694056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"DROP SHOT"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"CONQUEROR BLACK LABEL"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"Tecnologias"},{"id":"es_ES","type":"STRING","value":"Tecnologías"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":3,"id":"pt_PT","type":"STRING","value":"3D FACE: textura 3D em forma de losango, desenhada exclusivamente por Drop Shot, para dar mais rodada à bola em tacadas onde a rotação máxima deve ser dada à bola, especialmente concebida para jogadores agressivos."},{"ocurrence":8,"id":"pt_PT","type":"STRING","value":"3D FACE: textura 3D em forma de losango, desenhada exclusivamente por Drop Shot, para dar mais rodada à bola em tacadas onde a rotação máxima deve ser dada à bola, especialmente concebida para jogadores agressivos."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"TWIN TUBULAR SYSTEM: Todas nuestras palas de marco de Carbono están fabricadas con doble tubular de telas de carbono pre impregnadas con resinas de máxima durabilidad, dandole homogeneidad en todas las áreas de la cara y aportando una mayor rigidez, así no se pierde energía del golpe por distorsión del marco."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"CUBICARBON T-XTREME TECHNOLOGY: Carbono extra fino y plano de 18.000 filamentos de carbono por hilo, resistente y flexible. Ideal para palas de máximo control y potencia. Las palas fabricadas con este material gozan de la excelencia en el juego, dando un tacto de bola extremo al jugador."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"EVA TECH: Es una goma de mayor dureza y elasticidad, que aporta mayor control en jugadores experimentados, proporcionando un mayor tacto de bola."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"3D FACE: Textura en 3D en forma romboidal, exclusivamente diseñado por Drop Shot, para aportar un mayor efecto a la pelota en los golpes donde se debe dar un máximo efecto a la bola, especialmente pensado para jugadores agresivos en su juego."},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"POLYAMIDE PROTECTION BAMMPER: Protector de TPU pegado en la parte superior del marco de la pala, actua como protector de la pala y reductor de las vibraciones a consecuencia de los golpes contra la pared o cristal."},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"CORK CUSHION GRIP: Sistema de antivibración, que combinado con los otros sistemas que aportamos, hacen a nuestras palas ideales para jugadores que arrastran lesiones crónicas. Consiste en una lamina de corcho situada en el área de la empuñadura, evitando así que lleguen vibraciones a la mano del jugador."},{"ocurrence":6,"id":"es_ES","type":"STRING","value":"SMART HOLES SYSTEM: Sistema de distribución de agujeros en la cara de la pala, en forma curva, progresiva y que aporta un mejor desarrollo de las fuerzas mecánicas en el momento del golpeo, ayudando a dar efecto a la pelota y mejorando la reducción de vibraciones."},{"ocurrence":7,"id":"es_ES","type":"STRING","value":"SILICONE GRIP CHANNEL: Un canal en la empuñadura de la pala, donde se inserta una pieza de silicona con un recubrimiento de 2 mm de corcho superabsorbente, para reducir las vibraciones justo en la zona donde el jugador coge la pala. Las palas Drop Shot, con esta tecnología, permiten disfrutar de un juego más seguro y agradable."},{"ocurrence":8,"id":"es_ES","type":"STRING","value":"3D FACE: Textura en 3D en forma romboidal, exclusivamente diseñado por Drop Shot, para aportar un mayor efecto a la pelota en los golpes donde se debe dar un máximo efecto a la bola, especialmente pensado para jugadores agresivos en su juego."},{"ocurrence":9,"id":"es_ES","type":"STRING","value":"LOOK: Tornasolado, hace cambiar el color de la pala en funcion de la luz que reciba, avivando su elegancia y tecnologia"}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"Nota importante:"},{"id":"es_ES","type":"STRING","value":"Nota importante:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"El peso mostrado en web es un dato orientativo, este puede variar entre 350-380 g."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"E5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AD"},{"id":"Calificacion6","type":"STRING","value":"BA"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!Volum