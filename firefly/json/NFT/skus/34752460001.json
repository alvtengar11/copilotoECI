FLAG","value":"false"},{"id":"PeticionPrecioDeVenta","type":"FLAG","value":"false"},{"id":"ReferenciaDigital","type":"FLAG","value":"false"},{"id":"AnillosDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternet","type":"FLAG","value":"true"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8443310000"},{"id":"Atue","type":"STRING","value":"21B"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0609586"},{"id":"NombreProveedor","type":"STRING","value":"HP PRINTING AND COMPUTING SOLUTIONS"},{"id":"Fabricante","type":"STRING","value":"0609586"},{"id":"DescripcionFabricante","type":"STRING","value":"HP PRINTING AND COMPUTING SOLUTIONS"},{"id":"Marca","type":"STRING","value":"HP"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"124619056","value":"HP"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"HP DESKJET PLUS 4130"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"pt_PT","type":"STRING","value":"Deskjet Plus 4130"},{"id":"es_ES","type":"STRING","value":"Impresora Multifunción tinta HP DeskJet Plus 4130, Wi-Fi, copia, escanea, envía fax, compatible con Instant Ink"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","ocurrence":0,"type":"STRING","value":"Todas as funcionalidades de que necessita para as suas necessidades de impressão, fax, digitalização e cópia diárias estão à distância de um clique com a multifunções all-in-one da HP. Muito fácil de configurar e utilizar, está pronta para ser usada por toda a família. Com ligação Wi-Fi e Bluetooth permite facilmente começar a imprimir a partir do smartphone ou tablet. Beneficie de um alimentador automático de documentos para 35 folhas e beneficie de Wi-Fi com capacidade de autorrecuperação."},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Imprime, copia y escanea documentos diarios tanto en blanco y negro como en color. Envía fax móvil desde tu smartphone, tablet o PC.\nIncluye un alimentador automático de documentos de 35 páginas que te permitirá completar los trabajos de copia y escaneado en menos tiempo. \nBandeja de entrada de 60 hojas y bandeja de salida de 25 hojas. \nConectividad inalámbrica sin complicaciones. \nImprime documentos desde cualquier dispositivo gracias a la aplicación HP Smart. \nEsta impresora contiene más de un 20% de plástico reciclado. \nImpresora compatible con los cartuchos de tinta originales HP 305 y con el servicio HP Instant Ink. Esta impresora incluye 4 meses gratis de Instant Ink  si te registras en los 7 días posteriores a la configuración de la impresora."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"pt_PT","type":"STRING","value":"Descrição:"},{"id":"es_ES","type":"STRING","value":"HP Instant Ink"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","ocurrence":0,"type":"STRING","value":"Multifunções jato de tinta Deskjet Plus 4130 com funções de impressão, cópia, digitalização e fax."},{"id":"pt_PT","ocurrence":1,"type":"STRING","value":"Velocidade de impressão até 8.5/5.5 ppm (a preto/a cores)"},{"id":"pt_PT","ocurrence":2,"type":"STRING","value":"Contém mais de 20% de plástico reciclado"},{"id":"pt_PT","ocurrence":3,"type":"STRING","value":"Alimentador automático de documentos para 35 folhas"},{"id":"pt_PT","ocurrence":4,"type":"STRING","value":"Preparada para o HP Instant Ink"},{"id":"pt_PT","ocurrence":5,"type":"STRING","value":"Ligação fiável com Wi-Fi™ de banda dupla com Bluetooth® 5.0 e capacidade de autorrecuperação"},{"id":"pt_PT","ocurrence":6,"type":"STRING","value":"Capacidade de ligação sem fios e compatibilidade com a aplicação HP Smart"},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"HP Instant Ink es un servicio automático de tinta a domicilio que te permite imprimir de una manera mucho más cómoda y asequible. Y es que con Instant Ink, no tendrás que volver a preocuparte por quedarte sin tinta, ya que HP se encarga de enviarte los cartuchos a la dirección que elijas antes de que se agoten los que estás usando.\nAdemás, existen distintos planes de impresión para que puedas escoger el que mejor se adapte a tus necesidades, con total flexibilidad para cambiar de plan o cancelar el servicio sin ningún tipo de penalización. Los planes de impresión mensual se basan en la cantidad de páginas que imprimes y no en el volumen de tinta que consumes. Existen 5 planes diferentes a elegir con los que podrás ahorrar hasta un 70% en tinta desde tan solo 0,99€ al mes. \nLa cuota mensual de los planes incluye la tinta, el envío y el reciclaje de cartuchos."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"11"},{"id":"TipoDeGestion","type":"STRING","value":"00"}]},{"id":"DimensionesYPeso","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","featureGroupID":"204","id_Ext":"347186090","value":"cm"},{"id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","featureGroupID"