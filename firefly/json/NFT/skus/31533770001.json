nomia projetados para atender às necessidades exclusivas dos jogadores, o Nacon Wireless Controller e seus joysticks assimétricos oferecem uma maneira alternativa de jogar na PS4. Os jogadores também podem desfrutar do controle no PC."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Mando oficial PS4 asimétrico optimizado para audio inalámbrico."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Con una autonomía de hasta 7 horas, gracias a sus dos motores de vibración podrás disfrutar de experiencias únicas."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Conector para auriculares de 3,5 mm y distancia operativa de hasta 7m. Compatible para PC."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AC"},{"id":"TipoDeGestion","type":"STRING","value":"32"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"id":"ColorFabricante","type":"STRING","value":"ACCESORIOSPS4"},{"id":"TamanoHorma","type":"STRING","value":"CONTROLLER"}],"id":"ColoresYTallas","type":"GROUPING"},{"children":[{"id":"CodigoVarianteWeb","type":"STRING","value":"A29962793"},{"id":"VariantesTallas","type":"FLAG","value":"false"},{"id":