G","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"false"},{"id":"PartidaArancelaria","type":"STRING","value":"3303001000"},{"id":"Atue","type":"STRING","value":"21R"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0412395"},{"id":"NombreProveedor","type":"STRING","value":"L´OREAL ESPAÑA, S.A. LUJO"},{"id":"Fabricante","type":"STRING","value":"0412395"},{"id":"DescripcionFabricante","type":"STRING","value":"L´OREAL ESPAÑA, S.A. LUJO"},{"id":"Marca","type":"STRING","value":"LANCOME"},{"idExt":"133636056","id_Ext":"133636056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"LANCÔME"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"LVEB EDP 100ML"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"¡La vida es bella! Elige cómo vivirla o a quien hacer feliz hoy.\nLa Vie est Belle de Lancôme es un manifiesto, una declaración. Representa el triunfo del ser sobre las posesiones y las apariencias. La libertad de elegir el propio camino a la felicidad, más allá de las normas impuestas. Es la afirmación de las mujeres seguras de sí mismas que rechazan los rígidos dictados de la sociedad y siguen su propio camino hacia la felicidad. En pocas palabras: una mujer LIBRE, FELIZ Y REALIZADA.\nEs una fragancia que te invita a dar sentido a tu día a día a través de las emociones positivas. Simboliza el triunfo del ser sobre las apariencias y un camino hacia la felicidad. Además, una firma olfativa única, encapsulada en el aroma de este perfume dulce que crearon tres de los perfumistas más importantes de Francia: Olivier Polge, Dominique Ropio y Anne Flipo\nUn aroma excepcionalmente duradero... Conocida por su increíblemente duradera esencia, contiene una mezcla impresionante de ingredientes naturales en su Eau de Parfum. \nEl primer Iris Apetitoso. Un giro inesperado en el Bouquet de Flores Blancas. Las flores blancas tienen mucha más luminosidad gracias al Iris Pallida (excepcionalmente duradero y evoca la feminidad), Jazmín Sambac y a la Flor de Azahar, realzados por el corazón de patchouli, con una nota nostálgica proporcionada por el bouquet dulce. Además, el vetol, es un ingrediente inusual qu ele da un matiz dulce, a praliné.\n¿Sabías que no usamos la flor o las hojas de estas flores sino el rizoma, que se encuentra bajo tierra? \nDespués pasa por un proceso de secado de 2-3 años seguido por 9 meses de proceso de extracción antes de que se pueda usar en la fragancia. Engrandeciéndose con el tiempo, el Iris ofrece una nota muy elegante y delicada dentro de La Vie Est Belle\nEL FRASCO\nEl resplandeciente frasco, que data de 1949, se denomina \"le Sourire de Cristal\" (sonrisa de cristal) porque evoca la curva de una sonrisa inscrita en el corazón del frasco de cristal cuadrado\nHay más fragancias La Vie Est Belle\u2026 Además del  L'Eau de Parum y L'Éclat Eau de Parfum, puedes encontrar La Intensément, En Rose o su nueva versión: Soleil Cristal\u2026 ¡Hazte con la tuya al mejor precio en El Corte Inglés y elige cómo ser feliz hoy!"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"La libertad de elegir su camino hacia la felicidad."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":2,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Modo de empleo:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Vaporizar sobre la piel a unos 20cms de distancia, privilegiando las zonas más cálidas del cuerpo: la parte interior de las muñecas, detrás de los lóbulos de las orejas y detrás de las rodillas. De este modo, el olor durará durante más tiempo.\nAdemás, perfumar en nebulización alrededor de la cabeza y los hombros para que la fragancia se pose suavemente."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"I"},{"id":"Calificacion3","type":"STRING","value":"BR"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"A"},{"id":"Calificacion6","type":"STRING","value":"CG"},{"id":"TipoDeGestion","type":"STRING","value":"14"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"},{"children":[{"idExt":"20552576090","featureGroupID":"2530","id_Ext":"20552576090","id":"EnlacePUM","type":"LOOKUP_TABLE","value":"008"},{"id":"CantidadProducto","type":"NUMBER","value":"100.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}],"id":"PUM","type":"GROUPING"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"idExt":"351851090","featureGroupID":"393","id_Ext":"351851090","id":"Tallas","type":"LOOKUP_TABLE","value":"100 ml"},{"idExt":"349417090","featureGroupID":"394","id_Ext":"349417090","id":"TipoTallaje","type":"LOOKUP_TABLE","value":"Belleza - Tamaño"},{"id":"TamanoHorma","type":"STRING","value":"100ML"}],"id":"ColoresYTallas","type":"GROUPING"},{"children":[{"id":"CodigoVarianteWeb","type":"STRING","value":"A7364517"},{"id":"VariantesTallas","type":"FLAG","value":"false"},{"id":"Vari