":"SenyalInternetCodificacion","type":"FLAG","value":"false"},{"id":"PartidaArancelaria","type":"STRING","value":"9504500000"},{"id":"Atue","type":"STRING","value":"18J"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0014528"},{"id":"NombreProveedor","type":"STRING","value":"BADLAND GAMES PUBLISHING SL"},{"id":"Fabricante","type":"STRING","value":"0014528"},{"id":"DescripcionFabricante","type":"STRING","value":"BADLAND GAMES PUBLISHING SL"},{"idExt":"24352824056","id_Ext":"24352824056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"GRIP DIGITAL"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"MOTHERGUNSHIP"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Crea el arma de tus sueños con uno de los sistemas más modulares jamás vistos en un videojuego. Esquiva cientos de balas en un sistema de juego único, mezcla entre FSP y Bullet-hell."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Combate y sobrevive contra hordas de máquinas alienígenas, trampas mortíferas e impresionantes jefes. Habitaciones y NPCs generados aleatoriamente que supondrán enfrentarse a un nuevo reto en cada partida."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Lucha en línea junto a tus amigos o junto a la comunidad en una completa experiencia cooperativa. ¡Disfruta de una campaña extra y piezas para las armas, exclusivo de la edición física!."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"De los creadores de Tower of Guns, Mothergunship mezcla la intensidad de los géneros Bullet-hell y FPS, y promete una de las mayores opciones de personalización de armas de fuego vista jamás en un videojuego. Depende de ti el equiparte con arsenal fuera de serie y derrotar al ejército alienígena que ha conquistado la tierra."},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"Crea armas monstruosas que una persona normal jamás podría levantar, juega junto a tus amigos, pelea contra jefes gigantescos y experimenta un caos aleatorizado mientras te abres camino hasta el corazón de la flota para destruir la Mothergunship."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Características:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Construye: para acabar con la Mothergunship, necesitarás tus propias armas de destrucción personalizadas. Afortunadamente podrás crear el arma de tus sueños gracias a uno de los sistemas más modulares jamás visto en un videojuego. ¿Quieres tener una pistola de 12 cañones que dispare cohetes dirigidos? ¿O prefieres una escopeta de relámpagos? ¿Y qué arma no luciría mejor con una pecera pegada a la parte superior? ¡Hazlo! ¡El diseño de tu arsenal de destrucción masiva está en tus manos!"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Lucha: enfréntate a las peores probabilidades en un combate brutal y sin descanso, donde la única manera de sobrevivir es pensando donde están tus pies. Escapa a cientos de balas en una mecánica de juego mezcla de Bullet-hell y FPS. Cada nave alberga hordas de máquinas alienígenas, trampas mortíferas e increíbles jefes, todos ellos empeñados en evitar que salves a la humanidad. ¡A por ellos!"},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Resiste: únete a las filas de la resistencia global y recupera la Tierra junto con tus amigos. Combate junto a un amigo en una experiencia cooperativa completa, o únete a la comunidad mientras trabajáis juntos para abriros paso a través de las flotas alienígenas y alcanzar la meta final: derribar la Mothergunship."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":2,"chi