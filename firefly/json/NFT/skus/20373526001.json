su parte, dispone de un punto NFC para usar figuras amiibo, así como una cámara infrarroja de movimiento que detecta la distancia, forma y movimiento de objetos cercanos en los juegos diseñados para esta tecnología."}],"id":"Descripcion","type":"STRING"}],"id":"OtrasCaracteristicas","type":"GROUPING"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"420484301"}],"id":"/Mandos_De_Juego_ISS","type":"SPEC"}],"stores":[{"children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20200714_000000"},{"idExt":"233767090","featureGroupID":"10110","id_Ext":"233767090","id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","value":"010"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20170728_000100"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"true"}],"id":"Fechas","type":"GROUPING"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"420484301"}],"id":"/Fechas_WWW_ISS","type":"SPEC"},{"children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"MostrarSoloRebajado","type":"FLAG","value":"false"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"420484301"}],"id":"/Comunes_ISS","type":"SPEC"},{"children":[{"id":"Fecha de Publicacion","type":"DATE","value":"20210901_000001"},{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"idExt":"233767090","featureGroupID":"10110","id_Ext":"233767090","id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","value"