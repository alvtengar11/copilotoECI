llosDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EsAlcohol","type":"FLAG","value":"false"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8528724000"},{"id":"Atue","type":"STRING","value":"21L"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0026252"},{"id":"NombreProveedor","type":"STRING","value":"GAPLASA"},{"id":"Fabricante","type":"STRING","value":"0026252"},{"id":"DescripcionFabricante","type":"STRING","value":"GAPLASA"},{"id":"Marca","type":"STRING","value":"LOEWE"},{"idExt":"123264056","id_Ext":"123264056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Loewe"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"\"LED 49\"\" BILD 2.49 4"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"Não há razão para não ser flexível. Existem muitas razões para ter uma Loewe\nPosicione o Loewe bild 2 exatamente onde quiser. Graças à sua flexibilidade, cabe perfeitamente em uma parede ou num aparador. Além disso, exclusivamente para uma televisão deste tamanho, com um dos stands de chão impressionantes da Loewe pode posicioná-lo de pé em qualquer lugar na sala. Também oferece imagens equilibradas,um som personalizado e um design icônico."},{"id":"es_ES","type":"STRING","value":"TV LED 126 cm (49\") Loewe Bild 2.49 4K HDR Smart TV"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Maior liberdade\nO disco Loewe DR +, um disco rígido externo opcional com armazenamento de 1 TB, oferece ainda mais liberdade. Use-o para expandir as possibilidades oferecidas pelo Loewe bild 2. Pause um programa a qualquer momento ou defina para gravação usando a TV remota ou até mesmo através da aplicação Loewe, se estiver fora e aproximadamente. E com Timeshift Permanente, você pode começar a gravar após o início de um programa. Também há funcionalidades para vários ambientes que permitem que o conteúdo seja reproduzido sincronicamente em duas TVs Loewe de uma vez, seja ao vivo ou do arquivo."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Máxima comodidade e operação intuitiva.\nTudo o que precisa é de um controle remoto, o assistente da Loewe, para controlar todos as aplicações e dispositivos externos, como o Apple TV. Pode também controlar a TV com seu smartphone ou tablet usando a aplicação da Loewe ou até mesmo com a sua voz usando o Amazon Alexa. O Loewe OS tem um menu claro e bem construído e oferece um ecrã inicial personalizável onde pode encontrar os seus favoritos pessoais."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"Ouça todos os detalhes.\nMime-se com o som da Loewe bild 2: o conceito de Guided Wave direciona o som para a frente para uma nitidez soberba, enquanto os woofers traseiros proporcionam um som mais cheio. Para som surround, basta adicionar ao sistema de áudio Loewe klang 1. O Loewe bild 2 também possui som personalizado com o Mimi DefinedTM: como todos ouvem de forma diferente, essa tecnologia inovadora adapta o sinal de áudio ao seu perfil de audição individual em tempo real. Disponível em exclusivo em televisores da Loewe."},{"ocurrence":3,"id":"pt_PT","type":"STRING","value":"Contemporâneo, agora e no futuro.\nUm design minimalista e discreto, sofisticado acabamento preto puro e alto-falantes elegantemente integrados - Loewe bild 2 é intemporal. Com uma solução de suporte de chão Loewe em cromado ou cinza claro, ele pode ser posicionado livremente na sala. Graças à escolha de materiais, acabamento excepcional e atualizações regulares de software, o Loewe bild 2 será atualizado amanhã. Esta é a verdadeira sustentabilidade. Uma TV Loewe dura."},{"ocurrence":4,"id":"pt_PT","type":"STRING","value":"Televisão levada um passo adiante.\nO Loewe bild 2 oferece flexibilidade e novas possibilidades. Expanda o seu mundo do entretenimento com o Loewe bild 2 como o ponto focal do seu sistema de entretenimento ou como um segundo televisor. Aprimore sua experiência de áudio com um sistema de som Loewe que se conecta perfeitamente com o Loewe bild 2. E por último, os revendedores da Loewe estão sempre prontos para ajudar com consultoria especializada e serviço abrangente. Bem vindo ao mundo da Loewe."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Incluye soporte de mesa con función de giro manual"}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"WW"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"}],"id":"Dimen