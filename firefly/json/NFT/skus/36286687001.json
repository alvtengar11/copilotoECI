ito","type":"FLAG","value":"false"},{"id":"ReferenciaGenerica","type":"FLAG","value":"false"},{"id":"PeticionPrecioDeVenta","type":"FLAG","value":"false"},{"id":"ReferenciaDigital","type":"FLAG","value":"false"},{"id":"AnillosDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8471900000"},{"id":"Atue","type":"STRING","value":"21J"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0239061"},{"id":"NombreProveedor","type":"STRING","value":"SAMSUNG ELECTRONICS IBERIA SA"},{"id":"Fabricante","type":"STRING","value":"0239061"},{"id":"DescripcionFabricante","type":"STRING","value":"SAMSUNG ELECTRONICS IBERIA SA"},{"id":"Marca","type":"STRING","value":"SAMSUNG"},{"idExt":"122381056","id_Ext":"122381056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Samsung"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"TAB A7 - 10,4''/3/32/"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Samsung Galaxy TAB A7 26,41 cm (10,4\") 32 GB Wi-Fi plata"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"DESIGN\n\nCom um design fino (7mm) e simétrico, o Tab A7 destaca-se pelas suas cores metalizadas, quer seja em prateado, dourado ou cinzento. Veja aquilo que mais gosta no ecrã de 10.4\", WUXGA+ TFT do seu tablet enquanto se deslumbra com o seu design minimalista e estilo sofisticado. Para além do look moderno, o Galaxy Tab A7 é super resistente com alta durabilidade devido ao seu acabamento em metal."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"ENTRETENIMENTO\n\nCom o Tab A7 o mundo está nas suas mãos. Esqueça os bilhetes de cinema e faça uma sessão de cinema num ecrã dinâmico com quatro altifalantes AKG e Dolby Atmos, tudo no conforto do seu lar. Com a bateria potente de 7,040 mAh, não tem de se preocupar com a carga do seu Galaxy Tab e caso fique sem bateria, um carregador Fast Charging de 15W (não incluído) permite-lhe que retome aquilo que mais gosta."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"MAIS GALAXY\n\nPorque sabemos o quão valioso é o tempo de cada um, incorporámos no Tab A7 features Galaxy para que faça o maior proveito dos nossos equipamentos: continuidade de chamadas e mensagens, Quick Share e Auto Hotspot. Para os mais pequeninos oferecemos conteúdo educacional mantendo todo o controlo nos pais com a definição: Controlo Parental."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Prepárate para un nuevo nivel de diversión. Hemos creado una tablet versátil, sofisticada y asequible, porque la diversión de nueva generación debe ser para todas las generaciones. Disfruta de un dispositivo Premium a un precio increíble,"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Hemos creado una tablet tan versátil y sofisticada como asequible. Acabado metálico Premium, es la tablet ideal para contenidos multimedia gracias a su pantalla y características"},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Sus cuatro altavoces te permiten escuchar tu música favorita con un sonido potente y lleno de matices. Sumérgete en tus contenidos con el sonido surround tridimensional Dolby Atmos."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Con su gran batería y su carga rápida podrás disfrutar de la TAB A durante mucho más tiempo"},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"Disfruta aún más de tus contenidos favoritos. Galaxy Tab A7 cuenta con una nítida pantalla de 10,4\" WUXGA (2000x1200) que brinda colores asombrosos y niveles de brillo óptimos."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"11"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"},{"children":[{"id":"CantidadProducto","type":"NUMBER","value":"0.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}],"id":"PUM","type":"GROUPING"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"id":"ColorFabricante","type":"STRING","value":"SILVER"},{"idExt":"344764090","featureGroupID":"135","id_Ext":"344764090","id":"DescripcionDelColor","type":"LOOKUP_TABLE","value":"Plata"},{"idExt":"15692209090","featureGroupID":"10153","id_Ext":"15692209090","id":"ColorBasico","type":"LOOKUP_TABLE","value":"Plata"}],"id":"ColoresYTallas","type":"GROUPING"},{"children":[{"id":"CodigoVarianteWeb","type":"STRING","value":"A36443495"},{"id":"VariantesTallas","type":"FLAG","value":"false"},{"id":"VariosColores","typ