DeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"9504500000"},{"id":"Atue","type":"STRING","value":"21O"},{"id":"TipoAcuerdoServicio","type":"STRING","value":"N"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0389304"},{"id":"NombreProveedor","type":"STRING","value":"BANDAI NAMCO ENTERTAINMENT IBERICA,"},{"id":"Fabricante","type":"STRING","value":"0389304"},{"id":"DescripcionFabricante","type":"STRING","value":"BANDAI NAMCO ENTERTAINMENT IBERICA,"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"3519722056","value":"BANDAI NAMCO"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"ELDEN RING"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"pt_PT","ocurrence":0,"type":"STRING","value":"Elden Ring, um novo mundo criado por Hidetaka Miyazaki e George R.R. Martin. Desenvolvido pela FromSoftware, Inc. e pela BANDAI NAMCO Entertainment Inc., Elden Ring é uma aventura RPG de ação e fantasia num mundo criado por Hidetaka Miyazaki - criador da influente série de videogames Dark Souls e George R.R. Martin - autor da série de fantasia best-seller do New York Times, A Song of Ice and Fire. Dentro do mundo do Elden Ring, o perigo e a descoberta escondem-se a cada esquina, do maior jogo da FromSoftware até hoje."},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"ELDEN RING es un juego de rol y acción de ambientación fantástica desarrollado por FromSoftware Inc. y producido por BANDAI NAMCO Entertainment Inc. Está ambientando en un mundo lleno de misterios y peligros y se presenta como el juego más grande de FromSoftware hasta la fecha. "},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"En las Tierras Intermedias gobernadas por la Reina Márika, la Eterna, el Círculo de Elden, origen del Árbol Áureo, ha sido destruido."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Los descendientes de Márika, todos semidioses, reclamaron los fragmentos del Círculo de Elden conocidos como Grandes Runas. Fue entonces cuando la demencial corrupción de su renovada fuerza provocó una guerra: la Devastación. Una guerra que supuso el abandono de la Voluntad Mayor."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Y ahora, la gracia que nos guía recaerá sobre el Sinluz desdeñado por la gracia del oro y exiliado de las Tierras Intermedias."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Tú que has muerto, pero vives, con tu gracia tiempo ha perdida, recorre la senda hacia las Tierras Intermedias más allá del neblinoso mar para postrarte ante el Círculo de Elden."},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"Recorre las Tierras Intermedias, un nuevo mundo de fantasía ideado por Hidetaka Miyazaki, creador de la exitosa serie de videojuegos DARK SOULS, y por George R. R. Martin, autor de Canción de hielo y fuego, la serie de fantasía superventas según The New York Times. Desvela los misterios del poder del Círculo de Elden. Enfréntate a criaturas temibles y conoce a adversarios con pasados tumultuosos y personajes con sus propias motivaciones para ayudarte a avanzar o complicarte las cosas. "},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"ELDEN RING ofrece vastos parajes de fantasía y sombrías e intricadas mazmorras que están conectadas de forma fluida y sin interrupciones. Recorre este impresionante mundo a pie o a caballo, en solitario u online con otros jugadores. Sumérgete en las verdes llanuras, en los pantanos agobiantes, en las montañas tortuosas, en unos castillos que no auguran nada bueno y en otros parajes majestuosos. Todo ello, a una escala nunca antes vista en un juego de FromSoftware. "},{"id":"es_ES","ocurrence":7,"type":"STRING","value":"Crea a tu propio personaje en este refinado juego de rol y acción de FromSoftware y define tu estilo de juego a partir del amplio abanico de armas, poderes mágicos y habilidades que encontrarás a lo largo y ancho del mundo. Ve de cabeza al combate, usa el sigilo para acabar con los enemigos uno a uno o pide ayuda a tus aliados. Tendrás muchas opciones a tu disposición, tanto a la hora de explorar como de saltar al combate. "}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Los usuarios que compren ELDEN RING para PlayStation 4 recibirán gratuitamente la actualización de la versión de PlayStation 5. Las versiones de Xbox One y Xbox Series X|S serán compatibles con SmartDelivery."}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"*Los jugadores que compren la versión para PlayStation®4 podrán actualizarla gratis a la versión de PlayStation®5. Aviso: Los jugadores que adquieran la versión física del juego no podrán actualizarlo en PS5™ Digital Edition, ya que esta consola carece de lector de disco. Los jugadores que compren la versión digital para PS5™ a través de PlayStation™Store también podrán descargar la versión de PS4™ sin coste adicional. En todos los casos, es necesario estar registrado en PlayStation™Network, tener suficiente espacio en el disco duro y una conexión a Internet de alta velocidad (incluyendo los costes de transferencia de datos)."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"* Las versiones de Xbox One y Xbox Series X|S serán compatibles con SmartDelivery. Tras comprar el juego una vez, los usuarios podrán disfrutarlo tanto en Xbox Series X como en Xbox One."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Los jugadores que compren la versión física no podrán mejorar el juego en Xbox Series S Edition ya que no cuenta con lector de discos."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"AE"},{"id":"TipoDeGestion","type":"STRING","value":"00"}]},{"id":"DimensionesYPeso","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","featureGroupID":"204","id_Ext":"347186090","value":"cm"},{"id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","featureGroupID":"206","id_Ext":"347187090","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","featureGroupID":"213","id_Ext":"347188090","value":"ml"},{"id":"PUM","type":"GROUPING","children":[{"id":"CantidadProducto","type":"NUMBER","value":"0.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}]}]},{"id":"ColoresYTallas","type":"GROUPING","children":[{"id":"IndicadorBalanza","type":"FLAG","value":"false"},{"id":"ColorFabricante","type":"STRING","value":"JUEGOSPC"},{"id":"TamanoHorma","type":"STRING","value":"AVENTURA-ROL"}]},{"id":"Variantes","type":"GROUPING","children":[{"id":"CodigoVarianteWeb","type":"STRING","value":"A40168281"},{"id":"VariantesTallas","type":"FLAG","value":"false"},{"id":"VariosColores","type":"FLAG","value":"false"},{"id":"VariantesModelos","type":"FLAG","value":"false"},{"id":"VariosTamanos","type":"FLAG","value":"false"},{"id":"VariosFormatos","type":"FLAG","value":"false"},{"id":"VariosTipoPiel","type":"FLAG","value":"false"},{"id":"VariosSabores","type":"FLAG","value":"false"},{"id":"VariantesFormatoLibros","type":"FLAG","value":"false"}]},{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDeAltaCompras","type":"DATE","value":"20210624_000000"},{"id":"FechaDeAltaPr