miso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternet","type":"FLAG","value":"true"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8518220090"},{"id":"Atue","type":"STRING","value":"21J"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0026252"},{"id":"NombreProveedor","type":"STRING","value":"GAPLASA"},{"id":"Fabricante","type":"STRING","value":"0026252"},{"id":"DescripcionFabricante","type":"STRING","value":"GAPLASA"},{"id":"Marca","type":"STRING","value":"BOSE"},{"idExt":"160707056","id_Ext":"160707056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"Bose"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"BARRA SONIDO BOSE TV"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Barra de Sonido Bose TV Speaker Bluetooth"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"A barra de som da Bose é uma solução simples para melhorar o som da sua televisão. É pequeno, mas poderoso, oferece uma experiência de áudio clara, equilibrada e com som natural que melhora o desempenho do diálogo e dos graves."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Mais música\n\nPossui conectividade Bluetooth, para que possa ouvir o que quiser, quando quiser. Pressione o botão \"Bluetooth\" no controle remoto para emparelhar um dispositivo e reproduzir músicas e podcasts sem fio."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"Mais grave\n\nO botão \"Bass\" no controle remoto proporciona uns graves ainda mais fortes"},{"ocurrence":3,"id":"pt_PT","type":"STRING","value":"Mais clareza\n\nNo modo de Diálogo, o Bose TV Speaker analisa o que estiver assistir para elevar ainda mais os dialogos, para que possa ouvir e entender cada palavra com mais clareza. Basta pressionar o botão \"Modo de diálogo\" no controle remoto para ativar."},{"ocurrence":4,"id":"pt_PT","type":"STRING","value":"Fácil de configurar. Fácil de usar.\n\nProjetado com a simplicidade em mente usa uma única conexão à sua TV por meio de um cabo de áudio óptico (incluído) ou um cabo HDMI (vendido separadamente), para que possa passar do unboxing para assistir rapidamente. E com HDMI-CEC, pode usar o controle remoto da TV atual para controlar o volume. Ele detecta um sinal da sua TV quando ligado e liga automaticamente também."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Bose TV Speaker es una solución rápida y fácil para mejorar el sonido de la TV. Pequeño pero potente, garantiza un sonido claro, equilibrado y natural, mejorando la comprensión del diálogo y el rendimiento de graves"},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"El altavoz Bose TV también está equipado con conectividad Bluetooth, por lo tanto, puede escuchar lo que más le gusta, cuando lo desee. Presione el botón \"Bluetooth\" en el control remoto para emparejar un dispositivo y reproducir música y podcasts de forma inalámbrica"},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Y aunque ofrece una experiencia auditiva sorprendentemente rica y potente para un altavoz tan compacto, presionar el botón \"Bass\" en el control remoto le dará un sonido aún más profundo"},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Diseñado para la máxima simplicidad, el altavoz Bose TV está listo para usar en un instante, gracias a una sola conexión al televisor mediante un cable de audio óptico (incluido) o un cable HDMI (se vende por separado). Además, gracias a la tecnología HDMI-CEC, puede usar el control remoto normal del televisor para controlar el volumen del altavoz. El altavoz Bose TV detecta la señal de TV cuando esta se enciende y se enciende automáticamente."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"11"},{"id":"TipoDeGestion","type":"STRING","value":"14"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"},{"children":[{"id":"CantidadProducto","type":"NUMBER","value":"0.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}],"id":"PUM","type":"GROUPING"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"id":"ColorFabricante","type":"STRING","value":"NEGRO"},{"idExt":"347149090","featureGroupID":"135","id_Ext":"347149090","id":"DescripcionDelColor","type":"LOOKUP_TABLE","value":"Negro"},{"idExt":"351107090","featureGroupID":"10153","id_Ext":"351107090","id":"ColorBasico","type":"LOOKUP_TABLE","value":"Negros"}],"id":"ColoresYTallas","type":"GROUPING"},{"children":[{"id":"CodigoVarianteWeb","type":"STRING","value":"A