								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Twist Face promueve una mayor consistencia en los golpes erróneos comunes en las áreas de la cara con tacones bajos o punta alta."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
