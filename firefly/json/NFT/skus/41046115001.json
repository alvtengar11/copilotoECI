						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Altavoz Bluetooth con clasificación IP67 que se puede caer al agua y seguirá funcionado (incluso flota, por lo que no lo perderemos si se nos cae)."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Para garantizar una mayor protección contra el agua y el polvo, el transductor y los radiadores pasivos debajo de la rejilla de acero están construidos con materiales resistentes e impermeables y sellados herméticamente a la carcasa del altavoz."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Excelente calidad de sonido independientemente de su posición gracias a su tecnología PositionIQ, que ajusta el sonido automáticamente según la orientación que tenga para optimizando el sonido tanto si está de pie, tumbado boca arriba o colgando."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Autonomía 12 horas y carga mediante puerto USB-C."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Se puede combinar con otro SoundLink Flex u otro altavoz Bose Bluetooth para habilitar el modo Fiesta (funciona con la aplicación Bose Connect); además es compatible con las barras de sonido y altavoces Bose Smart enlazándose entre ellos."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "El micrófono incorporado permite recibir llamadas con una excelente calidad de sonido."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Alcance de Bluetooth hasta 9 metros."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 7,
									"value": "Memoria de hasta ocho dispositivos conectados."
								}
							]
						}
					]
