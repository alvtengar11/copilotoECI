							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "La gran superficie para cocinar de la Parrilla & Raclette permite que 8 personas se reúnan alrededor de ella y disfruten cocinando juntos."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Puede utilizarse para asar carne, pescado y verduras. ¡Sin necesidad de mantequilla o aceite para una opción sana y baja en grasas!."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Revestimiento negro con un termostato integrado para cocinar a una temperatura óptima. Con su gran potencia, alcanza la temperatura ideal rápido y mantiene el calor durante mucho tiempo."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Superficie para cocinar grande que incluye 8 sartenes y espátulas."
								},
								{
									"id": "es_ES",
									"ocurrence": 4,
									"type": "STRING",
									"value": "No es necesario calentar de antemano la plancha de piedra."
								},
								{
									"id": "es_ES",
									"ocurrence": 5,
									"type": "STRING",
									"value": "Fácil de limpiar. Deje que la parrilla se enfríe y limpie la plancha con un paño de cocina. Puede limpiar el resto de la plancha y la estructura con un paño húmedo. Las sartenes para raclette son aptas para el lavavajillas."
								}
							]
