ario personal vamos conociendo las increíbles peripecias de un extraterrestre en Barcelona. En este relato de carácter paródico y satírico, la invención de Eduardo Mendoza convierte la Barcelona cotidiana en el escenario de una carnavalada tras la cual se revela el verdadero rostro del hombre urbano actual. Al prólogo del autor y las ilustraciones originales, se añade en esta edición la «Guía de lectura», que incluye material didáctico y una sección especial para clubs de lectura.<\/p>"}],"id":"Descripcion","type":"STRING"}],"id":"Descripcion","type":"GROUPING"},{"id":"Ficcion","type":"FLAG","value":"false"},{"id":"CodigoSituacion","type":"STRING","value":"FV"}],"id":"CaracteristicasGenerales","type":"GROUPING"},{"ocurrence":0,"children":[{"idExt":"425164051","id_Ext":"425164051","groupID":"2002","id":"CodigoAutor","type":"RELATIONSHIP","value":"0088696"}],"id":"Autor","type":"GROUPING"},{"children":[{"id":"Estilo1","type":"STRING","value":"001"},{"id":"Estilo2","type":"STRING","value":"001"},{"id":"Estilo3","type":"STRING","value":"000"}],"id":"Estilos","type":"GROUPING"}],"id":"/Libros_ISS","type":"SPEC"}],"stores":[{"children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20191230_000000"},{"idExt":"233767090","featureGroupID":"10110","id_Ext":"233767090","id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","value":"010"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20140211_000000"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"true"}],"id":"Fechas","type":"GROUPING"}],"id":"/Fechas_WWW_ISS","type":"SPEC"},{"children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"MostrarSoloRebajado","type":"