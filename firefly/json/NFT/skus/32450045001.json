							],
							"id": "TituloPrincipal",
							"type": "STRING"
						},
						{
							"children": [
								{
									"ocurrence": 0,
									"id": "pt_PT",
									"type": "STRING",
									"value": "O encanto de uma mulher reside na sua força. Por vezes está oculta, outras, está aqui e é visível a olhos vistos."
								},
								{
									"ocurrence": 1,
									"id": "pt_PT",
									"type": "STRING",
									"value": "Pode ser romântica, sensível e feminina, mas, no fundo, tem o instinto de nutrir, proteger e inspirar todos os que a rodeiam."
								},
								{
									"ocurrence": 2,
									"id": "pt_PT",
									"type": "STRING",
									"value": "Tem ainda o poder de trazer uma nova vida ao mundo. Esta é a fonte de inspiração para a nossa nova colecção, Spring Blossom."
								},
								{
									"ocurrence": 3,
									"id": "pt_PT",
									"type": "STRING",
									"value": "Tendo uma flor em todo o seu esplendor como símbolo da força feminina, criámos uma colecção com uma elegância e sofisticação inigualáveis."
								},
								{
									"ocurrence": 4,
									"id": "pt_PT",
									"type": "STRING",
									"value": "Lindas flores exuberantes em cores arrojadas irradiam feminilidade e romantismo, sensualidade e graça. Evocando uma abundância rica que nos deixará sem fôlego."
								},
								{
									"ocurrence": 5,
									"id": "pt_PT",
									"type": "STRING",
									"value": "Encantadoras, sedutoras e de design luxuoso, são peças com personalidade que vão transformar as cabeças dos transeuntes."
								},
								{
									"ocurrence": 6,
									"id": "pt_PT",
									"type": "STRING",
									"value": "Apresentamos o Spring Blossom. Flores fortemente enraizadas."
								},
								{
									"ocurrence": 0,
									"id": "es_ES",
									"type": "STRING",
									"value": "El encanto de una mujer radica, a menudo, en su fortaleza. A veces está oculta, otras, en cambio, está ahí y es visible a los ojos de todos."
								},
								{
									"ocurrence": 1,
									"id": "es_ES",
									"type": "STRING",
									"value": "Puede ser romántica, sensible y femenina, pero, en el fondo, tiene el instinto de nutrir, proteger e inspirar a todos aquellos que la rodean."
								},
								{
									"ocurrence": 2,
									"id": "es_ES",
									"type": "STRING",
									"value": "Además, tiene el poder de traer una nueva vida al mundo. Esta es la fuente de inspiración para nuestra nueva colección, Spring Blossom."
								},
								{
									"ocurrence": 3,
									"id": "es_ES",
									"type": "STRING",
									"value": "Tomando una flor en todo su esplendor como símbolo de fortaleza femenina, hemos creado una colección con una elegancia y sofisticación inigualables."
								},
								{
									"ocurrence": 4,
									"id": "es_ES",
									"type": "STRING",
									"value": "Hermosas flores exuberantes de colores atrevidos irradian feminidad y romanticismo, sensualidad y gracia. Evocando una rica abundancia que te dejará sin respiración."
								},
								{
									"ocurrence": 5,
									"id": "es_ES",
									"type": "STRING",
									"value": "Encantadoras, seductoras y lujosamente diseñadas, son piezas con personalidad que harán girar las cabezas de los paseantes."
								},
								{
									"ocurrence": 6,
									"id": "es_ES",
									"type": "STRING",
									"value": "Os presentamos Spring Blossom. Flores fuertemente enraizadas."
