ntamiento (1 - 1,5ºC por hora), la limpieza (capacidad del filtro de la depuradora de cartucho de aproximadamente 1.325 l/h), la función de masaje, el inflado/desinflado, el temporizador y el ablandamiento del agua, se controlan con el panel digital.\n\nCapacidad para 5 a 7 personas.\n\nMedidas interiores de 151 x 151 x 80 cm.\n\nCon cartucho de recambio tipo VI incluido.\n\nEl peso del spa interior hinchable lleno de agua es de 1.117 kg."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Atrezzo no incluido. Montaje no incluido."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"NP"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"E"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"FS"},{"id":"TipoDeGestion","type":"STRING","value":"PD"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"idExt":"347188090","featureGroupID":"213","id_Ext":"347188090","id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","value":"ml"}],"id":"DimensionesYPeso","type":"GROUPING"},{"children":[{"id":"ColorFabricante","type":"STRING","value":"105"},{"idExt":"362396090","featureGroupID":"135","id_Ext":"362396090","id":"DescripcionDelColor","type":"LOOKUP_TABLE","value":"Madera"},{"idExt":"15560007090","featureGroupID":"10153","id_Ext":"15560007090","id":"ColorBasico","type":"LOOKUP_TABLE","value":"Madera"},{"id":"TamanoHorma","type":"STRING","value":"ST"},{"id":"Dibujo","type":"STRING","value":"OUTDOOR"}],"id":"ColoresYTallas","type":"GROUPING"},{"children":[{"id":"CodigoVarianteWeb","type":"STRING","value":"A31627609"},{"id":"VariantesTallas","t