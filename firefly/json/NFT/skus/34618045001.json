adorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"UnidadDeMedidaBase","type":"STRING","value":"UNI"},{"id":"PartidaArancelaria","type":"STRING","value":"8715001000"},{"id":"Atue","type":"STRING","value":"21J"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0998484"},{"id":"NombreProveedor","type":"STRING","value":"BUGABOO INTERNATIONAL, BV"},{"id":"Fabricante","type":"STRING","value":"0998484"},{"id":"DescripcionFabricante","type":"STRING","value":"BUGABOO INTERNATIONAL, BV"},{"id":"Marca","type":"STRING","value":"BUGABOO"},{"idExt":"133769056","id_Ext":"133769056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"BUGABOO"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"FOX2 BASE"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Carrinho de passeio dúo Fox 2 Base, em alumínio. Desenhado por si."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Bugaboo Fox2, o carrinho conforto mais avançado."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Coche de paseo dúo Fox 2 Base, en aluminio. Diseñado por ti."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Bugaboo Fox 2, el Coche confort más avanzado."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"Caracteristicas:"},{"id":"es_ES","type":"STRING","value":"Características:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"O Bugaboo Fox 2 é o nosso carrinho confortável mais preparado. Fruto de 20 anos de última inovação e avanços tecnológicos de Bugaboo: é a condução perfeita com direcção assistida."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"É pensado para pais que procuram o melhor em carrinhos confortáveis com um design ultra leve."},{"ocurrence":4,"id":"pt_PT","type":"STRING","value":"Posições de reclinação do carrinho de passeio: 6 posições, 3 viradas para a frente e 3 viradas para os pais."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"El Bugaboo Fox 2 es nuestro Coche confortable más preparado. Fruto de 20 años de última innovación y avances tecnológicos de Bugaboo: es la conducción perfecta con dirección asistida."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Sigue siendo nuestro mejor Coche, con un sinfín de características que lo convierten en el impulso más ligero para los padres, increíble para todo tipo de terrenos y condiciones meteorológicas y construido con materiales de calidad y mejorados hechos para durar."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Está pensado para padres que buscan lo mejor en Coches confortables con un diseño ultra ligero."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Y es súper cómodo para los más pequeños gracias a sus tejidos premium mejorados y a un capazo y silla de diseño ergonómico."},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"Posiciones de reclinado Silla de paseo: 6 posiciones, 3 mirando hacia el mundo 3 mirando hacia los padres."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":2,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"A condução perfeita com direcção assistida:"},{"id":"es_ES","type":"STRING","value":"La conducción perfecta con dirección asistida:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"No Bugaboo Fox 2 a tecnologia de condução foi melhorada continuamente para transformá-lo no melhor, com diferença, da sua categoria."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"É uma combinação de suspensão avançada, melhoras no interior e exterior das rodas e jantes, e a posição dos guiadores perfeitamente angulados em relação às rodas, que conferem uma sensação de um empurrar mais enérgico sem ter que usar mais força."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"Também, a forma como se move nas curvas e nos espaços reduzidos transforma-o no carrinho com a condução perfeita, pois tem direcção assistida."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"En el Bugaboo Fox 2 la tecnología de conducción se ha mejorado continuamente para convertirlo en el mejor, con diferencia, de su categoría."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Es una combinación de suspensión avanzada, mejoras en el interior y exterior de las ruedas y llantas, y la posición de los manillares perfectamente angulados en relación a las ruedas, que aportan una sensación de un empuje más enérgico sin tener que usar más fuerza."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Además, la forma en qué se mueve por las curvas y los espacios reducidos lo convierte en el Coche de conducción perfecta con dirección asistida."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":3,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Suspensión avanzada para todo tipo de terrenos:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Este Carrinho é o nosso passeio mais suave até à data."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"O tamanho óptimo das rodas de 8,5'' e 12'' (Diâmetro) e a suspensão avançada do eixo central (com uma suspensão adicional nas rodas traseiras e amortização interna da borracha) criam uma viagem suave e estável para os seus filhos, quer estejam na alcofa ou na cadeira."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Este Coche es nuestro paseo más suave hasta la fecha."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"El tamaño óptimo de las ruedas de 8,5'' y 12'' (diámetro) y la suspensión avanzada del eje central (con una suspensión adicional en las ruedas traseras y amortiguación interna de la goma) crean un paseo suave y estable para tus hijos, tanto si están en el Capazo como en la Silla."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"También hace que el Fox 2 sea una experiencia de conducción sin esfuerzo, se desliza fácilmente sobre baches y terrenos irregulares."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":4,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Robusto aunque ligero:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"O nosso carrinho de conforto mais preparado, com todas as características de conforto que se espera, pesa apenas 10,2 kg (chassis, rodas e cadeira)."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"Apesar da sua estrutura extremamente leve, pode continuar a transportar uma criança até 22 Kg ou 48 meses."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"Nuestro Coche confortable más preparado, con todas las características de confort que esperas, pesa solo 10,2 Kg. (Chasis, ruedas y Silla)."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"A pesar de su estructura ultraligera, puede seguir llevando un niño de hasta 22 Kg. o 48 meses."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Su peso y plegado en 1 sola pieza que se sostiene en pie o un plegado más compacto en 2 piezas, sin ruedas, hace que sea muy fácil de levantar y subir o bajar por las escaleras o en el transporte público."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":5,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"Design inovador para um conforto máximo:"},{"id":"es_ES","type":"STRING","value":"Diseño innovador para un confort máximo:"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"O Bugaboo Fox 2 tem uma cadeira e alcofa acolchoadas e ergonómicas, o que faz dela o máximo conforto para o bebé, desde o seu nascimento até ser criança mais velha."},{"ocurrence":1,"id":"pt_PT","type":"STRING","value":"No Bugaboo Fox 2 também foram introduzidas melhoras nos tecidos e características premium, como um prático bolso duplo na alcofa."},{"ocurrence":2,"id":"pt_PT","type":"STRING","value":"É um Carrinho incrível para usar em qualquer estação do ano, com uma Capota Premium XXL que tem uma janela e um painel ventilado para uma maior circulação do ar nos meses quentes do verão."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"El Bugaboo Fox 2 cuenta con un Silla y Capazo acolchados y ergonómicos, lo que lo convierte en el máximo confort para tu pequeño, desde su nacimiento hasta niño."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"En el Bugaboo Fox 2 también se han introducido mejoras en los tejidos y características premium, como un práctico bolsillo doble en el Capazo."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Es un Coche increíble para usar en cualquier estación del año, con una Capota Premium XXL que cuenta con una ventana y un panel ventilado para una mayor circulación del aire en los cálidos meses veraniegos."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"E5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"A"},{"id":"Calificacion6","type":"STRING","value":"ST"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":