turaMinima!Minima","type":"NUMBER","value":"1.8"},{"idExt":"349891090","featureGroupID":"214","id_Ext":"349891090","id":"UOM!AperturaMaxima!Unidad","type":"LOOKUP_TABLE","value":"F"},{"id":"UOM!AperturaMaxima!Maxima","type":"NUMBER","value":"2.8"}],"id":"Objetivo","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Sensor CMOS Exmor R tipo 1.0 de 20,1 MP (efectivos)"},{"id":"pt_PT","type":"STRING","value":"Sensor CMOS Exmor R tipo 1.0 de 20,1 MP (efetivos)"}],"id":"TitularDeLaDescripcion","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"El sensor CMOS Exmor R retroiluminado tipo 1.0 garantiza detalles brillantes y nítidos en todas tus fotos y vídeos. El diseño especial retroiluminado de Sony permite una captura de luz cuatro veces mejor al trasladar circuitos que bloquean la luz a la parte posterior del sensor. BIONZ X para conseguir un detalle y una representación de texturas superiores Todas las cámaras digitales necesitan convertir la luz capturada por su sensor a una hermosa fotografía digital. El sistema encargado de esta conversión es tan importante como el objetivo o un sensor de alta resolución, por lo que Sony ha desarrollado el excelente procesador BIONZ X, que captura detalles más naturales, imágenes más realistas, gradaciones de tonos más ricas y reduce el ruido al hacer tanto fotos como videos"},{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"O sensor CMOS Exmor R retroiluminado tipo 1.0 garante detalhes brilhantes e nítidos em todas as suas fotos e vídeos. O design especial retroiluminado Sony permite uma captação de luz quatro vezes melhor ao transportar os circuitos que bloqueiam a luz para a parte posterior do sensor. BIONZ X para conseguir um detalhe e uma representação de texturas superior. Todas as câmaras digitais necessitam converter a luz capturada pelo seu sensor para uma fotografia digital perfeita. O sistema responsável por esta conversão é tão importante como a objetiva ou um sensor de alta resolução, pelo que a Sony desenvolveu o excelente processador BIONZ X, que captura detalhes mais naturais, imagens mais realistas, gradações de tons mais ricas e reduz o ruído ao criar tanto fotos como vídeos"}],"id":"Descripcion","type":"STRING"}],"id":"OtrasCaracteristicas","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"es_ES","type":"STRING","value":"Lente ZEISS Vario-Sonnar T* de 24-70 mm F1,8-2,8"},{"id":"pt_PT","type":"STRING","value":"Lente ZEISS Vario-Sonnar T* de 24-70 mm F1,8-2,8"}],"id":"TitularDeLaDescripcion","type":"STRING"},{"children":[{"ocurrence":0,"id":"es_ES","type":"STRING","value":"El gran angular de 24 mm abarca más, lo que lo hace ideal para la arquitectura y los paisajes, mientras que el de 70 mm a un brillante F2,8 es excelente para retratos, primeros planos (30 cm de distancia) y el desenfoque creativo de fondos. Aprovechando más de 150 años de experiencia en óptica de precisión, la lente ZEISS ofrece a tus grabaciones un contraste y nitidez intensos, libres de los brillos y reflejos gracias a un avanzado revestimiento multicapa"},{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"O grande angular de 24 mm inclui mais, o que o torna ideal para a arquitetura e paisagens, enquanto o de 70 mm com um brilhante F2,8 é excelente para retratos, primeiros planos (30 cm de distância) e para a desfocagem criativa de fundos. Aproveitando mais de 150 anos de experiência em ótica de precisão, a lente ZEISS oferece às suas gravações um contraste e nitidez intensos, sem brilho e reflexos graças a um avançado revestimento multicamada"}],"id":"Descripcion","type":"STRING"}],"id":"OtrasCaracteristicas","type":"GROUPING"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"427459229"}],"id":"/Camara_Reflex_ISS","type":"SPEC"}],"stores":[{"children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"children":[{"children":[{"ocur