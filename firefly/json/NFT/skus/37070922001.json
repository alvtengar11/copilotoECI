									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Brillo variable de 40 a 810 lúmenes"
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Potencia nominal: 8 W, equivalente a 60 W"
