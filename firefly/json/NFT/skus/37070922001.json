								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Larga vida útil hasta 25000 horas. Esto significa que con 3 horas de uso por día, la bombilla puede durar hasta 22,8 años."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Temperatura de color blanco cálido a 2700 K"
								},
								{
									"id": "es_ES",
									"ocurrence": 4,
									"type": "STRING",
									"value": "Conectividad: IEEE 802.11b / g / n conectividad inalámbrica Wi-Fi 2.4 GHz\nControl de luz directamente desde la aplicación \"My Home\" instalada en el teléfono inteligente. Control por voz mediante Google Assistant"
								}
