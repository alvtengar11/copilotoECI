illosDeCompromiso","type":"FLAG","value":"false"},{"id":"ReferenciaDeLujo","type":"FLAG","value":"false"},{"id":"ReferenciaMadre","type":"FLAG","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"IndicadorDeEDP","type":"FLAG","value":"false"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"true"},{"id":"IndicadorMercanciaEspecial","type":"STRING","value":"5"},{"id":"PartidaArancelaria","type":"STRING","value":"8525803000"},{"id":"Atue","type":"STRING","value":"21M"},{"id":"TipoAcuerdoServicio","type":"STRING","value":"N"}],"id":"General","type":"GROUPING"},{"children":[{"id":"NumeroProveedor","type":"STRING","value":"0017337"},{"id":"NombreProveedor","type":"STRING","value":"SONY EUROPE B.V.SUCURSAL EN ESPAÑA"},{"id":"Fabricante","type":"STRING","value":"0017337"},{"id":"DescripcionFabricante","type":"STRING","value":"SONY EUROPE B.V.SUCURSAL EN ESPAÑA"},{"id":"Marca","type":"STRING","value":"SONY PRO"},{"idExt":"19023397056","id_Ext":"19023397056","groupID":"391","id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","value":"SONY PRO"}],"id":"ProveedorMarca","type":"GROUPING"},{"children":[{"id":"DescripcionTicket","type":"STRING","value":"ALPHA 7M4 BODY"}],"id":"DescripcionCorta","type":"GROUPING"},{"ocurrence":0,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"QUALIDADE DE IMAGEM IMPRESSIONANTE"},{"id":"es_ES","type":"STRING","value":"Cámara Evil 4K Sony Alpha 7M4 Cuerpo"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"O sensor Exmor R Full-Frame de 33 MP retro-iluminado, juntamente com o novo BIONZ™ XR, consegue uma qualidade de imagem profissional, mesmo com pouca luz, em todas as circunstâncias."},{"ocurrence":0,"id":"es_ES","type":"STRING","value":"El sensor Exmor R de fotograma completo retroiluminado de 33 MP junto a la nueva potencia de procesamiento BIONZ™ XR logran una calidad de imagen profesional, incluso con poca luz, y en todas las circunstancias. Con la ciencia de color y los modos creativos más recientes de las cámaras profesionales de Sony, no solo podrás captar imágenes naturales y vivas sino que lo harás con tu propio estilo."},{"ocurrence":1,"id":"es_ES","type":"STRING","value":"Con un diseño refinado, la Alpha 7 IV incluye un visor electrónico de 3,69 millones de puntos rápido y nítido, una nueva pantalla de 3'' multiángulo y un sistema de estabilización de imagen de 5 ejes en el cuerpo de la cámara para capturar de forma estable y cómoda. Con la inclusión del sistema de menú táctil e intuitivo de Sony, un dial específico para Foto/Vídeo/S&Q y la doble ranura para tarjeta, podrás cambiar sin problemas de entre foto y vídeo y centrarte en tu creatividad."},{"ocurrence":2,"id":"es_ES","type":"STRING","value":"Cuenta con la tecnología de seguimiento en tiempo real y AF/Eye AF más reciente (humanos / animales / aves) para realizar un seguimiento del objeto sin problemas y sin dejar de hacer fotos o grabar vídeos. Además, la Alpha 7 IV dispara hasta 10 fotogramas por segundo con vaciado rápido del búfer para captar el mejor momento de lo que está sucediendo delante de ti."},{"ocurrence":3,"id":"es_ES","type":"STRING","value":"Graba tu contenido en un glorioso 4K y hasta a 60p con lectura de píxeles completa y sin agrupamiento para lograr la mejor calidad. Para curtidos cineastas, la Alpha 7 IV puede grabar en 4:2:2 10 bits e incluye los perfiles de imagen S-CINETONE/S-LOG 3 para lograr un aspecto cinematrográfico sin complicarse en las ediciones. Junto a la vertiginosa tecnología de enfoque automático en tiempo real, podrás hacer un seguimiento de los ojos de tu objeto sin complicaciones (sean humanos, animales o aves). La Alpha 7 IV también incluye herramientas de vídeo exclusivas, como la compensación de la variacion de la longitud focal, una interfaz de audio digital para acoplar micrófonos de audio profesionales y una estructura de disipación del calor para sesiones que se prolonguen durante más tiempo."},{"ocurrence":4,"id":"es_ES","type":"STRING","value":"La Alpha 7 IV puede transmitir en directo a hasta 4K15p o Full HD a 60p sin tener que acudir a la tarjeta de captura para mantenerte conectado con tu público en todo momento. Con la compatibilidad USB-C gen 3.2, un chip Wi-Fi ultrarrápido y un modo de copia de seguridad de imágenes Bluetooth® automático, en esta cámara para streaming podrás transferir y compartir tus imágenes con el mundo en el mismo momento."},{"ocurrence":5,"id":"es_ES","type":"STRING","value":"Nuevo estándar entre las cámaras de fotograma completo, la Alpha 7 IV aúna una increíble calidad de imagen de 33 MP, vídeo 4K 60p, manejo avanzado y capacidades para compartir rápido, que la convierten en la cámara híbrida perfecta. Con el mejor enfoque automático en foto y vídeo en tiempo real entre los de su clase, la Alpha 7 IV pone la potencia de la mejor tecnología de Sony al alcance de creadores y profesionales."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":1,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"UMA EXPERIÊNCIA DE DISPARO ÚNICA"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"A Alpha 7 IV apresenta um visor electrónico rápido e nítido de 3,69 milhões de pontos, um novo visor multi-ângulo de 3'' e um sistema de estabilização de imagem de 5 eixos no corpo da câmara para um disparo estável e confortável. Com a inclusão do intuitivo sistema de menu táctil da Sony, um novo mostrador dedicado Photo/Video/S&Q e slots duplos de cartão, pode alternar sem problemas entre foto e vídeo e concentrar-se na sua criatividade."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":2,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"MELHOR CRIAÇÃO DE CONTEÚDOS DE VÍDEO"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"Filme o seu conteúdo em 4K e até 60p com leitura de píxeis completos e sem aglomeração para obter a melhor qualidade. A Alpha 7 IV apresenta perfis de imagem S-CINETONE/S-LOG 3 que proporcionam um aspecto cinematográfico sem o incómodo da edição. Também inclui ferramentas de vídeo únicas, tais como compensação da variação da distância focal, uma interface de áudio digital para anexar microfones de áudio profissionais e uma estrutura de dissipação de calor para sessões mais longas."}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"ocurrence":3,"children":[{"children":[{"id":"pt_PT","type":"STRING","value":"O SEU CONTEÚDO, SEMPRE LIGADO"}],"id":"TituloPrincipal","type":"STRING"},{"children":[{"ocurrence":0,"id":"pt_PT","type":"STRING","value":"A Alpha 7 IV consegue transmitir ao vivo até 4K15p ou Full HD a 60p sem ter de recorrer ao cartão de captura para a manter sempre ligada ao seu público. Com compatibilidade USB-C gen 3.2, um chip Wi-Fi ultra-rápido e um modo de backup automático de imagens Bluetooth®, pode transferir e partilhar as suas imagens com o mundo ao mesmo tempo"}],"id":"DescripcionPrincipal","type":"STRING"}],"id":"DescripcionLargaDelProducto","type":"GROUPING"},{"children":[{"id":"Calificacion1","type":"STRING","value":"C1"},{"id":"Calificacion2","type":"STRING","value":"A"},{"id":"Calificacion3","type":"STRING","value":"M5"},{"id":"Calificacion4","type":"STRING","value":"VV"},{"id":"Calificacion5","type":"STRING","value":"ES"},{"id":"Calificacion6","type":"STRING","value":"44"},{"id":"TipoDeGestion","type":"STRING","value":"00"}],"id":"GestionComprasStock","type":"GROUPING"},{"children":[{"idExt":"347186090","featureGroupID":"204","id_Ext":"347186090","id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","value":"cm"},{"idExt":"347187090","featureGroupID":"206","id_Ext":"347187090","id":"UOM!PesoBruto!U