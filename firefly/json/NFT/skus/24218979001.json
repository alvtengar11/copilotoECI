							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Boppy ComfyFit a forma mais fácil de envolver confortavelmente o seu bebé."
								},
								{
									"id": "pt_PT",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Permite transportar o bebé de forma natural e prática."
								},
								{
									"id": "pt_PT",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Fácil de usar, leve e elegante para acompanhar em todos os momentos do dia."
								},
								{
									"id": "pt_PT",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Permite a liberdade de movimentos e incentiva as interações do bebé com o meio envolvente."
								},
								{
									"id": "pt_PT",
									"ocurrence": 11,
									"type": "STRING",
									"value": "Unissexo."
								},
								{
									"id": "pt_PT",
									"ocurrence": 12,
									"type": "STRING",
									"value": "Algodão suave e elegante."
								},
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "El Portabebé ComfyFit es fácil de llevar, ligero y moderno, permite a los padres moverse libremente a la vez que estimula al bebé para que interaccione con su entorno."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Envuelve al bebé en un suave abrazo para una total comodidad, y su tejido suave y ligero se ajusta perfectamente al cuerpo del bebé para garantizar el máximo contacto piel con piel."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Avalado por el Instituto Internacional de Displasia de Cadera (IHD) que reconoce al portabebé Boppy Comfyfit como un producto saludable para la cadera cuando se utiliza siguiendo las instrucciones de uso."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Homologado desde el nacimiento (3,5 Kg.) hasta los 15 Kg. de peso."
								},
								{
									"id": "es_ES",
									"ocurrence": 4,
									"type": "STRING",
									"value": "Fácil de colocar en solo 3 pasos: 1. ajusta la correa, 2. coloca la banda sobre los hombros y 3. anuda en la cintura. Cómodo para los padres y facilita la correcta distribución del peso del bebé."
								},
								{
									"id": "es_ES",
									"ocurrence": 5,
									"type": "STRING",
									"value": "Mantiene la correcta posición de las caderas (forma de M) y la espalda del bebé (forma de C)."
								},
								{
									"id": "es_ES",
									"ocurrence": 6,
									"type": "STRING",
									"value": "La parte central es acolchada y soporta la cabeza/nuca del bebé para una sujeción máxima."
								},
								{
									"id": "es_ES",
									"ocurrence": 7,
									"type": "STRING",
									"value": "Con Sistema 'Easy Wear':  las bandas para hombros perforadas permiten llevarlo con más facilidad."
								},
								{
									"id": "es_ES",
									"ocurrence": 8,
									"type": "STRING",
									"value": "La parte central y el soporte para cabeza/ nuca están acolchados para una sujeción máxima."
								},
								{
									"id": "es_ES",
									"ocurrence": 9,
									"type": "STRING",
									"value": "Bolsillo con cremallera para guardar el teléfono, las llaves, el dinero o pequeños objetos."
								},
								{
									"id": "es_ES",
									"ocurrence": 10,
									"type": "STRING",
									"value": "Incluye Bolsa protectora."
								},
								{
									"id": "es_ES",
									"ocurrence": 11,
