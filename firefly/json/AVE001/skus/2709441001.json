  "specificAttribs": [
    {
      "id": "\/Perfumeria_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Con la nueva Sensai Foundations, Sensai presenta un nuevo tratamiento en forma de base de maquillaje que se aplica suavemente alternando mantos de agua pura e ingredientes de la seda para hidratar la piel y lograr un acabado translúcido y perfecto que refleje toda la delicadeza y el resplandor de la seda."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
