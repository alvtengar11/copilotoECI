                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Beneficios:"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Suave base de maquillaje semimate que se funde al instante con la piel aportándole un acabado aterciopelado suave de efecto duradero."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Enriquecido en Agua Fuji Sensui y Seda Koishimaru, se extiende rápida y fácilmente, aportando una sensación de hidratación y de frescura."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Extender uniformemente Smoothing Water Make-Up Base tras aplicar Double Moisturising."
                }
              ]
            }
          ]
        },
