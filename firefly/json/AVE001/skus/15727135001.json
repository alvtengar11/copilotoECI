            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "La bolsa de deporte Nike Brasilia (pequeña) está confeccionada en un tejido ultrarresistente para que transportes tu equipo de deporte. Con bolsillos interiores para organizar el material, el compartimento para calzado te permite guardar el calzado húmedo y seco por separado."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "La base duradera e impermeable impide que tu equipo se moje."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Compartimento principal espacioso para un almacenamiento versátil."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Compartimento ventilado para calzado húmedo y seco."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "El tejido 600D está confeccionado en poliéster impermeable y con una trama muy prieta para conseguir un material grueso y resistente."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "Las asas dobles pueden unirse con un cierre para transportar la bolsa fácilmente."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 6,
                  "type": "STRING",
                  "value": "Correa para el hombro acolchada extraíble y ajustable a tu medida para transportar la mochila con comodidad."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 7,
                  "type": "STRING",
                  "value": "El asa de agarre rápido del lateral ofrece otra opción de transporte."
                }
              ]
            }
