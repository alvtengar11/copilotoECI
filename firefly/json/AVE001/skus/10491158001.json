    {
      "id": "/Moda_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Jeggings te ofrece: La comodidad de los leggings, el diseño de los vaqueros, y los beneficios de una prenda moldeadora."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Moldean tu cuerpo."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Aspecto más firme."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Sin cremalleras, y sin botones."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "Muy cómodos."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "Realzan tus glúteos."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 6,
                  "type": "STRING",
                  "value": "Estilizan tu figura."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 7,
                  "type": "STRING",
                  "value": "Banda ancha de ajuste perfecto."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 8,
                  "type": "STRING",
                  "value": "Reducen visualmente el exceso de volumen."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 9,
                  "type": "STRING",
                  "value": "Material efecto cuero: 96% poliéster, 4% elastano."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Jeggings offers: The comfort of leggings, the design of jeans, and the benefits of a garment molding."
                },
                {
                  "id": "en_GB",
