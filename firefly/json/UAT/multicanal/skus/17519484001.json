						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "A trotinete acoplada Bugaboo Confort+ garante um passeio suave para a criança sem restringir o movimento dos pais."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Ao fazer clique em qualquer carrinho Bugaboo (exceto no Bugaboo Runner), a trotinete transforma-se na extensão perfeita."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "O design inteligente reflete-se na colocação flexível da trotinete, à direita ou à esquerda do carrinho, criando mais espaço para o passeio dos pais."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Um assento desmontável traz flexibilidade adicional, já que a criança tem opção de caminhar."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "* A trotinete é universal. Serve para todos os modelos Bugaboo."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "** Os modelos Bugaboo Bee 5 e Bugaboo Fox têm incluidos os adaptadores."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "*** Os modelos Bugaboo Bee, Bugaboo Cameleon, Bugaboo Buffalo, Bugaboo Donkey) podem ser utilizados, mas com o adaptador correspondente (que se vendem em separado, não estão incluídos)."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "El Patinete Acoplado Confort Bugaboo garantiza un paseo suave para el niño y permite que los padres continúen moviéndose libremente por su mundo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Al hacer clic en cualquier Coche Bugaboo (excepto en el Bugaboo Runner), el Patinete se convierte en la extensión perfecta."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "El diseño inteligente queda reflejado en la colocación flexible del Patinete, a la derecha o la izquierda del cochecito, creando más espacio para el paseo de los padres."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Un Asiento desmontable aporta la flexibilidad adicional, ya que el niño tiene la opción de ir de pie."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "* El Patinete es Universal. Sirve para todos los Modelos de Bugaboo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "** Los Modelos Bugaboo Bee 5 y Bugaboo Fox llevan incorporado los Adaptadores."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "*** Los Modelos Bugaboo Bee, Bugaboo Cameleon, Bugaboo Buffalo, Bugaboo Donkey) se puede utilizar pero con el correspondiente Adaptador (que se venden por separado, no vienen incluídos).\nTransforma el Patinete acoplado confort + en un patinete acoplado confort + Bugaboo butterfly con unas piezas de conexión  8 cm más largas (se venden por separado, no vienen incluídas)"
								}
