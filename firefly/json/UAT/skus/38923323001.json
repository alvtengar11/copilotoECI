								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Bombilla smart Wi-Fi TP-Link Tapo L530E Multicolor (Pack de 2)"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Torne a sua vida mais fácil com a lâmpada inteligente da TP-Link com controlo por voz, calendarização de funcionamento, monitorização de energia e Modo Away. Fácil de ajustar a intensidade, permite-lhe facilmente colocar o tipo de luz favorito para ver filmes, ler ou apenas luz de presença."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "As funcionalidades de calendarização permite definir uma hora/dia para acender e apagar e ajustar a luz ao fuso horário. Todos os ajustes podem ser feitos remotamente com Tapo app, que conta ainda com controlo por voz através da Alexa ou Google Assistant."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Multicolor: crie facilmente cenários para a sua rotina ou atividades diárias, personalizando o brilho, a temperatura da luz e as cores, com 16 milhões de tons para escolher."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Equivalente a 60 Watts - A lâmpada LED produz até 806 lúmenes de brilho branco e tem uma faixa de dimerização de 1% a 100%."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Programação e cronómetro: Crie programações e planos de contagem para ligar / desligar com o brilho / cor que você definir."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Multicolor: diseñe fácilmente escenarios para su rutina o actividades diarias personalizando el brillo, la temperatura de la luz y los colores, con 16.000.000 de tonos para elegir."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Equivalente a 60 vatios: la bombilla LED produce hasta 806 lúmenes de brillo blanco y tiene un rango de atenuación del 1% al 100%."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Preajuste para mayor comodidad: ¿encontrada la iluminación favorita para ver películas? Guardar como un ajuste que se puede seleccionar simplemente para futuras noches de películas."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Programación y temporizador: crear programaciones y cuente planes para encender / apagar con el brillo / color que establezca."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Modos de amanecer y atardecer: activar automáticamente su luz de acuerdo con su zona horaria."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "No se requiere concentrador: conectar la luz L530E a la wifi del hogar, y estará listo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Control por voz: administrar las luces con comandos de voz. Tapo funciona con Google Assistant."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 7,
									"value": "Control remoto: abra la aplicación Tapo en su móvil para controlar la luz de forma remota"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 8,
									"value": "Modo Ausente: simular automáticamente que alguien está en casa para asustar a los visitantes no deseados"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 9,
									"value": "Restaurar último estado de luz: la bombilla vuelve automáticamente a su estado de apagado anterior."
								}
							]
						}
					]
