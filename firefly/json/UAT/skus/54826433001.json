            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Siéntete ágil tanto en los entrenamientos como en los partidos improvisados con la camiseta entallada NikeCourt Victory. Esta prenda transpirable y elástica con capilarización del sudor está diseñada para jugar en el día a día. Las costuras de la parte posterior de los hombros están pensadas para favorecer el movimiento mientras rotas y te desplazas hacia la pelota."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "La tecnología Nike Dri-FIT aleja el sudor de la piel para mantener la transpirabilidad y la comodidad."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Tejido Knit suave, ligero y transpirable."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Costuras inclinadas en la parte posterior que aumentan el rango de movimiento al golpear la pelota."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "Refuerzos en las costuras laterales para una mayor elasticidad y movilidad."
                }
              ]
            }
          ]
