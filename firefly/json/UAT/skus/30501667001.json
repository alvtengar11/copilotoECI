						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "El disco duro portátil LaCie Rugged USB-C, es el disco duro con mayor portabilidad de LaCie, y le ofrece velocidades de transferencia de USB 3.1 Gen 1. Además, la carcasa de la unidad Rugged USB-C es pequeña y ligera para poder transportarla con facilidad y es resistente a los golpes y a las caídas desde una altura de hasta 1,2 metros"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "La unidad de disco duro de LaCie se envía con dos cables para garantizar una compatibilidad universal con todos los ordenadores modernos: Un cable USB 3.1 Gen 2 (USB-C) y un cable de USB 3.1 Gen 1 (USB-C) a USB tipo A (USB 3.0 y USB 2.0)"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Utilice el cable USB 3.1 para garantizar el máximo rendimiento de la transferencia de datos con puertos compatibles. Utilice el cable de USB 3.1 (USB-C) a USB tipo A para garantizar la compatibilidad con aquellos ordenadores que no dispongan de un puerto USB-C"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Requerimientos mínimos: Mac OS X 10.7 o posterior / Windows 7 o posterior"
								}
							]
						}
					]
