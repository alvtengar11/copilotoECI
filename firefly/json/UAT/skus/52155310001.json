							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Combinación de teclado extendido compacto y ratón con conectividad inalámbrica multidispositivo"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "El Teclado Inalámbrico Subblim soporta 3 dispositivos mediante dos canales con tecnología inalámbrica Bluetooth 5.2 y uno a través de un receptor USB RF 2.4G"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "El ratón soporta 2 dispositivos, un canal con tecnología inalámbrica Bluetooth 5.2 y uno a través del receptor USB"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "El receptor USB se comparte entre el teclado y el ratón unificando ambos y ocupando solo un puerto del dispositivo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Cambia entre los diferentes dispositivos muy fácilmente pulsando el selector de modo en el teclado y el ratón."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Es el más adecuado para el hogar, la oficina, para el uso su teléfono inteligente, ordenador portátil, iPad, Tablet Android o Windows, consolas de videojuegos o Smart TV."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Funcionamiento silencioso. Las teclas silenciosas y precisas proporcionan una escritura táctil natural con un menor ruido."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 7,
									"value": "Diseñado para una mayor productividad y portátil para una entrada de datos eficiente gracias a la parte de teclado numérico incorporada."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 8,
									"value": "El ratón de alta precisión de hasta 1600 DPI también tiene los botones silenciosos y batería recargable de alta duración."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 9,
									"value": "Diseño del Teclado en Español y Ratón Ultra-Slim"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 10,
									"value": "Compatible con dispositivos Windows 8/10/11, Android, iOS/iPadOS 13 y MacOs"
								}
							]
