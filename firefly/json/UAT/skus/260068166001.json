              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Abierto 82 x 45 x 62 cm\n82 x 45 x 26,5 cm (capota plegada)\nPlegado 82 x 45 x 14 cm\n0-9 kg\n3,5 kg"
                },
                {
                  "id": "pt_PT",
