    {
      "id": "/Complementos_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
