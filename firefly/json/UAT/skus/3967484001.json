            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Tres colgantes de plata de igual diseño pero distinto color, y es que de los tres cuelgan tres exquisitas joyas en forma de lágrima en amatista,turquesa y lapislázuli , enmarcadas en plata de ley 0925 y un pavé de circonitas."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "El cierre es un sencillo y firme mosquetón de plata de ley."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Los pendientes se componen de una elegante circonita en solitario delicadamente biselada con cuatro garras de plata de ley."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Cuentan con un cierre de mariposas, un cierre que al llevar un pequeño surco, encaja a la perfección para que no se puedan descolgar."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "Podrá lucir el conjunto en su totalidad, con las tres colgantes en la misma cadena, para aquellas ocasiones más elegantes y especiales, o también podrá combinarlos de forma separada para darle un toque más informal."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "Se entregará en un elegante estuche de joyería."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Three silver pendants of the same design but different color, and that of the three hang three exquisite teardrop shaped jewelry in amethyst, turquoise and lapis lazuli, framed in sterling silver 0925 and a pavé of zirconia."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "The clasp is a simple and firm carabiner made of sterling silver."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "The earrings are made up of an elegant solitary zirconia delicately beveled with four claws of sterling silver."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "They have a butterfly closure, a closure that by wearing a small groove, fits perfectly so they can not be picked up."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "You will be able to wear the whole set, with the three pendants in the same chain, for those more elegant and special occasions, or you can combine them separately for a more informal touch."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "It will be delivered in an elegant jewelry case."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Trois pendentifs en argent de la même conception, mais de couleur différente, et est celui des trois accrocher trois bijoux améthyste teardrop, turquoise et lapis lazuli exquis, encadrée en argent sterling et pavé 0925 zircons."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "La fermeture est un fermoir en argent sterling simple et solide."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Les boucles d'oreilles sont composées d'un élégant zircons seul avec quatre griffes en argent sterling délicatement biseauté."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Ils ont une fermeture papillon, une fermeture en apportant une petite rainure, correspond à la facture pour cela ne peut pas être décroché."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "Vous pouvez consulter tout l'ensemble, avec trois suspendus dans la même chaîne, pour ceux occasion plus élégante et spéciale ou vous pouvez également combiner séparément pour lui donner une touche plus décontractée."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "Il sera livré dans une boîte à bijoux élégante."
                }
              ]
