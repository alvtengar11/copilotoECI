				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 0,
					"children": [
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Explora novas fronteiras de jogo na tua consola PS5/PC com o comando sem fios DualSense Cosmic Red. Parte de uma nova linha de cores da nossa galáxia, este design vívido em duas cores inspira-se nos tons de vermelho únicos e deslumbrantes espalhados pelo nosso cosmos, complementado por detalhes de botão a condizer para um acabamento futurista."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Descobre uma experiência de jogo mais profunda e altamente envolvente que dá vida à ação nas palmas das tuas mãos. O comando sem fios DualSense oferece feedback háptico envolvente, gatilhos adaptáveis dinâmicos e um microfone incorporado, tudo integrado num design confortável."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Dá vida aos mundos dos jogos:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "- Sente as tuas ações e o ambiente simulado nos jogos através do feedback háptico"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "- Experimenta níveis variáveis de força e tensão nas pontas dos teus dedos com os gatilhos adaptativos"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Encontra a tua voz, partilha a tua paixão:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "- Conversa online através do microfone incorporado"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 7,
									"value": "- Liga uns auscultadores diretamente através da entrada de 3,5 mm."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 8,
									"value": "- Liga e desliga a captura de voz com o botão de silenciamento dedicado."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 9,
									"value": "- Grava e transmite os teus momentos épicos de jogo com o botão de criação"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 10,
									"value": "Um ícone dos jogos nas tuas mãos:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 11,
									"value": "- Desfruta de um design confortável e evoluído com uma disposição icónica e manípulos melhorados."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 12,
									"value": "- Carrega e joga com uma bateria incorporada e uma porta USB Type-C"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 13,
									"value": "- Interage intuitivamente com determinados jogos através do sensor de movimento integrado"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 14,
									"value": "- Ouve efeitos sonoros de maior fidelidade1 através da coluna incorporada em jogos suportados"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Descubre una experiencia de juego más profunda e inmersiva con el nuevo e innovador mando de PS5, que ofrece retroalimentación háptica y efectos de gatillos adaptativos. El mando inalámbrico DualSense incorpora además un micrófono integrado y un botón Crear, todo integrado en un icónico y práctico diseño."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Compatible con PlayStation 5, PC, Mac y dispositivos móviles."
								}
							]
						}
					]
				},
