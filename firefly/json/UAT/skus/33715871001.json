								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "A linha de sofás Ness tem peças com um design muito contemporâneo, de linhas muito simples que contribuem para que a sua sala possa introduzir peças aprazíveis, sossegadas, serenas e elegantes."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "É um design fino, minimalista, de traços rectos que devolvem um conjunto harmónico e envolvente. Os diferentes modelos de sofá, cadeirão ou pufe têm assentos amplos para desfrutar ao máximo os seus momentos de descanso."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Configure o seu sofá com o tecido, pés e o enchimento que preferir e dê-lhe o seu toque pessoal."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Sofá con chaiselongue perteneciente a nuestra colección Ness que puedes configurar eligiendo el tejido, las patas y el relleno que prefieras."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Los sofás Ness tienen un diseño contemporáneo, de líneas sencillas, con asientos amplios y grandes almohadones que garantizan un alto grado de confort."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Configura tu sofá con la tela, patas y el relleno que prefieras y dale tu toque personal."
