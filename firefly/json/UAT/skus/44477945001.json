					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "VISUALIZAÇÃO FÁCIL COM CONTROLO DE VOZ"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Controle a sua TV com comandos de voz simples. A sua smart TV vem com o Google Assistant integrado. Isso significa que com um simples toque você pode usar comandos de voz para controlar facilmente o seu dispositivo, gerir tarefas e visualizar o seu calendário. Você pode até controlar os outros dispositivos inteligentes na sua casa a partir da sua smart TV. O futuro é agora."
								}
							]
						}
					]
				},
