  "specificAttribs": [
    {
      "id": "/Generica_Bebes_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "CaracteristicasGenerales",
          "type": "GROUPING",
          "children": [
            {
              "id": "OtrasCaracteristicas",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "value": "Consulte sempre a etiqueta do tecido antes de lavar. \nLavar separadamente. \nTodas as capas podem ser lavadas à máquina a 30 °C. \nAs instruções de lavagem podem variar segundo a versão do produto, a primeira versão deve ser lavada à mão. \nConsulte sempre a etiqueta de lavagem para obter instruções exatas."
                }
              ]
            },
            {
              "id": "Material",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "value": "Exterior: 100% poliéster.\nEnchimento 1: 100% espuma de poliuretano.\nEnchimento 2: 100% poliéster."
                }
              ]
            },
            {
              "id": "Incluye",
              "type": "STRING",
              "children": [
                {
