				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 0,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "Detalhes do Produto"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "TopSpin 2K25, a lendária parcela da saga de videojogos desportivos de ténis da 2K, regressa após anos de ausência para os fãs de ténis e adeptos da modalidade para proporcionar a derradeira experiência.\n\nUm dos simuladores de ténis profissionais mais realistas, de regresso para a antiga e a nova geração, os utilizadores da PS4, PS5 e XBOX poderão desfrutar deste simulador desportivo imprescindível do mundo das raquetes, apresentado em parceria com o Open da Austrália."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 1,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "GANHE O CAREER GRAND SLAM®"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Viaje pelo mundo como profissional em ascensão, socialize com os maiores nomes do ténis e assuma uma posição de destaque em Wimbledon, Roland-Garros, no US Open e no Australian Open enquanto trabalha para se tornar Campeão do Grand Slam® no modo MyCAREER."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 2,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "COMPITA EM LOCAIS ICÓNICOS"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Visite alguns dos campos de ténis mais vibrantes do circuito de ténis no TopSpin 2K25. Desde os quatro torneios do Grand Slam® até arenas internacionais emblemáticas como Indian Wells, La Caja Mágica, Pala Alpitour, Foro Italico e mais."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 3,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "LENDAS DO TÉNIS E ESTRELAS EM ASCENSÃO"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Jogue como as lendas do ténis Roger Federer e Serena Williams ou sirva como os maiores: Carlos Alcaraz, Iga Swiatek, Frances Tiafoe, Andre Agassi e outros. Liberta o poder explosivo e as habilidades incríveis de mais de 24 profissionais jogáveis contra outros jogadores em modo multijogador local ou online."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 4,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "DOMINE O CAMPO ONLINE"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Teste a coragem do seu MyPLAYER e mostre a qualidade do seu ténis no World Tour ou entre no Tour 2K quando profissional de jogo a desafiar jogadores em todo o mundo com suporte multiplataformas."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 5,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "TREINE COM JOHN MCENROE"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Desde serviços poderosos a drop-shots elegantes, aprenda a jogar como uma lenda com John McEnroe na TopSpin Academy. Domina os controlos avançados através de uma série de exercícios e desafios que te melhoram as capacidades e te ajudam a vencer em qualquer situação."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 6,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "PERSONALIZE O SEU MyPLAYER"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Crie um MyPLAYER adaptado ao seu estilo de jogo e defina o seu visual no court! Com uma vasta gama de opções de personalização, podes ajustar os teus atributos e ganhar novos treinadores, acessórios e equipamento da Adidas, HEAD, Lacoste, New Balance, Nike, Wilson e mais."
								}
