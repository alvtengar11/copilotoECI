  "specificAttribs": [
    {
      "id": "/Menaje_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Sistema cómodo: todo se prepara desde el mismo sitio"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Sistema fácil: se puede cortar y almacenar con los recipientes que se incluyen"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Sistema rápido: todo está en el mismo contenedor."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Sistema limpio: no hay que utilizar recipientes adicionales, se corta, se guarda y se conserva. La tablas están dotadas de una superfice antibacteriana que no raya, ni mancha  ni absorbe malos olores, se mantiene limpia y como nueva durante muchos años."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "Una solución diseñada con materiales de alta calidad: tabla flexible y antideslizante. Dos tablas ultrarresistentes para cortar todo tipo de alimentos. Recipientes de metacrilato, tapas herméticas."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "Apto para el lavavajillas"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 6,
                  "type": "STRING",
                  "value": "La solución perfecta cuando se quiere marinar, rebozar, etc"
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
