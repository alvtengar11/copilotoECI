              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "La identidad de Davidoff Cool Water evoca la sensualidad de los poderes relajantes y misteriosos del agua. Combina fuerza, sensualidad y frescor, en una fragancia única y una imagen de comunicación de marca distinta, una completa sinergia entre el océano, el cuerpo y el espíritu del hombre."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Dia y Noche"
                },
                {
                  "id": "es_ES",
