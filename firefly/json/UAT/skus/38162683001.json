						{
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Plug 'n' Clean, el sistema de detergente de Kärcher"
								}
							],
							"id": "TituloPrincipal",
							"type": "STRING"
						},
						{
							"children": [
								{
									"ocurrence": 0,
									"id": "es_ES",
									"type": "STRING",
									"value": "Innovador dispositivo encajable para botellas de detergente de Kärcher. Para una aplicación rápida, sencilla y cómoda de detergente con la limpiadora de alta presión. Los detergentes Kärcher aumentan la eficiencia, protegen y conservan la superficie."
