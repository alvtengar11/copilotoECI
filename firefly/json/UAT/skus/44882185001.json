									"ocurrence": 1,
									"value": "Marcas de uso."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 1,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Tu Galaxy Watch4 Classic, siempre contigo"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Lleva siempre contigo un dispositivo con el que entrenar, monitorizar tu salud y que te servirá de asistente personal. Su sistema operativo en muy fácil de usar y podrás llevar el control de tu IMC, la masa muscular, la grasa corporal, el IMB, la presión arterial y mucho más."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Gracias a los más y mejores sensores del nuevo Samsung Galaxy Watch4 Classic podrás realizar un análisis exacto de tu composición corporal y ver detalladamente los porcentajes de grasa corporal, masa muscular y mucho más. Además, podrás entender mejor cómo duermes gracias a su análisis profundo de sueño, ronquidos y de oxígeno en la sangre. El Samsung Galaxy Watch4 Classic almacenará todos estos datos en la aplicación Samsung Health y creará un histórico que podrás consultar siempre y compartir con tu médico."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Y no termina allí, el nuevo Samsung Galaxy Watch4 Classic cuenta con un Electrocardiograma el cual detecta latidos irregulares del corazón desde tu muñeca, también es capaz de enviar una señal de alerta de ayuda compartiendo tu ubicación en caso de detectar irregularidades en caso de caídas fuertes. Tu Samsung Galaxy Watch4 Classic sabrá qué ejercicio estás haciendo ya que cuenta con 90 ejercicios diferentes incorporados para monitorear. Sin duda, esto lo convierte en un compañero indispensable para el deporte."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "El nuevo Sistema Operativo de Samsung: Wear OS, le proporciona al nuevo Samsung Galaxy Watch4 Classic un mayor ecosistema y catálogo de aplicaciones. Accede directamente desde tu muñeca a todas los servicios populares de Google como Play Store, Maps o Youtube Music, mantén tu salud al día con las nuevas funciones de Samsung Health y paga directamente desde tu muñeca con Samsung Pay."
								}
							]
						}
					]
				},
