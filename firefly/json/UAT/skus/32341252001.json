						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"ocurrence": 0,
									"type": "STRING",
									"value": "O ecrã com tecnologia Garmin Chroma Display™, legível sob luz solar e sempre ligado, está protegido por Corning® Gorilla® Glass 3 resistente."
								},
								{
									"id": "pt_PT",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Veja os níveis de energia do seu corpo durante o dia para que possa encontrar os melhores momentos para atividade e para descanso."
								},
								{
									"id": "pt_PT",
									"ocurrence": 2,
									"type": "STRING",
									"value": "O sensor de oximetria de pulso mede a saturação de oxigénio no sangue durante o dia e enquanto dorme para avaliar a absorção de oxigénio do seu corpo."
								},
								{
									"id": "pt_PT",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Quando quiser relaxar ou concentrar-se, pode iniciar uma atividade de trabalho de respiração e este relógio irá monitorizar o seu stress e respiração para ajudar a compreender melhor como respira."
								},
								{
									"id": "pt_PT",
									"ocurrence": 4,
									"type": "STRING",
									"value": "Quando o relógio e o telemóvel estiverem emparelhados, a sua localização em tempo real pode ser enviada para os seus contactos manualmente ou, durante atividades ao ar livre, automaticamente com a deteção de incidentes incorporada."
								},
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "vivoactive 4S smartwacth con GPS, música y Garmin Pay. Más de 15 perfiles de actividad precargados, VO2 Max, control de estrés, pasos, sueño. Pulsometro integrado en muñeca. Notificaciones inteligentes. Conecta con la app Connect IQ para más perfiles, widgets,... Conectividad BLE y auntonomía de 7 días en modo smartwatch y 8 horas con GPS activado"
								}
							]
						}
