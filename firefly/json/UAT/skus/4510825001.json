e":"false"},{"id":"IdMensajeAnterior","type":"NUMBER"}]}],"link":[{"id_Ext":"17399011013","hierarchyId":"999","categoryId":"1486723358"},{"id_Ext":"2865209021","hierarchyId":"100167","categoryId":"2865209021"},{"id_Ext":"8627176016","hierarchyId":"2013","categoryId":"1434101083"},{"id_Ext":"5520012","hierarchyId":"998","categoryId":"00217"},{"id_Ext":"2865214021","hierarchyId":"100167","categoryId":"2865214021"},{"id_Ext":"50357018","hierarchyId":"5001","categoryId":"01.979.234"},{"id_Ext":"2865210021","hierarchyId":"100167","categoryId":"2865210021"},{"id_Ext":"19023276020","hierarchyId":"5003","categoryId":"1494319202"},{"id_Ext":"2865211021","hierarchyId":"100167","categoryId":"2865211021"},{"id_Ext":"8592468016","hierarchyId":"2013","categoryId":"1433859574"},{"id_Ext":"2865212021","hierarchyId":"100167","categoryId":"2865212021"}],"specificAttribs":[{"id":"/Perfumeria_ISS","type":"SPEC","children":[{"id":"DescripcionLarga","ocurrence":0,"type":"GROUPING","children":[{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Emulsión con propiedades hidratantes, nutritivas y regeneradoras del tejido cutáneo. Su uso diario y continuo ayuda a fortalecer y renovar el tejido cutáneo logrando sorprendentes resultados en el tratamiento de marcas e imperfecciones de la piel (manchas, marcas de acné y pequeñas arrugas y cicatrices)."}]}]},{"id":"DescripcionLarga","ocurrence":1,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Activos"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Colágeno y Elastina. El colágeno y la elastina son los principales componentes del tejido conectivo de la piel, asegurando flexibilidad, tonicidad y elasticidad a la piel, propiedades que se deterioran con los años. Se trata de elementos abundantes en pieles jóvenes que van perdiendo sus propiedades con la edad. Por ello, puede decirse que se trata de dos componentes esenciales en la lucha contra el envejecimiento."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Alantoína. La alantoína es un activo que promueve la regeneración y la renovación celular, favoreciendo la renovación del tejido cutáneo."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Complejo de Alfa-hidroxiácidos y Vitamina A. La acción más importante de los Alfa-Hidroxiácidos, entre los que cabe destacar el ácido glicólico, es la de exfoliar las capas externas y deterioradas del estrato córneo de la epidermis. El resultado es una extraordinaria renovación de la superficie de la piel, que se manifiesta por una gran mejoría en la topografía general cutánea, con la consiguiente desaparición de pequeñas arrugas y surcos de expresión. La piel queda más fina, sedosa y aterciopelada."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Además, la Vitamina A tiene una gran cantidad de efectos beneficiosos sobre la piel, como son: Poder cicatrizante debido a la estimulación del metabolismo de las células epidérmicas, Acelera la formación de colágeno y elastina, Estimula la respuesta inmunológica de las células epidérmicas, Efecto antiarrugas, Potencia la capacidad antioxidante y captora de radicales libres por parte de la piel."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Aceite de Rosa Mosqueta : Se trata de un aceite que posee un alto contenido de ácidos grasos esenciales poliinsaturados: Linoleico 44-49% y Linolénico 28-34%. Estos ácidos son sustancias nobles, indispensables para áreas en las cuales existen altos índices de proliferación de células nuevas, tales como el rostro."},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"También se  conoce por su alto contenido en Vitamina A, E, C y B1 y B2, con excepcionales propiedades regenerativas y cicatrizantes."},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"Además de sus efectos en las capas más externas de la piel, el Aceite de Rosa Mosqueta también devuelve la vitalidad a las células de las capas interiores, revigorizando el fibroblasto, células que producen colágeno y elastina, responsables de la firmeza y elasticidad de la piel."},{"id":"es_ES","ocurrence":7,"type":"STRING","value":"Entre sus propiedades destacan: Regeneración y nutrición de la piel, eliminando arrugas no profundas y reduciendo cicatrices, Redistribución de la pigmentación, permitiendo la eliminación de manchas, Realiza acciones preventivas y correctivas al fotoenvejecimiento y problemas cutáneos por exposición a las radiaciones solares a través de la autogeneración de melanina."},{"id":"es_ES","ocurrence":8,"type":"STRING","value":"Aloe Vera. El Aloe es un ingrediente muy importante, pues penetra en las tres capas de la piel: epidermis, la dermis, la hipodermis, y expulsa las bacterias y los depósitos de grasa que tapan los poros. Al mismo tiempo la acción de los nutrientes naturales, los minerales, las vitaminas, los aminoácidos y las enzimas, estimulan la reproducción de nuevas células."},{"id":"es_ES","ocurrence":9,"type":"STRING","value":"También es un importante regenerador celular, cicatrizante, tonificador y de alta penetración en la piel. Cuando se usa con regularidad, evita las arrugas prematuras y retarda las propias de la edad. Es un excelente filtro solar de rayos ultravioletas y elimina las manchas causadas por el sol, si se usa por un periodo largo de tiempo."},{"id":"es_ES","ocurrence":10,"type":"STRING","value":"Placenta vegetal, Se trata de un activo con acción reestructurante y protectora de la piel que contribuye al enriquecimiento y a la suavidad de la piel."},{"id":"es_ES","ocurrence":11,"type":"STRING","value":"Extracto de microalgas. Plancton termal procedente de la microalga Porphyridium cruentum. Se trata de un alga unicelular con propiedades hidratantes, suavizantes, protectoras frente al daño causado por radicales libre y rayos UV, y favorecedora de la luminosidad y aclaración de la piel."},{"id":"es_ES","ocurrence":12,"type":"STRING","value":"Vitamina E. La vitamina E es altamente conocida por su elevada actividad antioxidante."}]}]},{"id":"DescripcionLarga","ocurrence":2,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Indicaciones"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Fórmula con múltiples propiedades beneficiosas para la piel, que estimula una profunda y constante regeneración de la piel. Aplicar dos o tres veces al día sobre la piel perfectamente limpia, acompañando siempre de un suave masaje hasta su completa absorción."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"No contiene protección solar por lo que no se recomienda su aplicación durante largas exposiciones al sol y se ha de evitar el contacto con los ojos."}]}]},{"id":"DescripcionLarga","ocurrence":3,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Composición"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Ingredients: Aqua, Cetearyl alcohol (and) Sodium lauryl sulfate, Aloe barbadensis leaf juice, Petrolatum, Isoeicosane, Glycerin, Hydrolyzed vegetable protein, Caprylic/capric/triglyceride, Decyl oleate, Dimethicone, Porphyridium cruentum extract, Paraffin, Propylene glycol, Hydrolyzed elastin, Hydrolyzed collagen, Cetyl alcohol, Aqua (and) Lactic acid (and) Glycolic acid (and) Sodium hydroxide (and) Malic acid (and) Tartaric acid  (and) Citric acid  (and) Retinyl palmitate, Rosa moschata oil, Urea, PEG-12 dimethicone, Tocopheryl acetate, Allantoin, Cyclomethicone (and) Dimethiconol, Phenoxyethanol (and) Methylparaben (and) Butylparaben (and) Ethylparaben (and) Propylparaben (and) Isobytylparaben, Methylchloroisothiazolinone, Methylisothiazolinone, Magnesium nitrate, Parfum, Citral, Limonene, Linalool."}]}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20100101_000001"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER"}]},{"id":"/Comunes_ISS","type":"SPEC","children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"Multimedia","type":"GROUPING","children":[{"id":"Fotos","type":"GROUPING","children":[{"id":"MainFotos","type":"GROUPING","children":[{"id":"UrlImagenT","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__100x100.jpg"},{"id":"UrlImagenX","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__40x40.jpg"},{"id":"UrlImagenL","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__225x225.jpg"},{"id":"UrlImagenM","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__150x150.jpg"},{"id":"UrlImagenG","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__600x600.jpg"},{"id":"UrlImagenP","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__1000x1000.jpg"},{"id":"UrlImagen170x170","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__170x170.jpg"},{"id":"UrlImagen210x210","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400317____1__210x210.jpg"},{"id":"Ur