						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Os odores podem afetar significativamente a qualidade do vinho durante a sua preservação. Os armários para vinhos Liebherr possuem um filtro de carvão ativado intercambiável para garantir a renovação do ar e uma qualidade do ar perfeita."
								}
							]
						}
