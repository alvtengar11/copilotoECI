						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "As prateleiras de madeira são ideais para o armazenamento seguro de garrafas de vinho. Colocar as garrafas em posições opostas nas prateleiras de madeira reguláveis ??em altura pode aproveitar ao máximo a capacidade interior."
								}
							]
