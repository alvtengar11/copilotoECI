	"specificAttribs": [
		{
			"id": "/Generica_Bebes_ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "DescripcionLarga",
					"ocurrence": 0,
					"type": "GROUPING",
					"children": [
						{
							"id": "Descripcion_OLD",
							"ocurrence": 0,
							"type": "STRING",
							"value": "Hamaca Stokke ® Steps TM, en rojo."
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 1,
							"type": "STRING",
							"value": "Está diseñada para brindar el mejor confort a tu bebé."
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 2,
							"type": "STRING",
							"value": "Tu bebé descansará sobre un asiento suave y acolchado, al tiempo que se sentirá acunado en tus brazos gracias al movimiento calmante de la silla."
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 3,
							"type": "STRING",
							"value": "A medida que crece, tu bebé descubrirá que puede utilizar sus propios movimientos corporales para hamacarse. Esto lo fortalece, promueve su desarrollo y le enseña a calmarse y a entretenerse solo."
						},
						{
							"id": "Descripcion_OLD",
							"ocurrence": 4,
							"type": "STRING",
							"value": "Tu bebé tendrá siempre a mano sus juguetes preferidos gracias al colgador de juguetes desmontable."
						},
						{
							"id": "Descripcion",
