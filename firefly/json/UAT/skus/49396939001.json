                  "ocurrence": 4,
                  "value": "100% algodón"
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 5,
                  "value": "RECOMENDACIONES:"
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 6,
                  "value": "Lavar a máquina en frío, no usar lejía, secar en secadora a baja, plancha baja, no limpiar en seco"
                }
