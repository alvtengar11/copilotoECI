							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Las Vegan Gummy Bar son una fuente de hidratos de carbono. El consumo de hidratos de carbono ayuda a mantener la glucosa en la sangre, aportando energía a nuestro cuerpo y manteniendo un alto rendimiento físico."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Son unas barritas de 30 g con textura de gelatina que las hacen perfectas tanto en los entrenamientos como en las competiciones."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Son equivalentes a tomar una bolsita de gominolas con la ventaja de ser más fáciles de comer por su formato alargado en una sola pieza"
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 1,
