        {
          "id": "DescripcionLargaDelProducto",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Juego de la fiable marca Arcos compuesto por taco, cuchillo panero, cuchillo jamonero, cuchillo mondador, cuchillo de cocinero y tijeras de cocina. Los cuchillos son de acero inoxidable forjado Nitrum y tienen el mango de polioximetileno. La tijera es de acero inoxidable con el mango de plástico."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "El juego viene presentado en un estuche propio para que puedas guardarlo con facilidad o regalarlo."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Set from the reliable brand Arcos comprising a block, bread knife, ham knife, paring knife, chef's knife and kitchen scissors. The knives are made of Nitrum forged stainless steel and the handle is polyoxymethylene. The scissors are made of stainless steel with a plastic handle."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Ensemble de la fameuse marque Arcos composé d'un bloc, d'un couteau à pain, d'un couteau à jambon, d'un couteau à peler, d'un couteau de cuisinier et de ciseaux de cuisine. Les couteaux sont fabriqués en acier inoxydable forgé Nitrum et le manche en polyoxyméthylène. Les ciseaux sont fabriqués en acier inoxydable avec un manche en plastique."
                }
              ]
            }
          ]
