Impuesto","type":"STRING","value":"02"}]},{"id":"Impuestos","ocurrence":3,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0737"},{"id":"Impuesto","type":"STRING","value":"02"}]},{"id":"Impuestos","ocurrence":4,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0909"},{"id":"Impuesto","type":"STRING","value":"01"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"129469378"}]}],"link":[{"id_Ext":"3283132022","hierarchyId":"5004","categoryId":"9909549022"},{"id_Ext":"2812567018","hierarchyId":"5001","categoryId":"01.975.605"},{"id_Ext":"5391012","hierarchyId":"998","categoryId":"00072"},{"id_Ext":"12202698011","hierarchyId":"997","categoryId":"20160519021936"},{"id_Ext":"11914485011","hierarchyId":"997","categoryId":"20160411123133"},{"id_Ext":"53539013","hierarchyId":"999","categoryId":"1354291507"}],"unlink":[],"specificAttribs":[{"id":"/Videojuegos_ISS","type":"SPEC","children":[{"id":"CaracteristicasGenerales","type":"GROUPING","children":[{"id":"CaracteristicasDelJuego","ocurrence":0,"type":"GROUPING","children":[{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"FIFA 16 aportará novedades en todo el campo de juego para que tengas una experiencia de fútbol equilibrada, auténtica y emocionante que te permite jugar a tu manera, y competir a más alto nivel. Un nuevo modo de juego de EA Sports FIFA introduce a las Selecciones Nacionales Femeninas en la franquicia."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Con las nuevas características de juego, FIFA 16 aportara Seguridad en Defensa, Control en el Centro del Campo y más posibilidades de crear esos momentos de mágicos del fútbol. Tanto los fans nuevos como los jugadores expertos que buscan mejorar su juego tendrán la oportunidad de competir en un nivel más alto utilizando el nuevo FIFA Trainer."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Novedades en todo el campo de juego y nuevos modos. Compite en un nivel más alto. Siente la magia del fútbol con FIFA 16."}]}]},{"id":"CaracteristicasDelJuego","ocurrence":1,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Novedades en todo el Campo de Juego:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Seguridad en Defensa:"},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Agilidad Defensiva: más de 25 mejoras en las reacciones de los defensas han mejorado el movimiento defensivo para permitir a la defensa no perder de vista a sus atacantes rivales. La defensa ahora es capaz de cerrar espacios sin desorganizarse y cambiar de dirección mediante desplazamientos que dan equilibrio a las situaciones de uno contra uno. El tiempo de máxima aceleración de la defensa y la mayor libertad de movimiento hará que la defensa se pegue a sus rivales y logre detener el ataque."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Defensa en Equipo: confía en tus compañeros de equipo para cubrir los huecos cuando vas a por un atacante. La nueva inteligencia defensiva de los jugadores mejora la percepción de los espacios peligrosos en el campo y ante sus oponentes. Tus compañeros de equipo bajaran a la defensa para detener a tus oponentes y cubrir las zonas de peligro."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Nuevos Fundamentos de Entradas: las nuevas formas de comportamiento de entradas te ayudaran a tomar posesión del balón. Además ofrece nuevas posibilidades a la hora de defender, como un amago de entrada, entrada con el cuerpo, o la posibilidad de contralar la distancia de una entrada rasa en caso de estar fuera de posición. Las entradas en FIFA 16 ahora son controlables y gratificantes"}]}]},{"id":"CaracteristicasDelJuego","ocurrence":2,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Control en el Centro del Campo:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Inteligencia para Interceptar el Balón: controla el centro del campo con el nuevo sistema de Intercepción que te ayuda a cubrir posibilidades de pase y así reducir las opciones de ataque. Esto crea una experiencia más auténtica en el centro de campo. En FIFA 16, la Inteligencia para Interceptar el Balón se podrá ajustar en el menú de opciones y poder decidir el nivel de agresividad con la que tus compañeros de equipo irán por el balón. El control sobre la creación de peligro desde el centro del campo está en tus manos."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Pases Orientados: FIFA 16 revoluciona los pases. Ahora podrás jugar pases más orientados y encontrar a tus compañeros con más precisión.  Una nueva mecánica de botón mejorara los pases a tus compañeros de equipo en espacios reducidos y dejara abrir nuevos caminos para tu ataque. Los Pases Orientados hacen un balance perfecto con la Inteligencia de Intercepción para crear una experiencia de fútbol aún más realista."}]}]},{"id":"CaracteristicasDelJuego","ocurrence":3,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Momentos de magia:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Regate sin Tocar el Balón: una característica del juego inspirada en la captura de movimientos realizada a Lionel Messi, que revoluciona la manera en que ahora los jugadores pueden atacar en el juego. Esta nueva forma de regate da a los jugadores la opción de dejar correr el balón para ganar tiempo, crear espacios, fintar y deshacerse del contrincante en el último tercio del campo. Esto revoluciona las batallas 1 contra 1 y te dará más oportunidades de ataque."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Centros Dinámicos: hacer centros en FIFA 16 ha cambiado la forma de reaccionar tanto del jugador que realiza el centro como los compañeros en el área que lo reciben. Se han integrado nuevas animaciones realistas a los jugadores al momento de desmarcarse para realizar un centro. Los jugadores en el área seguirán la trayectoria del balón para desmarcarse y rematar el balón en movimiento. Esto significa que los delanteros crearan más peligro y podrán jugar el balón por detrás de la línea defensiva."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Eficacia en el Ataque: el juego dará a los usuarios múltiples opciones para finalizar la jugada como un auténtico profesional. La trayectoria mejorada y la velocidad dinámica del balón harán que la experiencia de marcar un gol sea aún más emocionante."}]}]},{"id":"CaracteristicasDelJuego","ocurrence":4,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Competir a más alto nivel:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"FIFA Trainer: independientemente de las habilidades de cada jugador, todos los fans tendrán la posibilidad de competir al más alto nivel utilizando EA SPORTS FIFA Trainer, un sistema pionero de entrenamiento que utiliza el contexto del juego para facilitar opciones al jugador. Con el nuevo menú grafico podrás aprender mientras que juegas y te proporcionara consejos dependiendo de tu posición en el campo y el nivel de entrenador (automático o manual). Los consejos básicos darán la introducción al juego mientras que los consejos avanzados mejoraran la forma de jugar de los más expertos. Es como tener a un experto a tu lado mientras juegas."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Juegos de habilidad: Nivel básico, un nuevo nivel para los juegos de habilidad para los jugadores que juegan por primera vez a EA Sports FIFA."}]}]},{"id":"CaracteristicasDelJuego","ocurrence":5,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Nuevas formas de jugar:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Selecciones Nacionales Femeninas: por primera vez en la historia de la franquicia, contamos con 12 Selecciones Nacionales Femeninas (España, Australia, Brasil, Canadá, China, Inglaterra, Francia, Alemania, Italia, México, Suecia y los Estados Unidos) que representarán a sus respectivas federaciones en varios modos de juego, incluyendo Partido Rápido, Torneo Offline, así como Partidos Amistosos Online."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Hemos creado nuevas animaciones y modelos 3D para las mujeres."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Para hacer los movimientos lo más realista posible se han capturado los movimientos del equipo nacional estadounidense como referencia."}]}]},{"id":"Plataforma","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"462","id_Ext":"351026090","value":"PC"},{"id":"Desarrolladores","type":"LOOKUP_TABLE","featureGroupID":"460","id_Ext":"491983090","value":"EA Canada"},{"id":"Distribuidores","type":"LOOKUP_TABLE","featureGroupID":"461","id_Ext":"390926090","value":"EA Games"},{"id":"Pegi","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"468","id_Ext":"352515090","value":"7+"},{"id":"Genero","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"464","id_Ext":"2160332090","value":"Fútbol"},{"id":"SoporteDigital","type":"LOOKUP_TABLE","featureGroupID":"147","id_Ext":"350695090","value":"DVD"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"129469378"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","