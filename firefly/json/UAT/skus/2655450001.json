	"specificAttribs": [
		{
			"id": "/Videojuegos_ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "CaracteristicasGenerales",
					"type": "GROUPING",
					"children": [
						{
							"id": "CaracteristicasDelJuego",
							"ocurrence": 0,
							"type": "GROUPING",
							"children": [
								{
									"id": "CaracteristicasDelJuego",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"ocurrence": 0,
											"type": "STRING",
											"value": "Transforma lo ordinario en extraordinario y disfruta de una gran experiencia constructiva de LEGO con La LEGO Película: El Videojuego."
										},
										{
											"id": "es_ES",
											"ocurrence": 1,
											"type": "STRING",
											"value": "Entra en el mundo de Emmet, un ciudadano medio, completamente ordinario, y que sigue las reglas a rajatabla, pero que será confundido con una de las personas más extraordinarias del mundo y la clave para salvar al mundo."
										},
										{
											"id": "es_ES",
											"ocurrence": 2,
											"type": "STRING",
											"value": "Los jugadores deberán guiarle en una épica aventura para detener a un malvado tirano, un viaje para el que Emmet no está preparado."
										}
									]
								}
							]
						},
						{
							"id": "CaracteristicasDelJuego",
							"ocurrence": 1,
							"type": "GROUPING",
							"children": [
								{
									"id": "Titular",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"type": "STRING",
											"value": "Características:"
										}
									]
								},
								{
									"id": "CaracteristicasDelJuego",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"ocurrence": 0,
											"type": "STRING",
											"value": "Disfruta de más de 90 personajes diferentes que también aparecen en la película, incluyendo a Batman, Superman y Gandalf en más de 15 niveles."
										},
										{
											"id": "es_ES",
											"ocurrence": 1,
											"type": "STRING",
											"value": "Revienta más bloques que nunca en un entorno fascinante hecho de bloques de LEGO."
										},
										{
											"id": "es_ES",
											"ocurrence": 2,
											"type": "STRING",
											"value": "Colecciona y utiliza las páginas de instrucciones de LEGO para construir lo que imagines."
										},
										{
											"id": "es_ES",
											"ocurrence": 3,
											"type": "STRING",
											"value": "Viaja a través de fantásticos mundos como Ladriburgo, La Nube Cucolandia y muchos más."
										},
										{
											"id": "es_ES",
											"ocurrence": 4,
											"type": "STRING",
											"value": "Utiliza el increíble poder de los Maestros Constructores para construir extraordinarias creaciones de LEGO."
										},
										{
											"id": "es_ES",
											"ocurrence": 5,
											"type": "STRING",
											"value": "Disfruta de una auténtica experiencia LEGO como nunca antes se ha visto, con un nuevo estilo de animación visual en el cual se recrea el movimiento de los juguetes LEGO de forma real."
										},
										{
											"id": "es_ES",
											"ocurrence": 6,
											"type": "STRING",
											"value": "Juega con familia y amigos en el modo cooperativo en pantalla dividida."
										}
									]
								}
							]
						},
