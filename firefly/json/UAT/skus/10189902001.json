							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Densidad energética y grasas\t reducidas que ayudan a evitar la ganancia de peso."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Fibra incrementada que proporciona más volumen al alimento, lo que ayuda a evitar la sensación de hambre."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "L-Carnitina suplementada que incrementa la conversion de grasa en energía, para limitar su almacenamiento."
								},
								{
									"id": "es_ES",
