								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Alimento especialmente recomendado para perros senior que requieran menos aporte calórico, a partir de los 7 años de edad (perros con poca actividad, esterilizados o con tendencia al sobrepeso)."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "No está recomendado para gatos, cachorros ni para perras gestantes o en período de lactación. Durante estos períodos se debe cambiar el alimento de las perras a alguna de las fórmulas Science Plan Puppy Healthy Development (con excepción de Puppy Healthy Development Razas Grandes)."
								}
							]
						}
					]
				},
