n": [						{							"id": "TituloPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"value": "Pantalla brillante, colorida e inmersiva para un entretenimiento más fluido"								}							]						},						{							"id": "DescripcionPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"ocurrence": 0,									"value": "Redmi Note 12 cuenta con una pantalla AMOLED increíblemente brillante y colorida con una impresionante frecuencia de una amplia gama de colores que mejora la experiencia inmersiva y fluida. Ya sea que estés navegando por el contenido de las redes sociales o jugando a juegos, seguramente estarás encantado con las suaves transiciones de la pantalla y la jugabilidad. El modo de alto brillo generalmente alcanza hasta 700 nits, lo que lo hace ideal para tomar fotos y navegar por las webs incluso en días soleados. Podrás ver el contenido claramente incluso con luz muy brillante. La pantalla siempre activa brinda acceso rápido a información útil con un rápido doble toque."								}							]						}					]				},				{					"id": "DescripcionLargaDelProducto",					"type": "GROUPING",					"ocurrence": 2,					"children": [						{							"id": "TituloPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"value": "Más potencia, más rendimiento, más diversión"								}							]						},						{							"id": "DescripcionPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"ocurrence": 0,									"value": "Equipado con una pocesador móvil Snapdragon 685, Redmi Note 12 brinda una experiencia multitarea eficiente y sin problemas en fotografía, juegos, audio y multimedia. Fabricado en 6 nm, esto aumenta la eficiencia energética de la CPU de 2,8 GHz. Con 8 GB de RAM, puedes cambiar fácilmente entre diferentes aplicaciones y realizar varias tareas simultáneamente sin retardos ni retrasos. Junto con un almacenamiento rápido optimizado de hasta 256 GB, Redmi Note 12 permite instalar más de tus aplicaciones favoritas y guardar más fotos y videos sin preocuparte por quedarte sin espacio."								}							]						}					]				},				{					"id": "DescripcionLargaDelProducto",					"type": "GROUPING",					"ocurrence": 3,					"children": [						{							"id": "TituloPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"value": "Una combinación ganadora de batería de 5000 mAh y carga rápida de 33W"								}							]						},						{							"id": "DescripcionPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"ocurrence": 0,									"value": "Aporta valor y confianza, Redmi Note 12 tiene una batería de 5,000 mAh que te permite aprovechar al máximo todas las opciones de entretenimiento a tu alcance. Esta batería de larga duración dura más tiempo sin necesidad de recargarla. Cuando necesites cargarlo, la carga rápida de 33 W con tecnología MMT garantiza que sea un proceso estable y eficiente."								}							]						}					]				},				{					"id": "DescripcionLargaDelProducto",					"type": "GROUPING",					"ocurrence": 4,					"children": [						{							"id": "TituloPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"value": "Captura grandes momentos con la impresionante cámara triple de 50MP"								}							]						},						{							"id": "DescripcionPrincipal",							"type": "STRING",							"children": [								{									"id": "es_ES",									"type": "STRING",									"ocurrence": 0,									"value": "Con una impresionante configuración de cámara triple de 50MP, Redmi Note 12 toma excelentes fotos en todos los escenarios y con todo tipo de luz. Aparte de la cámara principal, viene con una cámara ultra gran angular y una cámara macro, junto con una gran cantidad de funciones y filtros útiles. Con el Modo nocturno, nunca te perderás ese momento mágico en la oscuridad, y el modo Retrato permite que un sujeto se destaque sobre el fondo al producir una profundidad de campo natural. Haciéndose eco del diseño de la serie Redmi Note 12, Redmi Note 12 cuenta con un DotDisplay inmersivo con elegantes marcos planos, que emiten una apariencia y sensación premium a la vez que son lo suficientemente duraderos y cómodos para sostenerlo durante largos períodos de tiempo."								}							]						}					]				},				{					"id": "GestionComprasStock",					"type": "GROUPING",					"children": [						{							"id": "Calificacion1",							"type": "STRING",							"value": "C1"						},						{							"id": "Calificacion2",							"type": "STRING",							"value": "A"						},						{							"id": "Calificacion3",							"type": "STRING",							"value": "M5"						},						{							"id": "Calificacion4",							"type": "STRING",							"value": "VV"						},						{							"id": "Calificacion5",							"type": "STRING",							"value": "ES"						},						{							"id": "Calificacion6",							"type": "STRING",							"value": "WW"						},						{							"id": "TipoDeGestion",							"type": "STRING",							"value": "00"						}					]				},				{					"id": "DimensionesYPeso",					"type": "GROUPING",					"children": [						{							"id": "UOM!Dimensiones!Unidad",							"type": "LOOKUP_TABLE",							"value": "cm",							"featureGroupID": "204",							"id_Ext": "347186090"						},						{							"id": "UOM!PesoBruto!Unidad",							"type": "LOOKUP_TABLE",							"value": "g",							"featureGroupID": "206",							"id_Ext": "347187090"						},						{							"id": "UOM!VolumenContenidoNeto!VolumenContenidoNeto",							"type": "NUMBER",							"value": "0.0"						},						{							"id": "UOM!VolumenContenidoNeto!Unidad",							"type": "LOOKUP_TABLE",							"value": "ml",							"featureGroupID": "213",							"id_Ext": "347188090"						}