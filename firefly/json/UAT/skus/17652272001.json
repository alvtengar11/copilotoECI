										{
											"id": "es_ES",
											"type": "STRING",
											"ocurrence": 0,
											"value": "Con el Adaptador multipuerto de USB-C a VGA puedes conectar un monitor VGA a tu MacBook con USB-C, además de un accesorio USB estándar y un cable USB-C para cargar tu dispositivo."
										},
										{
											"id": "es_ES",
											"type": "STRING",
											"ocurrence": 1,
											"value": "El Adaptador multipuerto de USB-C a VGA te permite mostrar la pantalla de tu MacBook en un televisor o monitor con VGA hasta en 1080p HD. También te sirve para contenidos multimedia como películas y vídeos."
										},
										{
											"id": "es_ES",
											"type": "STRING",
											"ocurrence": 2,
											"value": "Simplemente conecta el adaptador al puerto USB-C del MacBook y luego a un televisor o a un proyector mediante un cable VGA (se vende por separado)."
										},
										{
											"id": "es_ES",
											"type": "STRING",
											"ocurrence": 3,
											"value": "Utiliza el puerto USB estándar para conectar dispositivos (como una memoria flash o una cámara) o un cable USB para sincronizar y cargar tu iPhone, iPad o iPod. También puedes conectar un cable al puerto USB-C para cargar tu MacBook."
										}
									]
								}
							]
						},
