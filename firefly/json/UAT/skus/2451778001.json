[],"specificAttribs":[{"id":"/Vinos_ISS","type":"SPEC","children":[{"id":"Tipo","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"100158","id_Ext":"2796329090","value":"Tostada"},{"id":"Subtipo","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"100147","id_Ext":"20693867090","value":"Ale"},{"id":"ClasificacionOficial","ocurrence":0,"type":"GROUPING","children":[{"id":"Provincia","type":"LOOKUP_TABLE","featureGroupID":"100164","id_Ext":"2848556090","value":"Cádiz"}]},{"id":"Origen","ocurrence":0,"type":"GROUPING","children":[{"id":"Continente","type":"LOOKUP_TABLE","featureGroupID":"100152","id_Ext":"2393883090","value":"Europa"},{"id":"Pais","type":"LOOKUP_TABLE","featureGroupID":"167","id_Ext":"351549090","value":"España"},{"id":"ZonaGeografica","type":"LOOKUP_TABLE","featureGroupID":"100153","id_Ext":"2449642090","value":"Andalucía"}]},{"id":"Bodega","type":"LOOKUP_TABLE","featureGroupID":"100145","id_Ext":"3239118090","value":"Cerveza Maier S.L."},{"id":"Presentacion","type":"GROUPING","children":[{"id":"Formato","type":"LOOKUP_TABLE","featureGroupID":"100156","id_Ext":"2330735090","value":"botella"}]},{"id":"Capacidad","type":"GROUPING","children":[{"id":"Cantidad","type":"NUMBER","value":"33.0"},{"id":"UnidadDeMedida","type":"LOOKUP_TABLE","featureGroupID":"213","id_Ext":"356840090","value":"cl"}]},{"id":"ConsejosDeServicio","type":"GROUPING","children":[{"id":"TemperaturaDeServicio","type":"GROUPING","children":[{"id":"Desde","type":"GROUPING","children":[{"id":"Desde","type":"NUMBER","value":"7.0"}]},{"id":"Hasta","type":"GROUPING","children":[{"id":"Hasta","type":"NUMBER","value":"10.0"},{"id":"UnidadDeMedida","type":"LOOKUP_TABLE","featureGroupID":"210","id_Ext":"349645090","value":"°C"}]}]},{"id":"ConsejosDeServicio","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"This unfiltered beer may contain sediment, so it is recommended to let the bottle stand in a vertical position for a couple of minutes before serving. Serve well-chilled in a clear glass to appreciate its amber colour."},{"id":"es_ES","type":"STRING","value":"Al no estar filtrada puede contener sedimentos por lo que antes de servirla es conveniente dejarla reposar un par de minutos verticalmente. Servir bien fría en un vaso o copa transparente para apreciar su color ámbar."},{"id":"fr_FR","type":"STRING","value":"N'étant pas filtrée, elle peut contenir des sédiments. Il convient donc de la laisser reposer quelques minutes à la verticale avant de la servir. Servir bien froide dans un verre transparent pour apprécier sa couleur ambrée."}]}]},{"id":"FichaTecnica","type":"GROUPING","children":[{"id":"Graduacion","type":"GROUPING","children":[{"id":"Graduacion","type":"NUMBER","value":"4.5"},{"id":"UnidadDeMedida","type":"STRING_ENUMERATION","value":"%Vol"}]}]},{"id":"Caracteristicas","ocurrence":0,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"Gastronomy:"},{"id":"es_ES","type":"STRING","value":"Gastronomía:"},{"id":"fr_FR","type":"STRING","value":"Gastronomie :"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"en_GB","ocurrence":0,"type":"STRING","value":"Ideal for enjoying after a delicious meal."},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Ideal para disfrutar después de una suculenta comida."},{"id":"fr_FR","ocurrence":0,"type":"STRING","value":"Idéale à déguster après un délicieux repas."}]}]},{"id":"Caracteristicas","ocurrence":1,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"Other information:"},{"id":"es_ES","type":"STRING","value":"Otros datos de interés:"},{"id":"fr_FR","type":"STRING","value":"Autres informations utiles :"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"en_GB","ocurrence":0,"type":"STRING","value":"Maier is the first 100% artisan beer from Cadiz. In the years after Napoleon's retreat and the renowned 1812 \"La Pepa\" constitution, the mid 19th century saw a period of economic and cultural splendour in Cadiz. Around that time Carlos Maier arrived in Cadiz from Bavaria and created the Gran Fábrica de Cervezas y Gaseosas Seltz y Aguas de Soda Carlos Maier (the Great Carlos Maier Beer, Lemonade and Soda Water Factory)."},{"id":"en_GB","ocurrence":1,"type":"STRING","value":"As homage to him and with the aim of continuing the brewing tradition he established, this frothy adventure has been named after him."},{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Maier es la primera cerveza artesana 100% producida en la ciudad de Cádiz. A mediados del siglo XIX, época de esplendor económico y cultural de la ciudad, y pocos años después de la retirada de Napoleón y de la famosa constitución de 1812 'La Pepa', llega a Cádiz un Bávaro llamado Carlos Maier para crear la Gran Fábrica de Cervezas y Gaseosas Seltz y Aguas de Soda Carlos Maier."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Es en su honor y con la intención de continuar con esa tradición cervecera, el motivo por el que tiene su nombre esta espumosa aventura."},{"id":"fr_FR","ocurrence":0,"type":"STRING","value":"Maier est la première bière artisanale produite intégralement dans la ville de Cadix. À la moitié du XIXe siècle, alors que la ville vit une époque d'essor économique et culturel, et seulement quelques années après le retrait de Napoléon et La Pepa, la fameuse constitution de 1812, un Bavarois du nom de Carlos Maier arrive à Cadix pour créer la Grande Usine de bières et limonades Seltz et de sodas Carlos Maier."},{"id":"fr_FR","ocurrence":1,"type":"STRING","value":"C'est en son honneur et afin de poursuivre cette tradition de la bière que cette aventure mousseuse porte son nom."}]}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"137632374"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"Fechas","type":"GROUPING","children":[{"id":"PublicadoWWW","type":"FLAG","value":"true"},{"id":"FechaDePublicacionWWW","type":"DATE","value":"20170818_000001"},{"id":"NovedadWWW","type":"FLAG","value":"false"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20131016_112812"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"233767090","value":"010"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"false"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"137632374"}]},{"id":"/UK_ISS","type":"SPEC","children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"MostrarSoloRebajado","type":"FLAG","value":"false"},{"id":"FechaDePublicacion","type":"DATE","value":"20170818_000001"},{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"233767090","value":"010"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20131016_112812"},{"id":"NovedadWWW","type":"FLAG","value":"false"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"137632374"}]}],"prices":[{"productId":"001013342000406   ","centerId":"0090","regularPrice":"2.25","catalogPrice":"2.25","taxPercentage":"02","igic":"90"},{"productId":"001013342000406   ","centerId":"0143","regularPrice":"2.65","catalogPrice":"2.65","taxPercentage":"02","igic":"90"},{"productId":"001013342000406   ","centerId":"0424","regularPrice":"2.25","catalogPrice":"2.25","taxPercentage":"02","igic":"90"},{"productId":"001013