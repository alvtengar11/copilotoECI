					"ocurrence": 0,
					"children": [
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "MELHOR DESEMPENHO DE SEMPRE:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "- As inovadoras tecnologias T-Turbo Power, T-LIN, T-40VE, T-M.C.E e T-DFB — inauguradas pelo antecessor do produto e exclusivas de GT Sport — são igualmente incluídas no T-GT II, permitindo aos pilotos continuarem a desfrutar das sensações únicas proporcionadas por estas funcionalidades."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "- Motor \"Brushless II\" da próxima geração: desempenho ainda mais rápido do motor, que lhe permite enfrentar eficazmente as partes mais difíceis das corridas (limites da pista de corrida, curvas, etc.)."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "- Cálculo integrado da curva de drifting, para um nível de responsividade que se mantém inalterado, seja qual for o jogo de corrida de automóveis que estiver a jogar."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "- Efeitos Force Feedback em tempo real, sem zonas mortas, para uma eficácia sem rival nas competições de corrida de automóveis."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "CONCEBIDO PARA GT SPORT:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "- O T-GT II fornece o acesso direto às incríveis funcionalidades em Gran Turismo Sport — à semelhança do seu antecessor, o T-GT."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 7,
									"value": "ROBUSTEZ E FIABILIDADE MELHORADAS:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 8,
									"value": "- Componentes eletrónicos dotados da qualificação da indústria automóvel \"AEC-Q\": uma garantia de qualidade adicional para jogadores exigentes, desde as longas sessões de treino até às competições mais intensas."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 9,
									"value": "- Novos fusíveis melhorados utilizados no mecanismo interno do T-GT II, para uma durabilidade e uma segurança sem precedentes."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 10,
									"value": "-Conjunto de pedais T3PA GT II, transformado numa novíssima configuração de \"competição\":"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 11,
									"value": "Nova mola de travão precisa e durável"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 12,
									"value": "Componentes certificados da indústria automóvel belga"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 13,
									"value": "Design \"T-GT II Edition\""
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 14,
									"value": "COMPATIBILIDADE:"
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 15,
									"value": "- Compatível com a PlayStation e PC (Windows 10)."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Volante + Pedales T-GT II compatible con PS4/PS5/PC."
								}
