									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Olvídate de los gastos de envío con nuestra Tarifa Plana. Enviamos GRATIS todos tus pedidos online durante 1 año, por solo 29 €."
								}
							]
						}
					]
				},
