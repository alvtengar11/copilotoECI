              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Proteína Bruta 25%, Aceites y Grasas Brutos 12%, Fibras Brutas 2,5%, Cenizas Brutas 9,5%, Ácidos Grasos Omega-3 (EPA+DHA) 0,9%, Humedad máxima: 9%."
