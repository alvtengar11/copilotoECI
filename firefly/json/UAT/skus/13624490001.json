:"Localidad","type":"LOOKUP_TABLE","featureGroupID":"100163","id_Ext":"3007242090","value":"San Pelayo de Guareña"},{"id":"Provincia","type":"LOOKUP_TABLE","featureGroupID":"100164","id_Ext":"2425642090","value":"Salamanca"}]},{"id":"Origen","ocurrence":0,"type":"GROUPING","children":[{"id":"Continente","type":"LOOKUP_TABLE","featureGroupID":"100152","id_Ext":"2393883090","value":"Europa"},{"id":"Pais","type":"LOOKUP_TABLE","featureGroupID":"167","id_Ext":"351549090","value":"España"},{"id":"ZonaGeografica","type":"LOOKUP_TABLE","featureGroupID":"100153","id_Ext":"2333900090","value":"Castilla y León"}]},{"id":"Capacidad","type":"GROUPING","children":[{"id":"Cantidad","type":"NUMBER","value":"200.0"},{"id":"UnidadDeMedida","type":"LOOKUP_TABLE","featureGroupID":"213","id_Ext":"353499090","value":"g"}]},{"id":"Premios","ocurrence":0,"type":"GROUPING","children":[{"id":"Premio","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"Super Gold Medal at the International Cheese Awards"},{"id":"es_ES","type":"STRING","value":"Medalla Super Gold en El International Cheese Awards."},{"id":"fr_FR","type":"STRING","value":"Médaille Super Gold à l'International Cheese Awards."}]}]},{"id":"FichaTecnica","type":"GROUPING","children":[{"id":"Elaboracion","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"Coagulation between 30º and 32ºC The curd is cut with a horizontal and vertical lyre to get the desired curd size. The curd is gently stirred and reheated. After resting for a period of time, the curd is pressed into its moulds. It is salted by immersing it in cold brine until it has the desired amount of saltiness. It ages in a heat- and temperature-controlled room. The finest artisan cheese for the best palates."},{"id":"fr_FR","type":"STRING","value":"Coagulation entre 30º et 32ºC. Le lait caillé est coupé avec un tranche-caillé vertical et horizontal jusqu'à obtenir le grain souhaité. La pâte est ensuite mélangée doucement et réchauffée. Après un certain repos, le lait caillé est introduit dans des moules adaptés. Le salage est réalisé par immersion dans de la saumure froide jusqu'à obtenir le niveau de sel souhaité. Maturation en chambre climatisée, à une température et humidité contrôlée. Le fromage artisanal le plus soigné pour les palais les plus fins."},{"id":"es_ES","type":"STRING","value":"Coagulación entre 30º y 32ºC. Se corta la cuajada con lira vertical y horizontal hasta conseguir el grano deseado. A continuacón se mezcla la masa suavemente y se recalienta. Después de un reposo determinado, se introduce la cuajada en moldes apropiados. El salado se realiza por inmersión ensalmuera fría hasta alcanzar el punto de sal deseado. Maduración en cámara acondicionada, con temperatura y humedad controlada. El queso artesano más mimado para los mejores paladares."}]},{"id":"Curacion","type":"GROUPING","children":[{"id":"ProcesoCuracion","type":"LOOKUP_TABLE","featureGroupID":"100149","id_Ext":"13624491090","value":"Maduración de 6 a 12 meses"}]}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"137629497"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20180221_000000"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"true"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20160916_172618"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"XPUBLICA","type":"STRING","value":"D"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"233767090","value":"010"},{"id":"ModSP2","type":"FLAG","value":"false"},{"id":"Foto","type":"FLAG","value":"false"}]},{"id":"RepositoryModificationControl","type":"F