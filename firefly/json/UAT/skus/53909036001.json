				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 0,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Altavoz portátil Vieta Pro Mini Thunder 2, Bluetooth, IPX6"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "El altavoz Mini Thunder 2 es un dispositivo muy versátil, equipado con características innovadoras como Bluetooth 5.3, resistencia al agua IPX6,  puerto USB, función True Wireless, sistema de luces y una gran autonomía de batería."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 1,
					"children": [
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "El Mini Thunder 2 está equipado con la última versión de Bluetooth, la 5.3, que te permite conectarte de manera inalámbrica a una variedad de dispositivos, como teléfonos móviles, tabletas y computadoras portátiles, para reproducir música y otros contenidos de forma rápida y sencilla."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Este altavoz cuenta con una clasificación de resistencia al agua IPX6, lo que significa que puede soportar chorros de agua potentes desde cualquier dirección. Esto lo hace ideal para su uso en exteriores o en entornos húmedos, como la playa o la piscina."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Con una potencia de salida de 100W, este altavoz es capaz de proporcionar un sonido potente y claro que puede llenar cualquier habitación o espacio exterior"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "El Mini Thunder 2 también tiene un puerto USB incorporado, lo que te permite reproducir música desde tu pendrive"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "La función TWS te permite emparejar dos altavoces Mini Thunder 2 juntos para crear un sonido estéreo verdadero y aumentar la potencia de sonido en un 100%."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Este altavoz cuenta con un sistema de luces integrado que le da un aspecto elegante y moderno. Puedes elegir entre una variedad de modos de iluminación."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Con una batería de iones de litio de alta capacidad, el Mini Thunder 2 puede proporcionar hasta 15 horas de reproducción continua con una sola carga."
								}
							]
						}
					]
				},
