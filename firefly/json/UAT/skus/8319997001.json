e":"true"},{"id":"EnvioAtg","type":"FLAG","value":"true"},{"id":"EansVariantes","type":"GROUPING","children":[{"id":"EanVariante","ocurrence":0,"type":"GROUPING","children":[{"id":"CodigoVariante","type":"RELATIONSHIP","groupID":"5005","id_Ext":"8162580059","value":"5030917162565"},{"id":"CodigoEan","type":"STRING","value":"5030917162565"},{"id":"FechaAltaEanCompras","type":"DATE","value":"20150408_000000"},{"id":"EsEanCompraPrincipal","type":"FLAG","value":"false"}]},{"id":"EanVariante","ocurrence":1,"type":"GROUPING","children":[{"id":"CodigoVariante","type":"RELATIONSHIP","groupID":"5005","id_Ext":"10083594059","value":"5030917181733"},{"id":"CodigoEan","type":"STRING","value":"5030917181733"},{"id":"FechaAltaEanCompras","type":"DATE","value":"20151002_000000"},{"id":"EsEanCompraPrincipal","type":"FLAG","value":"true"}]}]},{"id":"Impuestos","ocurrence":0,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0090"},{"id":"Impuesto","type":"STRING","value":"02"}]},{"id":"Impuestos","ocurrence":1,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0143"},{"id":"Impuesto","type":"STRING","value":"02"}]},{"id":"Impuestos","ocurrence":2,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0424"},{"id":"Impuesto","type":"STRING","value":"02"}]},{"id":"Impuestos","ocurrence":3,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0737"},{"id":"Impuesto","type":"STRING","value":"02"}]},{"id":"Impuestos","ocurrence":4,"type":"GROUPING","children":[{"id":"Centro","type":"STRING","value":"0909"},{"id":"Impuesto","type":"STRING","value":"01"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"94316821"}]}],"link":[{"id_Ext":"2019832013","hierarchyId":"999","categoryId":"1376323003"},{"id_Ext":"5391012","hierarchyId":"998","categoryId":"00072"},{"id_Ext":"1260760018","hierarchyId":"5001","categoryId":"01.975.785"},{"id_Ext":"3284461022","hierarchyId":"5004","categoryId":"1409933795"}],"unlink":[],"specificAttribs":[{"id":"\/Videojuegos_ISS","type":"SPEC","children":[{"id":"CaracteristicasGenerales","type":"GROUPING","children":[{"id":"CaracteristicasDelJuego","ocurrence":0,"type":"GROUPING","children":[{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Treyarch, el estudio desarrollador de dos de las entregas más jugadas en la historia de Call of Duty, regresa con Call of Duty: Black Ops III."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Por primera vez y tras tres años de desarrollo, el admirado y premiado estudio ha creado su primer título para la nueva generación, dentro de la serie alabada por la crítica, Black Ops."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Bienvenidos a Call of Duty: Black Ops III, un futuro oscuro y retorcido en el que nace una nueva raza de soldados Black Ops y en el que se difuminan las líneas entre nuestra propia humanidad y la tecnología que creamos para estar a la vanguardia, en un mundo en el que la robótica militar punta define la guerra."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Call of Duty: Black Ops III combina tres modos únicos de juego: Campaña, Multijugador y Zombies, proporcionando a los fans el Call of Duty más profundo y ambicioso creado hasta la fecha."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"La Campaña ha sido diseñada como un juego cooperativo que puede jugarse online con hasta cuatro jugadores o en solitario, como un trepidante viaje cinemático."},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"El Multijugador será el más profundo, satisfactorio y adictivo hasta la fecha, con nuevas formas para subir de rango, personalizarse y prepararse para la batalla."},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"Y el modo Zombies proporciona una nueva experiencia de infarto con su propia narrativa."},{"id":"es_ES","ocurrence":7,"type":"STRING","value":"Call of Duty: Black Ops III puede jugarse online al completo y, por primera vez, cada uno de sus modos ofrece su propia XP al jugador, así como su sistema de progresión."},{"id":"es_ES","ocurrence":8,"type":"STRING","value":"El juego da paso a un nivel de innovación sin precedentes que incluye escenarios impresionantes, armas y habilidades nunca vistas y la presentación de un nuevo y mejorado sistema de movimientos fluido."},{"id":"es_ES","ocurrence":9,"type":"STRING","value":"Todo esto cobra vida gracias a la tecnología avanzada diseñada a medida para este título, que incluye una nueva inteligencia artificial y un nuevo sistema de animación, así como gráficos que redefinen los estándares de lo que los fans de Call of Duty pueden esperar de la aclamada serie de juegos, con los sistemas de iluminación y los efectos visuales más avanzados."},{"id":"es_ES","ocurrence":10,"type":"STRING","value":"Call of Duty: Black Ops III es la última experiencia en juegos 3 en 1."}]}]},{"id":"CaracteristicasDelJuego","ocurrence":1,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Características:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Presentando una nueva era de Black Ops: Call of Duty: Black Ops III lleva a los jugadores a un futuro en el que la biotecnología ha permitido la creación de una nueva raza de soldados Black Ops. Ahora, los jugadores estarán siempre online y conectados a la red de inteligencia y a sus compañeros durante la batalla. En un mundo más dividido que nunca, este escuadrón de élite estará formado por hombres y mujeres que han mejorado sus habilidades de combate para luchar más rápido, más fuerte y de forma más inteligente. Cada soldado tiene que tomar decisiones difíciles y visitar las tinieblas en esta descarnada e interesante historia."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Una Campaña de Call of Duty diferente a todo lo anterior: Treyarch eleva la experiencia social de Call of Duty al presentar una campaña con la habilidad de jugar cooperativamente con hasta cuatro jugadores online. Todo esto usando la misma red de infraestructuras ya probadas en las batallas y los sistemas sociales que se emplean en sus modos Multijugador y Zombies. Diseñado para el modo cooperativo y para jugarse una y otra vez, los jugadores encontrarán los momentos épicos cinematográficos por los que es conocido Call of Duty, así como áreas abiertas de estilo arena creadas para permitir que los usuarios empleen una estrategia diferente cada vez que jueguen. Ahora, cada jugador es totalmente personalizable: desde armas y menús de recargas, a habilidades y trajes, pasando por sistemas de progresión completos y una armería personalizada para mostrar logros, lo que proporciona una experiencia de campaña en constante evolución."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Prepárate para un Multijugador de mayor nivel: con Black Ops III, Treyarch presenta un nuevo sistema de movimiento encadenado basado en la potencia, que permite a los jugadores moverse de forma fluida por todo el escenario con elegancia, mediante saltos propulsados, deslizamientos y desplegando sus habilidades con múltiples combinaciones. Todo esto mientras se mantiene el total control sobre el arma en todo momento. Los mapas se han creado desde cero para el nuevo sistema de movimiento, permitiendo que los jugadores tengan éxito con los movimientos tradicionales, además de con tácticas avanzadas y maniobras. El multijugador de Black Ops III también presenta el nuevo sistema de personajes Especialistas, que permite a los jugadores clasificar y dominar las capacidades curtidas en la batalla de cada personaje, además de sus armas. Con este añadido a los sistemas de progresión Tradicional y de Armas XP, el multijugador de Black Ops III ofrece tres formas diferentes de subir de rango."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Lucha contra los no muertos en una nueva historia de terror: ningún juego de Treyarch está completo sin su firma: los Zombies. Una experiencia de juego completa con su propia historia recién creada. Black Ops 2 Zombies es el Call of Duty más inmersivo y ambicioso hasta la fecha, con un sistema de progresión completo basado en XP para los jugadores. Este sistema añade profundidad y rejugabilidad al adictivo modo de juego que los fans de los Zombies esperan."}]}]},{"id":"Plataforma","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"462","id_Ext":"1319284090","value":"Playstation 4"},{"id":"Desarrolladores","type":"LOOKUP_TABLE","featureGroupID":"460","id_Ext":"390893090","value":"Treyarch"},{"id":"Distribuidores","type":"LOOKUP_TABLE","featureGroupID":"461","id_Ext":"372291090","value":"Activision Blizzard"},{"id":"Pegi","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"468","id_Ext":"351032090","value":"18+"},{"id":"Genero","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"464","id_Ext":"350502090","value":"Acción"},{"id":"Subgenero","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"470","id_Ext":"351034090","value":"Shooter 1ª persona"},{"id":"SoporteDigital","type":"LOOKUP_TABLE","featureGroupID":"147","id_Ext":"353223090","value":"Blu-ray"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"94316821"}]}],"stores":[{"id":"\/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20160516_000000"},{"id":"NovedadWWW","type":"FLAG","value":"true"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"FechaDeVigencia","type":"DATE","value":"20160617_105113"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20151106_000100"},{"id":"NoPublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","