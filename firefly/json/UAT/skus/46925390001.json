							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "A tecnologia Nike Dri-FIT elimina o suor da pele para manter a respirabilidade e o conforto."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Mejora tu estilo Swoosh con esta cómoda gorra Club sin estructura. La visera curva y el logotipo Swoosh metálico aportan un look impecable, al tiempo que la tecnología de capilarización del sudor mantiene la frescura y la comodidad para disfrutar del buen tiempo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Tecnología Nike Dri-FIT que capilariza el sudor de la piel para mantener la transpirabilidad y la comodidad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Tejido de sarga ligero y suave al tacto."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Diseño de profundidad media de seis paneles para un estilo sencillo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Cierre de deslizamiento triple metálico con el logotipo Swoosh para regular el ajuste con facilidad"
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Step your Swoosh game up with this comfy, unstructured Club Cap. Its curved bill and metal Swoosh logo give your look a clean finish while sweat-wicking tech helps you stay cool and comfortable while you make the most of warm, sunny weather."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Nike Dri-FIT technology moves sweat away from your skin for quicker evaporation, helping you stay dry and comfortable."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Twill fabric has a lightweight, smooth feel."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Mid-depth, 6-panel design makes for easy styling."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Swoosh branded metal tri-glide lets you adjust your fit with ease"
								}
