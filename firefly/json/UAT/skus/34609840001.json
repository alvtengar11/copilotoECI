              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "ocurrence": 0,
                  "value": "Capota extensível Fox para carrinho de passeio, em cinzento mesclado."
                },
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "ocurrence": 1,
                  "value": "Bugaboo Fox. O carrinho mais completo."
                },
                {
                  "id": "es_ES",
