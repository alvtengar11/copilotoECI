  "specificAttribs": [
    {
      "id": "/Perfumeria_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Jean Patou"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Nacido en 1880 en Normandía, Jean Patou era un diseñador impulsivo y extravagante instintivamente atraído por el mundo de la moda."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "En 1912 abrió su primera Casa de Costura, Corte y Confección y Pieles."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Jean Patou se hizo famoso por sus tejidos novedosos y por crear el primer traje de baño de punto."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Sus diseños a veces radicales y revolucionarios contribuyeron a la emancipación de la mujer. Él inventó el concepto de ropa deportiva camisetas Jean Patou fue el primero en crear la 'logomania', el logo impreso en la ropa."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "'1000'"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "El aroma de 1000 es inconfundible - un bouquet floral suntuoso fiel a la imagen de Jean Patou."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Lanzado en 1972, la riqueza y elegancia de 1000 deja una notable impresión."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Una sinfonía de esencias preciosas de flores y de los ingredientes más exquisitos."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 2,
          "type": "GROUPING",
