					"type": "GROUPING",
					"children": [
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Es el spray antiparásito esprés para perros y gatos, que actúa rápidamente en caso de infestación de pulgas, garrapatas y piojos chupadores."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Puede ser utilizado para el tratamiento de la DAPP ( Dermatitis alérgica por pulgas)."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Producto activo durante 2 meses frente a pulgas y 1 mes frente a garrapatas."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Tratamiento también para hembras gestantes y lactantes y cachorros desde los 2 días de edad."
								},
								{
									"id": "es_ES",
									"ocurrence": 4,
									"type": "STRING",
									"value": "Uso tópico, medianta pulverización."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLarga",
					"ocurrence": 1,
					"type": "GROUPING",
					"children": [
						{
							"id": "Titulo",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Indicaciones de uso:"
								}
							]
						},
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Tratamiento de infestaciones por pulgas, garrapatas, y piojos en perros y gatos."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Se puede aplicar en cachorros y gatitos con más de 2 días de edad, sin restricciones de peso."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Puede ser utilizado en hembras gestantes o en período de lactancia."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Está recomendado para dueños de mascotas que necesitan proteger a sus perros y gatos de infestaciones de pulgas, garrapatas y piojos ya presentes en el animal."
