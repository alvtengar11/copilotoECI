							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Conjunto Tripp Trapp Baby Set, que consiste num encosto alto e uma barra de segurança para fixar à cadeira alta Tripp Trapp."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Criado especificamente para que as crianças pequenas possam sentar-se de forma segura e cómoda à mesa e possam começar a imitar as destrezas motoras, verbais e sociais de quem as rodeia."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "*O novo Tripp Trapp Baby Set é compatível com todas as cadeiras produzidas a partir de Maio de 2003 com número de série a partir de 3, 4 ou 5 e todas as novas cadeiras exclusivas Tripp Trapp."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Tripp Trapp Baby Set, compuesto por respaldo alto y una barra de sujección para acoplar a la Trona Tripp Trapp."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Diseñado específicamente para que los niños pequeños puedan sentarse de un modo seguro y cómodo en la mesa y puedan comenzar a imitar las destrezas motoras, verbales y sociales de los que les rodean."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "* El nuevo Tripp Trapp BAby Set es compatible con todas las sillas producidas a partir de Mayo del 2003 con el número de serie comenzando por 3, 4 ó 5 y todas las nuevas Tripp Trapp exclusive."
								}
