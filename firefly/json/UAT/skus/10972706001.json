								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "A cadeira alta Tripp Trapp cresce com a criança, adapta-se ao seu crescimento e ajusta-se ao seu tamanho, ajustando a profundidade e altura do assento e do apoio para os pés. Isso proporciona conforto e uma posição ergonomicamente correta para crianças de qualquer idade."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Agora, graças ao Newborn Set, é possível fazer uso da Cadeira Tripp Trapp desde o nascimento."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Desde o nascimento, a Tripp Trapp oferece ao bebé a oportunidade de interagir, facilitando deste modo, mimos, a sua alimentação e a brincadeira, estreitando laços familiares."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "O assento e o repousa-pés são reguláveis em altura e profundidade, pelo bem-estar da criança, para proporcionar um assento à sua medida à medida que cresce."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "La Trona Tripp Trapp crece con el niño, se adapta a su crecimiento y se ajusta a su talla mediante su regulación en profundidad y en altura del asiento y reposa-pies. Esto proporciona confort y una posición ergonómicamente conectada para nios de cualquier edad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Ahora gracias al Newborn Set se puede hacer uso de la Silla Tripp Trapp desde el nacimiento."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Desde el nacimiento, la Tripp Trapp le ofrece a tu bebé la oportunidad de interactuar, facilitando de este modo mimos, su alimentación y el juego, estrechando lazos familiares."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Por el bienestar del niño se regulan el asiento y el reposapiés en altura y profundidad para proporcionarle un suelo y un asiento a su medida según va creciendo."
								}
							]
						}
					]
				},
