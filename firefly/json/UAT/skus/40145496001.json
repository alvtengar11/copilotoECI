				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 0,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Philips Hue - Centro de control Sistema Hue Hue Bridge, controla hasta 50 dispositivos, control por voz con Apple Home y Google Assistant"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "A Hue Bridge é o cérebro do sistema de iluminação inteligente Philips Hue, permitindo-lhe ligar e controlar até 50 luzes e acessórios. Basta ligá-la e utilizar a aplicação Hue para configurar rotinas, temporizadores, cenas de iluminação personalizadas e muito mais."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Controle completo das funções de iluminação inteligente: O Hue Bridge dá-lhe todo o poder da Philips Hue, incluindo automações, controlo inteligente a partir de qualquer parte do mundo e muito mais."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Controle as luzes em qualquer lugar: O Hue Bridge permite o controlo fora de casa, para que possa controlar as suas luzes com a aplicação Hue a partir de qualquer lugar com uma ligação à Internet ou móvel."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Controlo no interior e no exterior: Com uma Hue Bridge, pode adicionar até 50 luzes e acessórios ao seu sistema de iluminação inteligente, tanto no interior como no exterior."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Adicione até 50 luzes e acessórios:Expanda o seu sistema de iluminação inteligente! O Hue Bridge permite-lhe adicionar até 50 luzes inteligentes em toda a sua casa, juntamente com interruptores e sensores inteligentes."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Ambiente dinâmico: Faça com que as suas luzes dancem, cintilem, diminuam e brilhem ao ritmo dos seus filmes, programas de televisão, jogos para PC ou consola e música preferidos."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Funciona com Matter: A ponte Hue permite-lhe ligar as suas luzes e acessórios a outros dispositivos domésticos inteligentes com Matter."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "El Hue Bridge es el cerebro del sistema de iluminación inteligente Philips Hue, te permite conectar y controlar hasta 50 luces y accesorios. Basta enchufarlo y utilizar la app Hue para configurar rutinas, temporizadores, escenas de luz personalizadas, etc."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "OBTÉN EL CONTROL TOTAL DE LAS FUNCIONES DE ILUMINACIÓN INTELIGENTE: Hue Bridge te ofrece toda la potencia de Philips Hue, incluidas las automatizaciones, el control inteligente desde cualquier lugar del mundo y mucho más"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "CONTROLA LAS LUCES DESDE CUALQUIER LUGAR: El Hue Bridge permite el control Fuera de casa, para que puedas controlar tus luces con la aplicación Hue desde cualquier lugar con conexión a Internet o móvil."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "CONTROL INTERIOR Y EXTERIOR: Con un Hue Bridge, puedes añadir hasta 50 luces y accesorios a tu sistema de iluminación inteligente tanto dentro como fuera de casa"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "ENTORNO DINÁMICO: Haz que tus luces bailen, parpadeen, se atenúen y se iluminen al ritmo de tus películas, programas de TV, juegos de PC o consola y música favoritos."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "AÑADE HASTA 50 LUCES Y ACCESORIOS ¡Amplía tu sistema de iluminación inteligente! El Hue Bridge te permite añadir hasta 50 luces inteligentes en toda tu casa, junto con interruptores y sensores inteligentes."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "FUNCIONA CON MATTER: El Puente Hue te permite conectar tus luces y accesorios a otros dispositivos inteligentes para el hogar con Matter."
								}
							]
						}
					]
