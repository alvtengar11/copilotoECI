							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Estante feita inteiramente de madeira de olmo reciclada, um material muito resistente que torna a peça de mobiliário robusta. Inclui cinco prateleiras com grande capacidade de arrumação e cruzes decorativas nas laterais."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Além disso, conferirá um carácter exclusivo a qualquer espaço, uma vez que foi fabricado à mão e cada peça é única."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "A série Mimosa oferece-lhe um mobiliário contemporâneo de alta qualidade e resistência com um design acolhedor, perfeito para criar uma atmosfera caseira."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Estantería completamente hecha en madera de olmo reciclado, un material muy resistente que aporta robustez al mueble. Incluye cinco estantes con gran capacidad de ordenación y crucetas decorativas en los laterales."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Además, aportará un carácter exclusivo a cualquier espacio, ya que ha sido elaborada de manera artesanal y cada pieza es única."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "La serie Mimosa te ofrece muebles contemporáneos de gran calidad y resistencia con un diseño cálido, perfectos para crear un ambiente hogareño."
								}
							]
