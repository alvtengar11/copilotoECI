					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Microsoft Surface Laptop 13\" Copilot+PC, Snapdragon X Plus X1P-42-100, 16GB, 256GB, W11"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Ultraligero, diseñado para el rendimento. Diseñado por Microsoft, Surface Laptop es un Copilot+ PC completamente nuevo y el Surface Laptop más portátil."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "El Copilot+ PC Surface Laptop más portátil, ultraportátil y ligero. El Surface Laptop se ha diseñado para moverse contigo, sin importar a dónde te lleve el trabajo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Pantalla táctil brillante PixelSense de 13 pulgadas. El Surface Laptop se ha creado para convertirse en un dispositivo increíble para la reproducción de tus películas, series y música favoritas."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Ultraportátil y ultraligero, con un peso de 1,1 kg, Surface Laptop está diseñado para llevarlo donde quieras."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Escribe a la perfección. Preciso, rápido y cómodo con panel táctil de gran precisión que mejora la productividad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Los puertos que necesitas. Carga en cualquier lugar, transfiere datos rápidamente o crea la configuración de escritorio definitiva con dos puertos USB-C 3.2. El cargador se vende por separado."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Productividad y eficiencia, redefinidas. Fabricado con los últimos procesadores Qualcomm Snapdragon X Plus (8 núcleos), Surface Laptop ofrece un rendimiento impresionante y cuenta con una NPU de hasta 45 TOPS, diseñada para acelerar las experiencias de IA."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 7,
									"value": "Procesadores Snapdragon X plus (8 núcleos). Potente rendimiento para el uso diario, navegación web, reproducción de vídeo y productividad diaria con aplicaciones Microsoft 365."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 8,
									"value": "NPU Qualcomm Hexagon con 45 TOPS. Con la capacidad de procesar 45 billones de operaciones por segundo, la potente NPU te permite acceder a la experiencia de IA integrada y mejorar tu productividad y creatividad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 9,
									"value": "Da rienda suelta a tu nuevo superpoder. Mejora tu productividad y creatividad con las experiencias exclusivas de Copilot+ PC."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 10,
									"value": "Tu compañero de IA. Aumenta la productividad y la eficiencia de tu día a día, da rienda suelta a tu creatividad y comunícate con la máxima claridad con Copilot. No importa la tarea, Copilot siempre está preparado para ayudarte."
								}
							]
						}
					]
