						},
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Fabricado especialmente para entornos en línea multijugador del sistema PlayStation 4, el auricular estéreo Kama de Tritton ofrece una experiencia de audio cómoda y simplifica el chat en línea. Se conecta directamente al controlador sin cables DualshocK 4, así como a casi cualquier dispositivo con un conector jack de 3,5 mm. para ofrecerte total libertad para jugar en estéreo sea cual sea el lugar donde te lleve el juego."
								}
							]
						}
					]
				},
				{
					"id": "CaracteristicasAdicionales",
					"ocurrence": 1,
					"type": "GROUPING",
					"children": [
						{
							"id": "TitularDeLaDescripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Conectividad Plug-and-Play intuitiva:"
								}
							]
						},
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "La preparación de Kama para el chat de voz es muy sencilla. Basta con enchufar el cable de 3,5 mm en el controlador sin cables de PS4 y se realiza el proceso de conexión."
								}
							]
						}
					]
				},
				{
