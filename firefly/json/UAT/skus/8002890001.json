  "specificAttribs": [
    {
      "id": "/Videojuegos_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "CaracteristicasGenerales",
          "type": "GROUPING",
          "children": [
            {
              "id": "CaracteristicasDelJuego",
              "ocurrence": 0,
              "type": "GROUPING",
              "children": [
                {
                  "id": "CaracteristicasDelJuego",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "ocurrence": 0,
                      "type": "STRING",
                      "value": "Siguiendo de las historias épicas de Parque Jurásico, El Mundo Perdido: Parque Jurásico y Parque Jurásico III, así como la esperado Jurassic World, Lego Jurassic World es el primer videojuego en el que los jugadores podrán revivir y experimentar las cuatro películas jurásicas."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 1,
                      "type": "STRING",
                      "value": "Reimaginado en forma de Lego y contado con el sentido del humor característico de los juegos de TT Games, esta emocionante aventura recreará escenas inolvidables y secuencias de acción de las películas, permitiendo a los seguidores jugar a través de momentos clave y tener la oportunidad de explorar las tierras de Isla Nublar e Isla Sorna."
                    }
                  ]
                }
              ]
            },
            {
              "id": "CaracteristicasDelJuego",
              "ocurrence": 1,
              "type": "GROUPING",
              "children": [
                {
                  "id": "Titular",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "type": "STRING",
                      "value": "Características:"
                    }
                  ]
                },
                {
                  "id": "CaracteristicasDelJuego",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "ocurrence": 0,
                      "type": "STRING",
                      "value": "Revive momentos clave de las cuatro películas de Jurassic: una aventura de 65 millones años de trabajo, ahora en forma de Lego."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 1,
                      "type": "STRING",
                      "value": "Siembra el caos con dinosaurios Lego: elije entre 20 dinosaurios, incluyendo el amable Triceratops, el letal Raptor, el salvaje Compy e incluso el poderoso T. rex."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 2,
                      "type": "STRING",
                      "value": "Personaliza tu propia colección de dinosaurios: colecciona ámbar Lego y experimenta con ADN para crear originales dinosaurios, como el Dilophosaurus Rex."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 3,
                      "type": "STRING",
                      "value": "Rellenar y explora la Isla Nubla y la Isla Sorna: pon tus creaciones únicas de dinosaurios en los prados y completa las misiones especiales Free Play."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 4,
                      "type": "STRING",
                      "value": "Juega con tu familia y amigos con fácil acceso y salida de jugadores (drop in, drop-out) en cualquier momento del juego (disponible solo para Consolas)."
                    }
                  ]
                }
              ]
            },
            {
