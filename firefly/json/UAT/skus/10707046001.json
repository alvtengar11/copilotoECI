  "specificAttribs": [
    {
      "id": "/Decoracion_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "en_GB",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Filtrate broom designed to trap dust and dirt indoors and outdoors. Perfect for cleaning carpets, tiles or windows both dry and wet."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Filaments de balai conçus pour retenir la poussière et à l'intérieur de la saleté et à l'extérieur. Parfait pour le nettoyage des tapis, des tuiles ou des fenêtres à la fois sèches et humides."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Escoba de filamentos diseñada para atrapar el polvo y la suciedad en interiores y exteriores. Perfecto para limpiar alfombras, azulejos o ventanas tanto  en seco como en húmedo."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "en_GB",
                  "type": "STRING",
                  "value": "Characteristics"
                },
                {
                  "id": "fr_FR",
                  "type": "STRING",
                  "value": "Des caractéristiques"
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Características"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "en_GB",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Designed with 700 rubber filaments."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "It has the same technology used by industrial cleaning machines."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Rubber bristles create an electrostatic charge that attracts pet hair, lint and other debris."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Ideal for all types of surfaces, including carpets, tiles, windows, clothing, furniture and curtains."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "It is ideal for both indoor and outdoor use."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 5,
                  "type": "STRING",
                  "value": "Rinse with mild soap."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 6,
                  "type": "STRING",
                  "value": "The telescopic bar makes any work easy, allows you to reach the highest areas and adapt it to the height of each person."
                },
