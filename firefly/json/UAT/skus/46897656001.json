              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "TV OLED 195 cm (77'') LG OLED77G26LA Evo Gallery Edition 4K SmartTV WebOS 22, HDR Dolby Vision, HDR10, Dolby Atmos"
                }
