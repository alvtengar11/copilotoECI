							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "La combinación de piel, tela y malla da como resultado unas zapatillas duraderas, transpirables y cómodas para todo el día."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Diseñada originalmente para el running, la unidad Max Air ofrece una amortiguación reactiva en cada pisada."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "La mediasuela de espuma mejora la amortiguación para que dure más tiempo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "La suela exterior de goma proporciona tracción y durabilidad."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Leather, textile and mesh combine for a durable construction that's breathable and comfortable to wear all day."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Originally designed for performance running, the Max Air unit delivers lightweight cushioning with every step."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 2,
									"value": "The foam midsole adds cushioning to last."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 3,
									"value": "The rubber outsole provides traction and durability."
								}
							]
