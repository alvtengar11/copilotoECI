							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Ligação direta Bluetooth (BTOOTB): Ligue e reproduza instantaneamente com qualquer dispositivo Bluetooth, sem necessidade de configuração."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Botões de alimentação e Bluetooth etiquetados: melhor usabilidade com controlos tácteis e etiquetados para um funcionamento intuitivo."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Cabo USB-C para USB-C: design à prova de futuro e fiabilidade para um carregamento rápido e seguro do dispositivo."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Cores e logótipo atualizados: Acabamentos modernos em tons subtis para um aspeto mais elegante e contemporâneo."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Até 10 horas de autonomia da bateria: desfrute de longas sessões de música com um único carregamento."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "À prova de água IP67: À prova de água e de poeiras, ideal para utilização no exterior em todas as condições climatéricas."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Conexión Bluetooth directa (BTOOTB): Conecta y reproduce instantáneamente con cualquier dispositivo Bluetooth, sin necesidad de configuración previa."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Botones de encendido y Bluetooth etiquetados: Mejora la usabilidad con controles táctiles y etiquetados para un manejo intuitivo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Cable USB-C a USB-C: Diseño y fiabilidad a prueba de futuro para cargar el dispositivo de manera rápida y segura"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Colores y Logo actualizados: Acabados modernos en tonos sutiles para un aspecto más elegante y contemporáneo"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Hasta 10 horas de duración de batería: Disfruta de largas sesiones de música con una sola carga"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Resistencia al Agua IP67: Impermeable y resistente al polvo, ideal para usar en exteriores bajo cualquier condición climática"
