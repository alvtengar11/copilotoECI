								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Máxima recuperación y desempeño"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Fast Recovery Drink GoldNutrition® está compuesta por proteínas de alto valor biológico y de rápida absorción, aminoácidos de cadena ramificada (BCAA) y una dosis eficaz de carbohidratos de alto índice glucémico (rápida absorción), y prácticamente libre de grasas. Además de esto contiene un conjunto de vitaminas y minerales que favorecen los procesos metabólicos relacionados con la absorción y metabolización de los carbohidratos aumentando en simultaneo el potencial antioxidante y de recuperación de la fórmula."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Favorece la síntesis de masa muscular"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Ayuda a maximizar la recuperación"
								},
