								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Lavadora  de carga superior H-WASH 300 LITE de 7 Kg y velocidad de centrifugado hasta 1200 rpm."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Ahorra tiempo y reduce el consumo: con funciones tan prácticas como el Detector de Kgs, 9 ciclos de lavado de menos de 59', Inicio Diferido y mucho más."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Función KG Mode: Pesa la ropa en los primeros 4 minutos del programa, adaptando el agua, el consumo energético y el tiempo del ciclo con precisión científica."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Tecnología Power Care System: Tecnología que crea un mix perfecto de agua y detergente y que lo inyecta directamente en el interior del tambor para que pueda penetrar en las fibras, garantizando una acción de lavado un 20% superior."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Sistema de apertura de puertas gradual Gentle Touch Opening."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Tecnología NFC que permite añadir funcionalidades a la lavadora a través del Smartphone."
								}
							]
