									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Réplica na escala 8:10 da Ferrari 488 GTB, com licença oficial da Ferrari e PlayStation 4, para o realismo total em todos os jogos de corridas do PlayStation 4 que suportam rodas."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
