								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Controles completos: 11 botões de ação + D-pad multidirecional para navegar pelos menus."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 7,
									"value": "2 grandes alavancas de rodas sequenciais montadas na roda e metal (2,7 \"/ 7 cm de altura): 2 alavancas de mudança digitais para cima e para baixo permitem que mude a velocidade rapidamente."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Réplica a escala 8:10 del Ferrari 488GTB, con licencia oficial de Ferrari y PlayStation 4, para el realismo total en todos los juegos de carreras de PlayStation 4 que soportan ruedas."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Botones oficiales para PlayStation4 (PS, SHARE y OPTIONS) para una fácil navegación dentro de la interfaz de PlayStation4 y en los menús de los juegos de PlayStation 4."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Rueda de diseño ergonómico, perfecta para todo tipo de juegos de carreras en PlayStation 4 (GT, F1, Stock car, Rally, Arcade, etc.)"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Chip de certificación incrustado en el T80 Racing Wheel que permite el reconocimiento de PS4."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
