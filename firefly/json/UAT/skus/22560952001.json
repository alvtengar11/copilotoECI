								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Roda de design ergonómico, perfeita para todos os tipos de jogos de corridas na PlayStation 4 (GT, F1, stock car, rali, arcada, etc.)"
								},
								{
									"id": "pt_PT",
