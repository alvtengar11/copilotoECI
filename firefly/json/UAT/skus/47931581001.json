					"ocurrence": 0,
					"children": [
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Construção vulcanizada que liga a sola à parte superior para proporcionar flexibilidade e conforto."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Las Nike Blazer Mid '77 ofrecen un diseño atemporal y muy cómodo. La parte superior de piel elegante combina a la perfección con un logotipo retro y una actualización tricolor. El logotipo combinado y los cordones multicolores completan el look."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Confección duradera, diseñada originalmente para el baloncesto, con costuras resistentes y un sistema de cordones muy práctico, sinónimo de comodidad duradera."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Zona del tobillo de perfil medio y acolchada para ofrecer un look elegante muy cómodo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Confección vulcanizada que une la suela con la parte superior para ofrecer flexibilidad y comodidad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Suela exterior de goma maciza con patrón de diseño de espiga que aporta tracción, durabilidad y un estilo tradicional."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 0,
									"value": "The Nike Blazer Mid '77 delivers a timeless design that's easy to wear. Its crisp leather upper breaks in beautifully and pairs with retro branding and a tricolor refresh. A combination logo and multicolored laces complete the look."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Originally designed for performance hoops, the durable construction, tough stitching and easy-entry lacing delivers comfort that lasts."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Padded, mid-cut collar looks sleek and feels great."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Vulcanized construction fuses the sole to the upper for a flexible, broken-in feel."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Solid rubber outsole with herringbone pattern adds traction, durability and heritage styling."
								}
							]
						}
					]
