  "specificAttribs": [
    {
      "id": "/Decoracion_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Clean Cat nos ofrece la solución higiénica más completa del mercado a base de gránulos de sílice."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Eficacia:"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "La revolucionaria tecnología Odor Free absorbe el líquido de la orina y retiene sus olores, atrapándolo dentro de sus partículas y finalmente los regenera evaporando sus líquidos."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Además de ser anti-olores es anti-bacterias, anti-humedad y tine una larga duración (entre 20 y 30 días)."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 2,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Modo de empleo:"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Clean Cat, actúa en 3 pasos, proporcionando resultados insuperables para las arenas tradicionales y todo ello en sólo 30 min."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Vierta apróximadamente 3 cm de arena de silice en la bandeja de su gato (lo que equivale al envase práctico)."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Distribuya homogéneamente el producto y deje actuar."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 3,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
