                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "1,8 Kg. Práctico. Envase de 1 uso. Ligero y fácil de transportar."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
