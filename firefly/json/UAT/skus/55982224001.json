					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 1,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Champagne Lallier Rosé 2020."
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Champagne Lallier Rosé 2020. Un champagne que expresa con su propio carácter: Color tosa claro, fresco y vigorizante. La fruta domina la fragancia, con notas de cerezas frescas, grosellas rojas y frambuesas, combinadas con delicados toques de manzana fresca y mandarina. Se marca el paso con frutas rojas y notas florales. Expresa plenamente su personalidad cuando es disfrutado por sí solo. Puede disfrutar maridado con pescado crudo o mariscos, como la langosta o el cangrejo real. Marida muy bien tiernos y cremosos."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 2,
					"children": [
						{
							"id": "TituloPrincipal",
