							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Instrucciones:"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Consuma el gel minutos antes, durante y / o inmediatamente después de la actividad."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 2,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Cantidad de energía:"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Los estudios han demostrado que nuestros cuerpos pueden utilizar hasta 90 gramos de carbohidratos por hora. Recientemente se ha demostrado científicamente que la proporción de glucosa y fructosa de 0.8: 1 permite una absorción aún mayor: hasta 100 gramos por hora. El GEL 100 ha sido desarrollado utilizando esta relación, por lo que otorga mucha energía. Una porción contiene 25 gramos de carbohidratos."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
