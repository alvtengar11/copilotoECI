              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Collar realizado con perlas cultivadas en el mar de Japón (conocidas como Akoya) de 8-8,5 mm de diámetro."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Se caracteriza por que el tamaño de las perlas centrales del collar miden 8,5 mm y las de los extremos 8 mm. su longitudtotal es de 46 cm aproximadamente."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Consta de un cierre de oro blanco de 750 ml de 3 grs. con un diseño de bandas transversales en el cuerpo y en las casquillas, cuyo mecanismo está dotado de lengüeta."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "El cierre tiene engastados 6 diamantes de talla brillante de pureza S12 ycolor G, cuyo peso total es de 0.03 cts."
