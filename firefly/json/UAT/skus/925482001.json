e":"LOOKUP_TABLE","featureGroupID":"420","id_Ext":"9651455090","value":"Tapa blanda"}]},{"id":"Dimensiones","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Alto","type":"NUMBER","value":"21.0"},{"id":"UOM!Dimensiones!Ancho","type":"NUMBER","value":"13.0"}]},{"id":"NumPaginas","type":"NUMBER","value":"176.0"},{"id":"Idioma","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"157","id_Ext":"347494090","value":"Catalán"},{"id":"Descripcion","ocurrence":0,"type":"GROUPING","children":[{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Els Premis Literaris Baix Camp per a Joves Escriptors, que convoca Òmnium Baix Camp, i els Premis APELLC joves, que convoca l'Associació de Professionals i Estudiosos en Llengua i Literatura Catalanes representen una mostra significativa de la creació literària de molts joves del Països Catalans. El present volum aplega els XXXI, XXXII i XXXIII Premis Antoni Bofarull de narrativa breu d'Òmnium Baix Camp dels anys 2009, 2010 i 2011 i el V Premi, de l'any 2011, Joves.Lit que concedeix L'APELLC. El títol <i>Ventalls prisats</i> vol expressar la varietat d'estils i de personalitats literàries que recull la present publicació i aplega el conjunt d'obres premiades en ambdós certàmens literaris. El pròleg de l'edició és a càrrec de Lurdes Malgrat, escriptora. Atès que el jurat de la XXXI edició va acordar declarar no adjudicat el XXXI Premi Antoni Bofarull, no se'n publica cap text. El jurat de la XXXII edició va acordar d'atorgar el XXXII Premi Antoni Bofarull a l'obra <i>Perdut a la cambra fosca</i> de David Moragas Llevat i un accèssit a Joan Cané i Rúbies, per <i>La península picant</i>. El jurat de la XXXIII edició va acordar d'atorgar el XXXIII Premi Antoni Bofarull a l'obra <i>Terres Blanques</i> de Bàrbara Molas. El jurat del V Premi APELLC joves va acordar d'atorgar el primer premi a l'obra <i>Doble abisme</i>, de Marta Ginebra Domingo, en la categoria de 14 a 17 anys. En la categoria de 18 a 21 anys, va atorgar un accèssit al relat <i>Reminiscències</i>, d'Anna Andevert Llurba i el primer premi a Raquel Galofré Bofarull, amb l'obra <i>Escampar la boira</i>. Amb l'edició d'aquesta publicació, les dues entitats, Òmnium Baix Camp i APELLC volen fer costat els joves autors que escriuen en la nostra llengua tot volent donar a conèixer la varietat i la qualitat de les seves creacions literàries."}]}]},{"id":"CodigoSituacion","type":"STRING","value":"FV"}]},{"id":"NombreAutor","type":"STRING","value":"_DIVERSOS_"},{"id":"Autor","ocurrence":0,"type":"GROUPING","children":[{"id":"CodigoAutor","type":"RELATIONSHIP","groupID":"2002","id_Ext":"400346051","value":"0061211"}]},{"id":"Estilos","type":"GROUPING","children":[{"id":"Estilo1","type":"STRING","value":"001"},{"id":"Estilo2","type":"STRING","value":"001"},{"id":"Estilo3","type":"STRING","value":"000"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"132226614"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20180101_000001"},{"id":"PublicarAutomaticamente","type":"FLAG","value":"false"},{"id":"FechaDePrimeraPublicacionWWW","type":"DATE","value":"20121015_000000"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"132226614"}]},{"id":"/Carteleria_ISS","type":"SPEC","children":[]}],"prices":[{"productId":"001006500105132   ","centerId":"0090","regularPrice":"12.255","catalogPrice":"12.90","taxPercentage":"08","igic":"90"},{"productId":"001006500105132   ","centerId":"0143","regularPrice":"12.90","catalogPrice":"12.90","taxPercentage":"08","igic":"90"},{"productId":"001006500105132   ","centerId":"0424","regularPrice":"12.90","catalogPrice":"12.90","taxPercentage":"08","igic":"90"},{"productId":"001006500105132   ","centerId":"0737","regularPrice