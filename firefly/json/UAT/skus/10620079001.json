	"specificAttribs": [
		{
			"id": "/Portabebes_ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "DescripcionLarga",
					"ocurrence": 0,
					"type": "GROUPING",
					"children": [
						{
							"id": "Descripcion",
							"ocurrence": 0,
							"type": "STRING",
							"value": "Silla de Auto Línea Silver Pallas Gray Rabbit para Grupo 1/2/3, en gris oscuro."
						},
						{
							"id": "Descripcion",
							"ocurrence": 1,
							"type": "STRING",
							"value": "Como Grupo 1 con Cojín de seguridad, la Cybex Pallas ha recibido de Autobild la mejor puntuación 'very good'. Consta de un innovador Cojín de seguridad, sistema parecido a un airbag hinchado, que distribuye las fuerzas del impacto por su superficie y las neutraliza gracias a sus materiales diseñados para absorber la energía del golpe."
						},
						{
							"id": "Descripcion",
							"ocurrence": 2,
							"type": "STRING",
							"value": "Cuando el niño cumple los 3 años de edad aproximadamente la silla se convierte en la ganadora del Grupo 2/3: la Solution X."
						},
						{
							"id": "Descripcion",
							"ocurrence": 3,
							"type": "STRING",
							"value": "La Cybex Pallas se utiliza durante más de 11 años."
						},
						{
							"id": "Descripcion_New",
							"type": "STRING",
