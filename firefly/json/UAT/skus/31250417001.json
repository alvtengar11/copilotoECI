              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 0,
                  "value": "La tarjeta regalo Gracias de El Corte Inglés es el regalo perfecto porque en ella caben todos los regalos que puedas imaginar."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 1,
                  "value": "Te permite elegir el valor a regalar entre 10€ y 500€."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 2,
                  "value": "No tiene caducidad, se puede utilizar tantas veces como quiera hasta agotar el saldo."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 3,
                  "value": "Es válida en cualquier centro comercial de El Corte Inglés, Hipercor, Supercor, Sfera, Bricor, La Tienda en Casa, www.elcorteingles.es* y Viajes El Corte Inglés."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 4,
                  "value": "* Excepto en colchones, muebles (a medida o personalizados), aire acondicionado, flores y regalos y supermercado."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 5,
                  "value": "Envío a domicilio en Península y Baleares."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 6,
                  "value": "Observaciones: este producto es personalizado y no admite anulación, cambio o devolución."
