							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Gel energético Isotónico con ciclodextrina, aromas naturales y stevia."
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Gel energético Isotónico con ciclodextrina, aromas naturales y edulcorante natural stevia."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Isotonic Gel cuenta con el sello Cologne List, es la primera y más grande plataforma de prevención de dopaje para suplementos nutricionales en el mundo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Cologne List solo incluye productos que se han sometido a pruebas rigurosas para verificar mediante analíticas y la verificación de los etiquetados, que los fabricantes no utilizan en sus productos sustancias prohibidas incluidas en la lista de la WADA (World Anti-Doping Agency)."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "El isotonic gel es un gel isotónico en el que la fuente principal de hidratos de carbono es la ciclodextrina, un carbohidrato de última generación que mejora la reposición de glucógeno de manera más eficiente."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Ofrece una liberación de energía prolongada, perfecta durante y después del ejercicio."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Un menor pico de insulina, favoreciendo el uso de glucosa a nivel celular en un tiempo más corto y manteniendo el nivel de azúcar sanguíneo durante más tiempo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Rápido vaciado gástrico por su gran peso molecular y su baja osmolaridad, favoreciendo la digestión y reduciendo los efectos secundarios gastrointestinales."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 7,
									"value": "No inhibe la combustión de grasa."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 8,
									"value": "Su característica principal es que no necesita agua al tomarlo ya que el propio gel contiene la cantidad necesaria para consumirlo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 9,
									"value": "En formato stick de 68 g y con 89 kcal, contiene 22 g de carbohidratos por gel de los cuales prácticamente su totalidad son hidratos complejos y solo 1,4 g de azúcar."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 10,
									"value": "Lima: fórmula sin cafeína."
								}
							]
						}
