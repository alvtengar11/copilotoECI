						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "O disco de armazenamento portátil WD Elements SE com USB 3.0 oferece armazenamento confiável e de alta capacidade, conectividade universal e rápidas velocidades de transferência de dados. Este disco rígido portátil inclui o software WD Discovery para gerenciamento de disco."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Se o disco rígido interno estiver quase cheio, o computador poderá ficar lento. Não exclua arquivos. Liberte espaço em seu disco rígido interno transferindo arquivos para seu disco de armazenamento portátil WD Elements SE e aproveite seu laptop novamente."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "O design leve e pequeno do disco de armazenamento portátil WD Elements SE torna-o um companheiro de notebook ideal para que você possa levar seus arquivos aonde quer que vá."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "El disco de almacenamiento portátil WD Elements SE con USB 3.0 ofrece almacenamiento fiable y de gran capacidad para llevar, conectividad universal y velocidades rápidas de transferencia de datos. Este disco duro portátil incluye el software WD Discovery para la gestión de los discos."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Si el disco duro interno está casi lleno, el ordenador se puede ralentizar. No borre archivos. Libere espacio en el disco duro interno transfiriendo archivos a su disco de almacenamiento portátil WD Elements SE y vuelva a disfrutar de su ordenador portátil."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "El diseño pequeño y ligero del disco de almacenamiento portátil WD Elements SE hace que sea un compañero portátil ideal para que pueda llevar sus archivos donde vaya."
								}
							]
						}
