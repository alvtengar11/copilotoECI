            {
              "id": "TituloPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Los usuarios de la Llave Espada podrán revivir las mágicas aventuras de Sora, el Pato Donald, Goofy y sus amigos mientras intentan detener la invasión de los Sincorazón que amenaza su universo"
                }
              ]
            },
            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Los fans viajarán a emblemáticos mundos de Disney y unirán sus fuerzas a las de queridos personajes de Disney y FINAL FANTASY para luchar contra la amenaza de la oscuridad y devolver la luz a todos los mundos."
                }
              ]
            }
          ]
