	"specificAttribs": [
		{
			"id": "/Videojuegos_ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "CaracteristicasGenerales",
					"type": "GROUPING",
					"children": [
						{
							"id": "CaracteristicasDelJuego",
							"ocurrence": 0,
							"type": "GROUPING",
							"children": [
								{
									"id": "CaracteristicasDelJuego",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"ocurrence": 0,
											"type": "STRING",
											"value": "Videojuego de la marca Lego que vuelve a abordar la marca Batman desde un nuevo punto de vista."
										},
										{
											"id": "es_ES",
											"ocurrence": 1,
											"type": "STRING",
											"value": "¡La franquicia Lego Batman regresa con una aventura cargada de acción que se desarrollará fuera de este planeta!"
										},
										{
											"id": "es_ES",
											"ocurrence": 2,
											"type": "STRING",
											"value": "En Más Allá de Gotham, el Caballero Oscuro se une a otros superhéroes del universo DC Comics en un título con más gadgets y desafíos a superar."
										},
										{
											"id": "es_ES",
											"ocurrence": 3,
											"type": "STRING",
											"value": "En Lego Batman 3: Más allá de Gotham, el Cruzado de la Capa une fuerzas con superhéroes del universo de DC Comics y despega hacia el espacio para detener al malvado Brainiac antes de que destruya la Tierra."
										},
										{
											"id": "es_ES",
											"ocurrence": 4,
											"type": "STRING",
											"value": "Usando el poder de los Anillos Lantern (Anillos de las Linternas), Brainiac es capaz de encoger mundos para añadirlos a su retorcida colección de ciudades en miniatura de todo el universo."
										},
										{
											"id": "es_ES",
											"ocurrence": 5,
											"type": "STRING",
											"value": "Ahora, los mejores superhéroes y los villanos más astutos deben unirse y viajar a diferentes mundos Lantern para recolectar los Anillos de Poder e intentar detener a Brainiac antes de que sea demasiado tarde."
										}
									]
								}
							]
						},
						{
							"id": "CaracteristicasDelJuego",
							"ocurrence": 1,
							"type": "GROUPING",
							"children": [
								{
									"id": "Titular",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"type": "STRING",
											"value": "Características:"
										}
									]
								},
								{
									"id": "CaracteristicasDelJuego",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"ocurrence": 0,
											"type": "STRING",
											"value": "Emocionantes combates espaciales. Lucha con Batman y sus aliados en el espacio exterior, visitando varios mundos Lantern como Zamaron y Odym."
										},
										{
											"id": "es_ES",
											"ocurrence": 1,
											"type": "STRING",
											"value": "Elenco de héroes y villanos de DC Comics. Juega y desbloquea más de 150 personajes únicos con increíbles poderes y habilidades, incluyendo a miembros de la Liga de la Justicia y grandes figuras de LEGO como Cyborg, Solomon Grundy y muchos más."
										},
										{
											"id": "es_ES",
											"ocurrence": 2,
											"type": "STRING",
											"value": "Una historia original. Los trajes sorprendentes, las habilidades de control mental de Brainiac y el poder de los anillos Lantern, le darán un nuevo giro a la personalidad de personajes que creías conocer."
										},
										{
											"id": "es_ES",
											"ocurrence": 3,
											"type": "STRING",
											"value": "Hackear ordenadores. Entra en un mundo virtual para escapar de laberintos, combatir en las arenas, y correr para encontrar el código."
										},
										{
											"id": "es_ES",
											"ocurrence": 4,
											"type": "STRING",
											"value": "Gadgets Bat-tásticos. Sólo presionando un botón puedes elegir entre los diferentes trajes de los personajes y mejorarlos junto a sus habilidades."
										},
										{
											"id": "es_ES",
											"ocurrence": 5,
											"type": "STRING",
											"value": "Entornos icónicos. Visita el Salón de Justicia, la Batcueva, o La Atalaya de la Liga de la Justicia para acceder a tiendas y salas de trofeos o personalizar héroes y vehículos."
										},
										{
											"id": "es_ES",
											"ocurrence": 6,
											"type": "STRING",
											"value": "Elenco de actores espectacular. Con una lista de actores increíble. Mucho de ellos retomando su papel de los anteriores juegos de LEGO Batman incluyendo: Troy Baker (Batman); Travis Willingham (Superman); Christopher Cory Smith (The Joker); Laura Bailey (Wonder Woman y Catwoman); Dee Bradley Baker (Brainiac); Josh Keaton (Green Lantern); Scott Porter (Aquaman), Y nada más y nada menos que el Batman de los años 60 ¡Adam West!"
										}
									]
								}
							]
						},
						{
							"id": "CaracteristicasDelJuego",
							"ocurrence": 2,
							"type": "GROUPING",
							"children": [
								{
									"id": "Titular",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"type": "STRING",
											"value": "Características del Juego portátil:"
										}
									]
								},
								{
									"id": "CaracteristicasDelJuego",
									"type": "STRING",
									"children": [
										{
											"id": "es_ES",
											"ocurrence": 0,
											"type": "STRING",
											"value": "Combates con un estilo espectacular y personalizado."
										},
										{
											"id": "es_ES",
											"ocurrence": 1,
											"type": "STRING",
											"value": "Una aventura con 45 misiones basadas en una historia original, dinámica y rápida."
										},
										{
											"id": "es_ES",
											"ocurrence": 2,
											"type": "STRING",
											"value": "Juega como más de 100 personajes únicos del universo de DC Cómics."
										}
									]
								}
							]
						},
						{
							"id": "Plataforma",
							"ocurrence": 0,
