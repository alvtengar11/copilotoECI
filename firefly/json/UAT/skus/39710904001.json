            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "ocurrence": 0,
                  "value": "Quando os dentes do seu bebé provocam dores de crescimento, um mordedor fresco salva o dia."
                },
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "ocurrence": 1,
                  "value": "O pilar do Mordedor vem pré cheio com água, para que o possa guardar no frigorífico e dar às gengivas ternas do seu bebé um alívio extra."
                },
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "ocurrence": 2,
                  "value": "A forma lagarta brincalhona cria uma mordedura fácil de arrancar que as pequenas mãos do seu bebé conseguem agarrar e segurar."
                },
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "ocurrence": 3,
                  "value": "As múltiplas formas e superfícies manterão o seu bebé curioso ocupado enquanto acalma as gengivas doridas."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 0,
                  "value": "Cuando los dientes de su bebé le causan dolores de crecimiento, un mordedor frío salva el día."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 1,
                  "value": "El pilar del Mordedor viene precargado con agua, por lo que puedes guardarlo en el refrigerador y darle a las encías tiernas de tu bebé un alivio adicional."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 2,
                  "value": "La alegre forma de Oruga crea un mordedor fácil de agarrar que las manitas de su bebé pueden agarrar y sostener."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 3,
                  "value": "Las múltiples formas y superficies mantendrán ocupado a tu bebé curioso mientras calman las encías doloridas."
                }
              ]
            }
          ]
