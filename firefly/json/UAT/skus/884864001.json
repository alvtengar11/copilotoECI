  "specificAttribs": [
    {
      "id": "/Videojuegos_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "CaracteristicasGenerales",
          "type": "GROUPING",
          "children": [
            {
              "id": "CaracteristicasDelJuego",
              "ocurrence": 0,
              "type": "GROUPING",
              "children": [
                {
                  "id": "CaracteristicasDelJuego",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "ocurrence": 0,
                      "type": "STRING",
                      "value": "Basada en la trilogía El Señor de los Anillos, Lego: El Señor de los Anillos introduce a los jugadores a una héroica aventura a través de la Tierra Media."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 1,
                      "type": "STRING",
                      "value": "Encomendado en la peligrosa tarea de destruir un poderoso anillo que amenaza todo lo que es bueno, Frodo deja su pacífico hogar."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 2,
                      "type": "STRING",
                      "value": "Pero el camino al Monte del Destino para cumplir su misión está infestado de horribles criaturas\ndeterminadas a conseguir el anillo. Para ayudar a Frodo, un extravagante grupo de personajes se une: Aragorn el montaraz, Gandalf el mago, Legolas el elfo, Gimli el enano, Boromir el noble soldado y los amigos Hobbits de Frodo, Sam, Merry y Pippin. Únete a ellos en la batalla para restaurar la paz."
                    }
                  ]
                }
              ]
            },
            {
              "id": "CaracteristicasDelJuego",
              "ocurrence": 1,
              "type": "GROUPING",
              "children": [
                {
                  "id": "Titular",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "type": "STRING",
                      "value": "Características:"
                    }
                  ]
                },
                {
                  "id": "CaracteristicasDelJuego",
                  "type": "STRING",
                  "children": [
                    {
                      "id": "es_ES",
                      "ocurrence": 0,
                      "type": "STRING",
                      "value": "¡Revive la leyenda en modo Lego, y guía a Frodo en su búsqueda para destruir el Anillo Único!"
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 1,
                      "type": "STRING",
                      "value": "Toma el control de la Comunidad del Anillo y más de 80 personajes coleccionables."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 2,
                      "type": "STRING",
                      "value": "Explora toda la Tierra Media en una multitud de increíbles paisajes."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 3,
                      "type": "STRING",
                      "value": "Lucha contra pavorosas criaturas como Uruk-hai, el Balrog, el Señor de los Nazgûl, y otras apestosas criaturas."
                    },
                    {
                      "id": "es_ES",
                      "ocurrence": 4,
                      "type": "STRING",
                      "value": "¡Equipa a tu personaje con objetos mágicos, o fórjalos de nuevo con Lego Mithril!"
                    }
                  ]
                }
              ]
            },
