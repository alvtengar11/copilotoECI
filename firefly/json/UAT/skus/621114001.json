	"specificAttribs": [
		{
			"id": "/Perfumeria_ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "DescripcionLarga",
					"ocurrence": 0,
					"type": "GROUPING",
					"children": [
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "El nuevo Prevage Intensive anti-aging + repair daily serum combina Idebedona, el antioxidante más potente existente en la actualidad, con arazine, nuestro nuevo y exclusivo ingrediente."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "La Idebedona no sólo protege la piel de los impactos medioambientales, sino que también ayuda en el proceso de reparación natural de la piel y la rejuvenece."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Arazine es una nueva y exclusiva molécula que posee propiedades antioxidantes, ayudando a proteger la piel de los radicales libres y de los efectos negativos de la inflamación crónica en la piel."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLarga",
					"ocurrence": 1,
					"type": "GROUPING",
					"children": [
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Se ha demostrado clínicamente que Prevage Intensive anti-aging + repair daily serum mejora de forma inmediata el aspecto de las líneas de expresión y arrugas, a la vez que aporta luminosidad y reafirma la piel."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Asimismo, las pruebas han demostrado que, en solo cuatro semanas, su fórmula avanzada reduce la visibilidad de las manchas propias de la edad y mejora la firmeza de la piel en un 60 %."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Con el tiempo Prevage Intensive Anti-Aging + Repair Daily Serum favorece la producción natural de colágeno y elastina de la piel y ayuda a protegerla de las agresiones medioambientales. Con su uso continuado, Prevage Intensive Anti-Aging + Repair Daily Serum dota a la piel de mayor luminosidad y firmeza y rejuvenece su aspecto de forma inmediata."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLarga",
					"ocurrence": 2,
					"type": "GROUPING",
					"children": [
						{
							"id": "Titulo",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Beneficios inmediatos:"
								}
							]
						},
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Los ingredientes Idebenona, Arazine y Thiotaine neutralizan los radicales libres y protegen la piel de los daños que estos provocan."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "El Triacetato de pantenilo y la Naringenina calman la piel y minimizan las rojeces, unificando el tono."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Contiene difusores ópticos que suavizan las líneas de expresión y llenan de luminosidad el rostro."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "El extracto vegetal de alcornoque mejora el tono y la firmeza de la piel."
								}
							]
						}
					]
				},
