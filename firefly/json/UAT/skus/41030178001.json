						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Traça a tua rota para aventuras astronómicas na tua consola PS5™ com o comando sem fios DualSense™ Galactic Purple. Parte de uma extensa gama de acessórios inspirados na nossa galáxia, este comando elegante em púrpura é o companheiro perfeito para explorar novos universos de jogos."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Descobre uma experiência de jogo mais profunda e altamente envolvente1 que dá vida à ação nas palmas das tuas mãos.  O comando sem fios DualSense™ oferece feedback háptico envolvente2, gatilhos adaptáveis dinâmicos2, e um microfone incorporado, tudo integrado num design confortável."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Descubre una experiencia de juego más profunda e inmersiva con el nuevo e innovador mando de PS5, que ofrece retroalimentación háptica y efectos de gatillos adaptativos. El mando inalámbrico DualSense incorpora además un micrófono integrado y un botón Crear, todo integrado en un icónico y práctico diseño."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Compatible con PlayStation 5, PC, Mac y dispositivos móviles."
								}
							]
						}
