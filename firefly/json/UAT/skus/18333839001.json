                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Tratamiento de infestaciones por pulgas, garrapatas, y piojos en perros y gatos"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Se puede aplicar en cachorros y gatitos con más de 2 días de edad, sin restricciones de peso."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Puede ser utilizado en hembras gestantes o en periodo de lactancia"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 4,
                  "type": "STRING",
                  "value": "Está recomendado para dueños de mascotas que necesitan proteger a sus perros y gatos de infestaciones de pulgas, garrapatas y piojos ya presentes en el animal"
