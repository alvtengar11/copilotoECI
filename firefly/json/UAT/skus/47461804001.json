							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "McAfee+ Premium para un número ilimitado de dispositivos ofrece una protección de nivel superior: averigua quién vende tus datos, aprende a destruirlos y disfruta de control parental y de una VPN ilimitada. Además, con todas las funciones de McAfee Total Protection, vivirás tu vida digital con total tranquilidad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Conéctate donde quieras con una protección personalizada: garantizamos la protección de quienquiera que se conecte, en cualquier lugar y con cualquier dispositivo que utilice."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Consigue una protección todo en uno de nivel superior: seguridad premium para dispositivos, control parental, supervisión de la identidad, protección de la privacidad online y VPN automática."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Comprueba el estado de tu protección online: nuestro Nivel de protección, líder del sector, identifica los puntos débiles y enseña a tu familia a mejorar su seguridad."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Compra, utiliza la banca electrónica y navega con total privacidad: la VPN ilimitada y segura de McAfee se activa automáticamente para proteger tus datos personales y la información de tus tarjetas de crédito"
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Mantén a tus hijos protegidos online: con control parental para todos los dispositivos de la familia."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Disfruta de un antivirus galardonado: relájate sabiendo que McAfee te alerta de los sitios web peligrosos y te protege frente a las últimas amenazas"
								}
							]
						}
