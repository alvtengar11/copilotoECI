					"type": "GROUPING",
					"ocurrence": 1,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "Características:"
								},
								{
									"id": "es_ES",
									"type": "STRING",
