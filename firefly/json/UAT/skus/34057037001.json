								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Cadeira baixa de exterior com estrutura em tubo de alumínio de 22 mm e assento e poltrona em textilene, um tecido muito resistente e fácil de manter e limpar."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "É uma cadeira muito confortável, com apoios de braços para poder adotar uma posição natural, e que, além disso, reclina para poder regular a posição e fixar aquela que lhe é mais confortável."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "É dobrável, pelo que pode levá-lo para onde quiser apenas retirando-o das pegas que incorporou. É uma poltrona leve e fácil de abrir e fechar."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Sillón bajo para exterior con estructura de tubo de 22 mm de aluminio y tejido de multifibra, que es resistente y fácil de mantener."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Lleva respaldo reclinable para poder regular la posición y fijar la más confortable."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Es plegable y lleva asas para poder transportarlo con comodidad. Es un sillón ligero y fácil de manejar."
								}
