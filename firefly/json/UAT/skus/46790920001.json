								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Running errands or running paths, this tank top is made with tech designed to keep you feeling dry and comfortable. No need to check your eyes, this double Swoosh graphic mimics movement so you feel inspired to keep going."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Nike Dri-FIT technology moves sweat away from your skin for quicker evaporation, helping you stay dry and comfortable."
