  "specificAttribs": [
    {
      "id": "/Perfumeria_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Olay Total Effects 7-en-1 Hidratante Reafirmante de Noche es una crema hidratante de noche multifunción que aporta 7 beneficios en un solo producto."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Además, cuenta con un rico complejo vitamínico de eficacia probada que proporciona a la piel un aspecto más juvenil cada mañana."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Combate los 7 signos del envejecimiento: minimiza visiblemente las arrugas y las líneas de expresión, ayuda a que la piel no pierda su hidratación, unifica el tono de la tez, minimiza el aspecto de los poros, alisa y da uniformidad a la textura de la piel, le aporta luminosidad, la hidrata y le devuelve una mayor firmeza."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Despiértate cada mañana con una piel visíblemente más firme y juvenil."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
