                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Combate los 7 signos del envejecimiento para obtener una piel con un aspecto más joven y saludable cada mañana."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Contiene el complejo multivitamínico dermatológico VitaNiacinTM con vitaminas B3, E y C."
