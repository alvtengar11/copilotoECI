        {
          "id": "ProveedorMarca",
          "type": "GROUPING",
          "children": [
            {
              "id": "MarcaMostradaEnWeb",
              "type": "RELATIONSHIP",
              "value": "BUGABOO",
              "idExt": "133769056",
