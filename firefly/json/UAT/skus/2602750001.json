  "specificAttribs": [
    {
      "id": "/Complementos_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Aislado de proteína de gran pureza. Ideal para definir la calidad muscular. Sin grasa, sin hidratos y sin lactosa."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Neo Isolate Whey 100 CFM es la proteína más pura del mercado con un 90% de proteína en cada batido. Sin grasa, sin hidratos y sin lactosa es ideal para evitar incrementar peso graso, al mismo tiempo que permite desarrollar al máximo la masa muscular gracias a su alto contenido en proteína."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Su riqueza en aminoácidos ramificados convierte esta proteína en un suplemento completo para todo deportista que busca una óptima recuperación muscular después de intensas sesiones de entrenamiento."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Si necesitas dar un paso más en tus resultados, no busques más, Neo Isolate Whey 100 CFM es tu proteína."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Ingredientes destacados:"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "0% grasa, 0% hidratos, 1% lactosa: Aspectos fundamentales para lograr una buena digestibilidad y para evitar el aumento de masa grasa."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Aislado de suero: Aislado de proteína obtenida mediante tecnología de última generación (CFM), fundamental para lograr la máxima concentración proteica en cada batido. Su riqueza en aminoácidos ramificados (BCAAs) completa el valor de cada batido, pues los BCAAs son esenciales en los procesos de regeneración muscular."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Vitamina B6: Vitamina de especial importancia en el metabolismo proteico, por lo que resulta imprescindible para todo deportista que realice una actividad con un desgaste muscular elevado."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 2,
