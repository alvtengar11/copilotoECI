							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "La enorme unidad de asiento reversible del Balios S Lux es lo último en comodidad y lujo. Reclina hasta alcanzar una posición ergonómica ideal desde el nacimiento."
								}
							]
						}
