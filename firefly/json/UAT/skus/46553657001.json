								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Este rugby con rayas es un icono de Polo y se ha diseñado con detalles clásicos, como un cuello inglés de color blanco, botones de goma y puños acanalados."
								}
							]
