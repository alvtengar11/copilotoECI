                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 0,
                  "value": "Para gemelos o hermanos con poca diferencia de edad."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 1,
                  "value": "Apta desde el nacimiento hasta los 17 Kg. por niño."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 2,
                  "value": "Puede llevarse a cualquier parte porque es ligera (solo 12,5 Kg.) y queda compacta cuando se cierra."
