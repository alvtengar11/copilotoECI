            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Deleita tus ojos con este plato llano de la colección Wild Strawb de Wedgwood inspirada en deliciosas fresas salvajes. Sus hojas y flores con borde dorado te transportarán desde la mesa a un jardín campestre inglés, con el olor a hierba cortada en el aire."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Este plato está fabricado en porcelana new New Bone, un material que se caracteriza por su alta resistencia a los golpes y por su alto grado de blancura y transparencia."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Ideal para combinar con el resto de la colección de la misma serie y crea una vajilla única para compartir con tus familiares y amigos."
                }
              ]
            }
