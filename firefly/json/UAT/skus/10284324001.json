						{
							"id": "DescripcionDelProducto",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Todo juego tiene su momento y su lugar, y ahora puedes estar seguro de que nunca faltará a la cita."
