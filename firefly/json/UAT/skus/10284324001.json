					]
				},
				{
					"id": "CaracteristicasAdicionales",
					"ocurrence": 0,
					"type": "GROUPING",
					"children": [
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "El diseño compacto y fácil de transportar de este estuche oculta una capacidad envidiable. Con sus dos hojas, te permitirá llevar siempre encima una colección de hasta 24 títulos para tu 3DS perfectamente protegidos del polvo y los arañazos."
								}
							]
						}
					]
				},
				{
					"id": "CaracteristicasAdicionales",
					"ocurrence": 1,
					"type": "GROUPING",
					"children": [
						{
							"id": "TitularDeLaDescripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Grandes detalles:"
								}
							]
						},
						{
							"id": "Descripcion",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Hacía falta la pasión de Hori por las pequeñas cosas para crear el estuche de juegos más cuidado para Nintendo 3DS."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Desde las bisagras invisibles hasta el práctico adaptador para tarjetas SD, el diseño funcional japonés actúa sin que lo notes."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Identifica cada juego al instante gracias a las superficies frontal y trasera traslúcidas, enmarcadas por un cuerpo con un agradable acabado mate."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
									"type": "STRING",
									"value": "Dentro, todos los cartuchos se insertan exactamente como en la caja original de Nintendo y siempre en el mismo sentido, sea cual sea la cara que utilices."
								},
								{
									"id": "es_ES",
									"ocurrence": 4,
									"type": "STRING",
									"value": "¡Pon a salvo tus partidas y multiplica la diversión por 24!"
								}
							]
						}
					]
				},
				{
					"id": "CaracteristicasAdicionales",
					"ocurrence": 2,
					"type": "GROUPING",
