									"value": "Licencia oficial de Nintendo."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Capacidad para 24 cartuchos (2 hojas a doble cara)."
								},
								{
									"id": "es_ES",
									"ocurrence": 2,
									"type": "STRING",
									"value": "Superficies frontal y trasera en plástico traslúcido de alta calidad, marco con acabado mate."
								},
								{
									"id": "es_ES",
									"ocurrence": 3,
