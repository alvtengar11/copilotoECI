  "specificAttribs": [
    {
      "id": "/Moda_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Zapatillas Stepluxe con núcleo de espuma gel, contienen un almohadillado suave y más confortable, que actúa como amortiguador, proporcionándote alivio, efecto revitalizante, ayudando a reducir el impacto al andar, disminuye  el dolor de rodillas, piernas y pies, ofreciéndote un mayor apoyo y comodidad, que las zapatillas tradicionales, relaja la zona lumbar... sobre todo te proporcionarán bienestar, confort y suavidad. Están fabricadas en suave microfibra con suelas antideslizantes y resistentes."
                },
                {
                  "id": "en_GB",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Stepluxe gel foam core pads contain a softer, more comfortable cushion that acts as a shock absorber, providing relief, a revitalizing effect, helping to reduce foot impact, lessens knee, leg and foot pain, giving you more support and Comfort, than traditional sneakers, relax the lumbar area ... above all will provide comfort, comfort and softness. They are made of soft microfiber with non-slip and resistant soles."
                },
                {
                  "id": "fr_FR",
                  "ocurrence": 0,
                  "type": "STRING",
