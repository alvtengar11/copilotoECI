":"TipoColeccion","type":"RELATIONSHIP","groupID":"2004","id_Ext":"394510053","value":"20101105021236"},{"id":"Numero","ocurrence":0,"type":"STRING","value":"1"}]},{"id":"Formato","type":"GROUPING","children":[{"id":"FormatoEncuadernacion","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"418","id_Ext":"10121051090","value":"Tapa blanda"},{"id":"Encuadernacion","type":"LOOKUP_TABLE","featureGroupID":"420","id_Ext":"9651455090","value":"Tapa blanda"}]},{"id":"Dimensiones","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Alto","type":"NUMBER","value":"21.0"},{"id":"UOM!Dimensiones!Ancho","type":"NUMBER","value":"14.0"},{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","featureGroupID":"204","id_Ext":"347186090","value":"cm"}]},{"id":"Edicion","type":"INTEGER","value":"1"},{"id":"NumPaginas","type":"NUMBER","value":"72.0"},{"id":"Idioma","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"157","id_Ext":"347423090","value":"Castellano"},{"id":"FechaPrimeraEdicion","type":"GROUPING","children":[{"id":"Ano","type":"INTEGER","value":"1999"},{"id":"Mes","type":"LOOKUP_TABLE","featureGroupID":"1050","id_Ext":"351281090","value":"Enero"},{"id":"Dia","type":"INTEGER","value":"12"}]},{"id":"Descripcion","ocurrence":0,"type":"GROUPING","children":[{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"<p>Si un libro nuevo de <b>Juan Luis Panero</b> siempre es una grata noticia para los amantes de la poesía, este que presentamos ahora es doblemente bienvenido, porque desmiente las propias declaraciones del poeta sobre los pocos versos que escribía últimamente y reafirma su voluntad de no quedar mudo después de la publicación, hace cerca de dos años, de su<b> Poesía</b> <b>completa (1968-1998</b>) (Marginales 153). Miguel García Posada, crítico de<i> El País</i>, saludó su aparición como <b>«un acontecimiento editorial de primer orden </b>en el campo de la lírica<b>»,</b> y Víctor García de la Concha (<i>Abc</i>) comentó la obra en estos términos : «<b>He aquí un libro mayor</b> <b>en la historia de la poesía de los últimos treinta años</b>».</p> <p></p> <b><p>Enigmas y despedidas</b> ofrece otra vuelta de tuerca sobre la apesadumbrada percepción de los efectos -devastadores- del paso del tiempo. La memoria recupera lugares, personajes, escenas, incluso objetos, en apariencia fugaces o ya desvaídos como «humo al atardecer»,</p> <p>pero que a los ojos del recuerdo se nos descubren premonitorios, revestidos, de pronto, de todo un universo de referencias. Son experiencias que, desde una honda melancolía, también nos descubren la omnipresencia de la muerte, de cuya injerencia hablan más que nunca los poemas de este libro.</p> <p></p> <p>Dividido en tres partes, «<b>Humo al atardecer</b>», «<b>El destino y los sueños</b>» -tres prosas poéticas que recrean un momento y un personaje histórico- y «<b>Documentos de la</b> <b>melancolía</b>», el libro insiste en los <b>enigmas</b> que acrecientan contra todo pronóstico el misterio de lo vivido, que usurpan el puesto a viejas certezas y agudizan el sentimiento de pérdida de tanto momento del pasado, así como en las muchas<b> despedidas</b> a las que nos obliga la conciencia de un irremediable final.</p>"}]}]},{"id":"MotivoNoDisponibilidad","type":"LOOKUP_TABLE","featureGroupID":"417","id_Ext":"351280090","value":"No Publicado"},{"id":"Ficcion","type":"FLAG","value":"true"},{"id":"CodigoSituacion","type":"STRING","value":"FV"}]},{"id":"Autor","ocurrence":0,"type":"GROUPING","children":[{"id":"CodigoAutor","type":"RELATIONSHIP","groupID":"2002","id_Ext":"309637051","value":"0023458"}]},{"id":"Estilos","type":"GROUPING","children":[{"id":"Estilo1","type":"STRING","value":"001"},{"id":"Estilo2","type":"STRING","value":"008"},{"id":"Estilo3","type":"STRING","value":"000"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"true"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"129839167"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SP