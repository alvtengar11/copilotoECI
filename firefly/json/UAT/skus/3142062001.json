","value":"false"},{"id":"VentaSinStock","type":"FLAG","value":"false"},{"id":"CodigoUnicoOrigen","type":"FLAG","value":"true"},{"id":"SenyalInternetCodificacion","type":"FLAG","value":"false"}]},{"id":"ProveedorMarca","type":"GROUPING","children":[{"id":"NumeroProveedor","type":"STRING","value":"0355586"},{"id":"NombreProveedor","type":"STRING","value":"PROCTER & GAMBLE PRESTIGE PRODUCTS, S.A."},{"id":"Fabricante","type":"STRING","value":"0355586"},{"id":"DescripcionFabricante","type":"STRING","value":"PROCTER & GAMBLE PRESTIGE PRODUCTS, S.A."},{"id":"Marca","type":"STRING","value":"GUCCI"},{"id":"MarcaMostradaEnWeb","type":"RELATIONSHIP","groupID":"391","id_Ext":"289904056","value":"GUCCI"}]},{"id":"DescripcionCorta","type":"GROUPING","children":[{"id":"DescripcionTicket","type":"STRING","value":"GUCCI BY GUCCI PREMIE"}]},{"id":"DescripcionLargaDelProducto","ocurrence":0,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Gucci Première"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Gucci presenta Gucci Première Eau de Toilette, una encarnación más suave, brillante y delicada de su memorable aroma, para celebrar el entusiasmo del éxito diario. Más discreta que su predecesor Eau de Parfum, Gucci Première Eau de Toilette enriquece esos logros diarios celebrados con champagne, los hace más grandes y duraderos."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Su fresca y chispeante fragancia combina la presencia de la mujer Gucci con una sensual feminidad dotándola de un resplandor imperecedero."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"El universo de fragancias de Gucci Première se inspira en la colección de Alta Costura Gucci Première, que debutó en el Festival de Cine de Cannes en el año 2010."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Pero, mientras que Gucci Première representa el glamour de la alfombra roja o de una gran noche, la nueva versión Eau de Toilette es más suave."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Posee el carácter de la original, pero con un toque más natural y refrescante. Puedes usarlo como tu fragancia diaria."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":1,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Notas:"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Fiel a la sofisticada silueta de la icónica fragancia Eau de Parfum, Gucci Première Eau de Toilette tiene una nueva estela. Flores radiantes y notas cítricas chispeantes que hacen más ligera la fragancia."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"La combinación de las flores de la salida aporta una elegancia luminosa y efervescente, el azahar y los ligeros aceites cítricos se unen para darle una sensación que recuerda a las gotas de un champagne vintage frío en una distinguida copa de cristal."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"El refinado brillo de las notas deja paso lentamente a las radiantes flores blancas del corazón de la fragancia la fresía, el jazmín y la suave rosa de Bulgaria. A medida que la fragancia se seca sobre la piel, el calor sutil pero tenaz del cuero, el pachulí y las notas de almizcle perfeccionan su cautivador aroma."}]}]},{"id":"DescripcionLargaDelProducto","ocurrence":2,"type":"GROUPING","children":[{"id":"TituloPrincipal","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"El frasco:"}]},{"id":"DescripcionPrincipal","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Incorpora muchos de los detalles y motivos de diseño ya asociados con Gucci Première Eau de Parfum: una medalla adorna el elegante cuello del dorado frasco entrelazándose con el icónico bocado de la Casa."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"En el tapón se inscribe la elegante firma: 'Gucci Première'. El estuche revela la dorada doble G entrelazada, que se ha convertido en uno de los símbolos de diseño más reconocidos del mundo, así como la firma del padre fundador Guccio Gucci y la tribanda icono de la Casa."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Sin embargo, en consonancia con el carácter único de la nueva Eau de Toilette, el glamour se ha reinventado. Al igual que el jugo que descansa en el interior, el color de la caja es de oro pálido en lugar de un tono más intenso."}]}]},{"id":"GestionComprasStock","type":"GROUPING","children":[{"id":"Calificacion1","type":"STRING","value":"A"},{"id":"Calificacion2","type":"STRING","value":"I"},{"id":"Calificacion4","type":"STRING","value":"A"},{"id":"Calificacion5","type":"STRING","value":"AL"},{"id":"Calificacion6","type":"STRING","value":"CG"},{"id":"TipoDeGestion","type":"STRING","value":"14"}]},{"id":"DimensionesYPeso","type":"GROUPING","children":[{"id":"UOM!Dimensiones!Unidad","type":"LOOKUP_TABLE","featureGroupID":"204","id_Ext":"347186090","value":"cm"},{"id":"UOM!PesoBruto!Unidad","type":"LOOKUP_TABLE","featureGroupID":"206","id_Ext":"347187090","value":"g"},{"id":"UOM!VolumenContenidoNeto!VolumenContenidoNeto","type":"NUMBER","value":"0.0"},{"id":"UOM!VolumenContenidoNeto!Unidad","type":"LOOKUP_TABLE","featureGroupID":"213","id_Ext":"347188090","value":"ml"},{"id":"PUM","type":"GROUPING","children":[{"id":"EnlacePUM","type":"LOOKUP_TABLE","featureGroupID":"2530","id_Ext":"20552576090","value":"008"},{"id":"CantidadProducto","type":"NUMBER","value":"75.0"},{"id":"UnidadesProducto","type":"STRING","value":"001"}]}]},{"id":"ColoresYTallas","type":"GROUPING","children":[{"id":"Tallas","type":"LOOKUP_TABLE","featureGroupID":"393","id_Ext":"349421090","value":"75 ml"},{"id":"TipoTallaje","type":"LOOKUP_TABLE","featureGroupID":"394","id_Ext":"349417090","value":"Belleza - Tamaño"},{"id":"TamanoHorma","type":"STRING","value":"75ML"}]},{"id":"Varian