                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "value": "Alcofa completa com painel ventilado e tecidos de toque suave para o máximo conforto em todos os seus passeios."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Capazo completo con panel ventilado y tejidos suave al tacto para un máximo confort en todos tus paseos"
