  "specificAttribs": [
    {
      "id": "/Perfumeria_ISS",
      "type": "SPEC",
      "children": [
        {
          "id": "DescripcionLarga",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Fórmulas milenarias unidas a la investigación y a la tecnología, inspiraron la combinación de elementos de la magistral fórmula de Royal Bee. Los principios de la Jalea Real, Miel, Propóleos... por su capacidad regeneradora, reforzado con el poder rejuvenecedor de la Crisálida (seda), capaz de transformar la oruga en una bella mariposa."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "En pocos días la piel se ilumina, las arrugas disminuyen y el rostro se vuelve más firme y terso. su uso continuado rejuvenece con efecto visible y duradero"
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLarga",
          "ocurrence": 1,
          "type": "GROUPING",
          "children": [
            {
              "id": "Titulo",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Fórmula"
                }
              ]
            },
            {
              "id": "Descripcion",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Miel: aporta vitaminas y minerales."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Jalea Real: Revitalizante."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Extracto de crisálida: Regenerador y cicatrizante."
                },
