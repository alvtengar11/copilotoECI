,"value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"137423789"}]}],"link":[{"id_Ext":"10782849016","hierarchyId":"2013","categoryId":"1450712272"},{"id_Ext":"17399011013","hierarchyId":"999","categoryId":"1486723358"},{"id_Ext":"10782825016","hierarchyId":"2013","categoryId":"1450700784"},{"id_Ext":"2865209021","hierarchyId":"100167","categoryId":"2865209021"},{"id_Ext":"8627173016","hierarchyId":"2013","categoryId":"1434100960"},{"id_Ext":"5520012","hierarchyId":"998","categoryId":"00217"},{"id_Ext":"2865214021","hierarchyId":"100167","categoryId":"2865214021"},{"id_Ext":"50357018","hierarchyId":"5001","categoryId":"01.979.234"},{"id_Ext":"2865210021","hierarchyId":"100167","categoryId":"2865210021"},{"id_Ext":"19023276020","hierarchyId":"5003","categoryId":"1494319202"},{"id_Ext":"2865211021","hierarchyId":"100167","categoryId":"2865211021"},{"id_Ext":"8592468016","hierarchyId":"2013","categoryId":"1433859574"},{"id_Ext":"2865212021","hierarchyId":"100167","categoryId":"2865212021"}],"specificAttribs":[{"id":"/Perfumeria_ISS","type":"SPEC","children":[{"id":"DescripcionLarga","ocurrence":0,"type":"GROUPING","children":[{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Emulsión facial con propiedades hidratantes y nutritivas que, además, protege frente a los daños causados por la exposición solar gracias a su elevado contenido en Aloe Vera y filtros UVA y UVB. También contiene activos antienvejecimiento como Colágeno y Elastina."}]}]},{"id":"DescripcionLarga","ocurrence":1,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Activos"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Aloe Vera. El Aloe es un ingrediente muy importante, pues penetra en las tres capas de la piel: epidermis, la dermis, la hipodermis, y expulsa las bacterias y los depósitos de grasa que tapan los poros. Al mismo tiempo la acción de los nutrientes naturales, los minerales, las vitaminas, los aminoácidos y las enzimas, estimulan la reproducción de nuevas células."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"También es un importante regenerador celular, cicatrizante, tonificador y de alta penetración en la piel. Cuando se usa con regularidad, evita las arrugas prematuras y retarda las propias de la edad. Es un excelente filtro solar de rayos ultravioletas y elimina las manchas causadas por el sol, si se usa por un periodo largo de tiempo."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Filtros solares. Protegen frente a la radiación ultravioleta (UVB y UVA) a la que la piel se ve expuesta a lo largo del día. Previenen daños en manchas ya existentes y la aparición de nuevas."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Colágeno y Elastina. El colágeno y la elastina son los principales componentes del tejido conectivo de la piel, asegurando flexibilidad, tonicidad y elasticidad a la piel, propiedades que se deterioran con los años. Se trata de elementos abundantes en pieles jóvenes que van perdiendo sus propiedades con la edad. Por ello, puede decirse que se trata de dos componentes esenciales en la lucha contra el envejecimiento."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Vitamina E. La vitamina E es altamente conocida por su elevada actividad antioxidante."}]}]},{"id":"DescripcionLarga","ocurrence":2,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Indicaciones"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Se trata de un tratamiento facial que hidrata y nutre profundamente la piel. Su uso diario y continuo, además, aporta protección al rostro frente las agresiones producidas por la exposición solar. Aplicar 1-2 veces al día sobre la piel perfectamente limpia, acompañando siempre de un suave masaje hasta su completa absorción."}]}]},{"id":"DescripcionLarga","ocurrence":3,"type":"GROUPING","children":[{"id":"Titulo","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Composición"}]},{"id":"Descripcion","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Ingredientes: Aqua, Aloe barbadensis leaf juice, Cetearyl alcohol, Ethylhexyl methoxycinnamate, Homosalate, Petrolatum, Isoeicosane, Glycerin, Caprylic/Capric/Triglyceride, Decyl oleate, Dimethicone, Benzophenone-3, Propylene glycol, Hydrolyzed elastina, Hydrolyzed collagen, Urea, PEG-12 Dimethicone, Titanium dioxide (and) Aluminum hydroxide (and) Stearic acid, Sodium lauryl sulfate, Tocopheryl acetate, Cetearyl alcohol, Paraffin, Phenoxyethanol, Ethylhexylglycerin, Parfum, Citral, Limonene, Linalool."}]}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"137423789"}]}],"stores":[{"id":"/Comunes_ISS","type":"SPEC","children":[{"id":"destacado","type":"INTEGER","value":"9999999"},{"id":"Multimedia","type":"GROUPING","children":[{"id":"Fotos","type":"GROUPING","children":[{"id":"MainFotos","type":"GROUPING","children":[{"id":"UrlImagenT","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400267____1__100x100.jpg"},{"id":"UrlImagenX","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400267____1__40x40.jpg"},{"id":"UrlImagenL","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400267____1__225x225.jpg"},{"id":"UrlImagenM","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400267____1__150x150.jpg"},{"id":"UrlImagenG","type":"IMAGE_URL","value":"http://sgfm.elcorteingles.es/SGFM/dctm/MEDIA02/CONTENIDOS/201411/20/00197923400267____1__600x600.jpg"},{"id":"UrlImagenP","type":"IMAGE_URL","value":"http://sgfm.elcorte