							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Humedad 10%, proteína bruta 21,5%, grasa bruta 15%, fibra bruta 3%, ceniza bruta 6%, lisina 1,2%, metionina 0,6 %, calcio 0,6%, sodio 0,16%."
								}
							]
						}
					]
				},
