				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 0,
					"children": [
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Alimento indicada para canarios. Las fórmulas Serinus son alimentos completos. Las aves obtienen en ellas todos los nutrientes necesarios para gozar de una óptima salud, excelente vigor y una inmejorable calidad de plumaje."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "La fórmula de mantenimiento es la indicada para animales ornamentales y de canto, y para ser suministrada durante el período de reposo reproductivo en reproductores."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Ideada para ser suministrada como dieta única. Opcionalmente pueden ser utilizadas con semillas en dietas mixtas."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Es aconsejable suministrar hojas de verdura periódicamente con la finalidad de dar variedad a la dieta."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Debe suministrarse en seco y en comederos con rejilla. Conservar en sitio fresco y seco."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Consumo diario: aproximadamente 3-4 g por día y ave."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Alimento fisiológico."
								}
							]
						}
					]
				},
				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 1,
					"children": [
						{
							"id": "TituloPrincipal",
