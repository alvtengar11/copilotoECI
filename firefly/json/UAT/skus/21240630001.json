						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"value": "Batedeira Philips Série 5000 HR3740/00 com 5 Velocidades e Turbo, de 450 W"
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Um bater intenso e eficiente para obter bolos fofos."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "A batedeira Philips ajuda-o na criação de bolos deliciosos e fofos e pães para toda a família. O bater cónico com ar proporciona um bater mais rápido e uma massa de bolos mais macia. O potente motor de 450 W facilita a preparação de massas mais pesadas."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Varas de forma cónica para máxima incorporação do ar. \nA forma cónica exclusiva das varas permite a máxima incorporação do ar, o que contribui para uma massa de bolo suave e mais fofa."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Motor com potência de 450 W para as massas mais difíceis. \nO potente motor de 450 W facilita o trabalho das massas mais difíceis."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "5 Regulações de velocidade para um melhor controlo. \nA ampla gama de velocidades fornece-lhe o melhor controlo na mistura."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Função turbo. \nA função turbo permite impulsos extra de potência quando precisa deles."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Conjunto de varas fácil. \nAs varas foram concebidas com um padrão diferente numa das extremidades para serem intuitivamente montadas para uma configuração rápida."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 7,
									"value": "Botão de ejeção fácil das varas. \nCom um simples toque pode libertar as varas ou pás para amassar."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 8,
									"value": "Manter os cabos arrumados é fácil com a mola para o fio. \nO gancho para guardar o fio ajuda a manter a sua cozinha arrumada."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Amasadora que te ayudará a crear deliciosas y esponjosas tartas y bizcochos, así como panes. El amasado cónico con incorporación de aire reduce el tiempo de montado para suavizar la masa de la tarta. Su potente motor de 450 W permite preparar las masas más difíciles de forma sencilla."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Montaje fácil de varillas. Clip para el cable."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Mixer that will help you create delicious and fluffy cakes and biscuits, as well as breads. Conical air-entrained kneading reduces whipping time to smooth out cake batter."
								},
								{
									"id": "en_GB",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Its powerful 450 W motor allows you to prepare the most difficult doughs easily. Easy mounting of rods and cable clip."
								},
								{
									"id": "fr_FR",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Mélangeur qui vous aidera à créer de délicieux gâteaux et biscuits moelleux, ainsi que des pains. Le pétrissage conique à air entraîné réduit le temps de fouettage pour lisser la pâte à gâteau."
								},
								{
									"id": "fr_FR",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Son puissant moteur de 450 W vous permet de préparer facilement les pâtes les plus difficiles. Montage facile des tiges et du serre-câble."
								}
							]
						}
					]
