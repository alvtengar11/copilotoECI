							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Todo es mucho más fácil con Android TV de Google. El sistema de televisón inteligente compatible con las principales plataformas de contenido online. Películas y series a tu alcance, organizadas de forma inteligente por tendencia y temática."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "Pídele lo que necesitas. El asistente de voz de Google responde a tus órdenes de búsqueda. El mando a distancia reconoce tu voz para buscar rápidamente en aplicaciones y servicios."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Mucho más que un televisor. Consulta la previsión sobre el tiempo, noticias de actualidad o la información deportiva. Conéctate a tus redes sociales. Reproduce vídeos, fotos y contenidos desde tu teléfono móvil."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Puedes reproducir contenidos multimedia mediante dispositivos externos conectados al puerto USB. O bien conectar todo tipo de reproductores a través de sus 3 puertos HDMI."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Preparado para la TDT que viene gracias a su sintonizador T2."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "Compatible con soportes de pared VESA 100x100mm."
								}
							]
						}
