              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 0,
                  "value": "Base USB lectora de tarjetas inteligentes y DNIe."
                },
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "ocurrence": 1,
                  "value": "Compatible con Mac OS X/Windows 10, o versiones anteriores y el nuevo DNIe 3.0."
