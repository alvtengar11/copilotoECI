				{
					"id": "DescripcionLargaDelProducto",
					"type": "GROUPING",
					"ocurrence": 0,
					"children": [
						{
							"id": "TituloPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "es_ES",
									"type": "STRING",
									"value": "Earpods Pokemon Pikachu True Wireless."
								}
							]
						},
						{
							"id": "DescripcionPrincipal",
							"type": "STRING",
							"children": [
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Estes pequenos e leves auriculares verdadeiramente sem fios proporcionam uma experiência de áudio completa, rica e nítida com graves profundos, médios suaves e agudos cristalinos. Desfrute de uma experiência de som de qualidade superior com a tecnologia Bluetooth V5.3 em cada auricular. Estes auscultadores sem fios são perfeitos para viagens, deslocações e exercício físico."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 1,
									"value": "A caixa de carregamento USB tipo C proporciona até 6 horas de tempo de audição com 3 carregamentos adicionais."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Escolha entre dois tamanhos de encaixes de silicone macio (pequeno e grande) para obter um ajuste personalizado / criar uma vedação acústica para uma experiência de audição ainda mais envolvente."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Controlo tátil inteligente: Pode saltar/reproduzir/pausar uma faixa, atender/recusar chamadas telefónicas ou ativar o assistente de voz com um simples toque."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Confortável de usar: Incluem-se pontas auriculares adicionais para personalizar o ajuste no canal auditivo e evitar que os auriculares escorreguem."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 5,
									"value": "A tecnologia Bluetooth 5.3 garante uma ligação mais fiável e estável, sem queda de chamadas ou pausas na música."
								},
								{
									"id": "pt_PT",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Emparelhamento automático: Uma vez emparelhados, os auscultadores emparelham-se automaticamente para utilização futura."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 0,
									"value": "Estos pequeños y livianos earpods true wireless ofrecen una experiencia de audio completa, rica y clara con bajos profundos, medios lisos y agudos cristalinos. Disfruta de una experiencia de sonido premium con tecnología Bluetooth V5.3 en cada auricular. Estos auriculares inalámbricas son perfectos para viajar, desplazarse y hacer ejercicio."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 1,
									"value": "La caja de carga con USB de tipo C proporciona hasta 6 horas de tiempo de escucha con 3 cargas adicionales."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 2,
									"value": "Elije entre dos tamaños de accesorios de silicona suaves (pequeños y grandes) para dar un ajuste personalizado / crear un sello acústico para una experiencia auditiva aún más inmersiva."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 3,
									"value": "Control táctil inteligente: Puedse omitir / reproducir / pausar una pista, responder / rechazar llamadas telefónicas o activar el asistente de voz simplemente tocándolo."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 4,
									"value": "Cómodos de usar: Eartips adicionales incluidos para personalizar su ajuste en el canal auditivo para evitar que los auriculares se deslicen."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 5,
									"value": "La tecnología Bluetooth 5.3 garantiza una conexión más confiable y estable sin cortes de llamadas o pausas de música."
								},
								{
									"id": "es_ES",
									"type": "STRING",
									"ocurrence": 6,
									"value": "Emparejamiento automático: Una vez emparejados, los auriculares se emparejarán automáticamente para su uso futuro."
								}
							]
						}
					]
