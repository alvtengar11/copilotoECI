3159","id_Ext":"1263883159","groupID":"6636","id":"CodigoVariante","type":"RELATIONSHIP","value":"5704947006716"},{"id":"CodigoEan","type":"STRING","value":"5704947006716"},{"id":"FechaAltaEanCompras","type":"DATE","value":"20190312_000000"},{"id":"FechaHastaEanPromocional","type":"DATE","value":"20190313_000000"},{"id":"EsEanCompraPrincipal","type":"FLAG","value":"true"}],"id":"EanVariante","type":"GROUPING"}],"id":"EansVariantes","type":"GROUPING"},{"id":"Modificado","type":"FLAG","value":"false"},{"id":"Oferta","type":"FLAG","value":"false"},{"id":"EciExpress","type":"FLAG","value":"false"},{"id":"ProductoExclusivoEciExpress","type":"FLAG","value":"false"},{"id":"EsAlcohol","type":"FLAG","value":"false"}],"id":"/Supermercado Peninsula CPS","type":"SPEC"}],"specificAttribs":[{"children":[{"id":"ActivarDocPropia","type":"FLAG","value":"true"},{"children":[{"id":"es_ES","type":"STRING","value":"Alivio garantizado para pies muy secos y agrietados. O'Keeffe's for Healthy Feet ofrece una fórmula única de ingredientes hidratantes para garantizar la mejora de la piel seca y agrietada. La tierra árida y cuarteada necesita agua. Y lo mismo le ocurre a la piel seca y áspera. Garantía de devolución del 100 %: Si no está totalmente satisfecho con el resultado de los productos O'Keeffe's le devolvemos el 100 % del precio de compra."}],"id":"InformacionGeneral","type":"STRING"},{"children":[{"id":"es_ES","type":"STRING","value":"O'Keeffe's Healthy Feet contiene una alta concentración de glicerina que retiene la humedad, la cual es necesaria para tener una piel sana e hidratada. Healthy Feet también contiene alantoína, que además de hidratar, ayuda a penetrar en la piel más gruesa y áspera del pie. Y lo mejor de todo es que funciona con rapidez. La mayoría de las personas comienzan a notar los resultados en tan solo dos días. Se ha demostrado clínicamente que el uso diario de O'Keeffe's for Healthy Feet:\n- Aumenta instantáneamente los niveles de hidratación.\n- Forma una capa protectora en la superficie de la piel.\n- Ayuda a prevenir una mayor pérdida de hidratación.\n- Logra una mejora notable en unos días\nProducto sin perfume, no graso e hipoalergénico. Es apto para pieles diabéticas."}],"id":"InformacionGeneral1","type":"STRING"},{"children":[{"id":"es_ES","type":"STRING","value":"Aqua, Glycerin, Stearic Acid, Sodium Hydroxide, Octyldodecyl Stearate, Hydroxypropyl Methylcellulose, Paraffin, Acrylates/Acrylamide Copolymer, Allantoin, Paraffinum Liquidum, Polysorbate 85, Diazolidinyl Urea, Iodopropynyl\nButylcarbamate, Dimethicone, Ceteth-10, Laureth-4\""}],"id":"Ingredientes","type":"STRING"},{"children":[{"id":"es_ES","type":"STRING","value":"Para unos mejores resultados, aplica la crema en la piel exfoliada a la hora de irte a la cama y tras la ducha, ya que esos momentos son los más efectivos para hidratar la piel a fondo. Una muy pequeña cantidad de producto será suficiente. Aplicar el producto tantas veces sea necesario. Una pequeña cantidad será suficiente."}],"id":"Consejos","type":"STRING"},{"children":[{"id":"es_ES","type":"STRING","value":"Evitar almacenar bajo el sol directo ni en lugares con variación continua de la temperatura."}],"id":"Precauciones","type":"STRING"}],"id":"/Alimentacion ISS","type":"SPEC"}],"id_Ext":"1263884101","entryContainerID":"6639","link":[{"idExt":"1067904123","hierarchyId":"6809","id_Ext":"1067904123","categoryId":"010733"},{"idExt":"1067881123","hierarchyId":"6809","id_Ext":"1067881123","categoryId":"010714"},{"idExt":"1067902123","hierarchyId":"6809","id_Ext":"1067902123","categoryId":"010731"},{"idExt":"1067878123","hierarchyId":"6809","id_Ext":"1067878123","categoryId":"010713"},{"idExt":"1067876123","hierarchyId":"6809","id_Ext":"1067876123","categoryId":"010711"},{"idExt":"1067877123","hierarchyId":"6809","id_Ext":"1067877123","categoryId":"010712"},{"idExt":"1067884123","hierarchyId":"6809","id_Ext":"1067884123","categoryId":"010719"},{"idExt":"1001002123","hierarchyId":"6809","id_Ext":"10