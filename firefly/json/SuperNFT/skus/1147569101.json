r","type":"STRING","value":"790 00110"}],"id":"MercanciaGeneral","type":"GROUPING"},{"children":[{"ocurrence":0,"children":[{"idExt":"26867190","featureGroupID":"6619","id_Ext":"26867190","id":"CodigoRegion","type":"LOOKUP_TABLE","value":"CANARIAS"},{"children":[{"id":"Anulacion","type":"FLAG","value":"true"}],"id":"Temporal","type":"GROUPING"}],"id":"Regiones","type":"GROUPING"}],"id":"Excepciones","type":"GROUPING"},{"id":"Enviado","type":"FLAG","value":"true"},{"id":"TipoDocumentacion","type":"STRING","value":"Gran Consumo"},{"id":"Filled","type":"FLAG","value":"true"},{"id":"ExternalCode","type":"STRING","value":"1147569101"},{"id":"NumDiasCadGarantizadaRef","type":"INTEGER","value":"0"},{"children":[{"ocurrence":0,"children":[{"idExt":"746900159","id_Ext":"746900159","groupID":"6636","id":"CodigoVariante","type":"RELATIONSHIP","value":"3574661206585"},{"id":"CodigoEan","type":"STRING","value":"3574661206585"},{"id":"FechaHastaEanPromocional","type":"DATE","value":"20180308_000000"},{"id":"EsEanCompraPrincipal","type":"FLAG","value":"true"}],"id":"EanVariante","type":"GROUPING"}],"id":"EansVariantes","type":"GROUPING"},{"id":"Modificado","type":"FLAG","value":"false"},{"id":"EciExpress","type":"FLAG","value":"false"}],"id":"/Supermercado Peninsula CPS","type":"SPEC"}],"specificAttribs":[{"children":[{"id":"ActivarDocPropia","type":"FLAG","value":"true"},{"children":[{"id":"ca_ES","type":"STRING","value":"Un suau massatge amb la crema peus durícies sobre les zones especialment seques és suficient per prevenir i tractar les durícies amb efectivitat. La pell amb tendència a patir aquests problemes millora progressivament, els peus queden intensament hidratats, més renovats i molt més suaus.\nEl seu alt contingut d'urea disminueix el gruix de les durícies alhora que hidrata i suavitza amb més eficàcia, gràcies a la millor penetració dels agents hidratants (glicerina i vaselina). \nLa crema peus durícies de Neutrogena també és eficaç contra els radicals lliures, gràcies a l'extracte de Vitis vinifera, el palmitat de vitamina C i la vitamina E (o tocoferol). Combinada amb l'exfoliant es converteix en el tractament intensiu més eficaç, que a més s'absorbeix ràpidament sense tacar i sense deixar sensació de greix.\nEls peus queden totalment renovats utilitzant l'exfoliant una vegada per setmana"},{"id":"es_ES","type":"STRING","value":"Un suave masaje con la Crema Pies Durezas sobre las zonas especialmente secas es suficiente para prevenir y tratar las durezas con efectividad. La piel con tendencia a padecer estos problemas mejora progresivamente, los pies quedan intensamente hidratados, más renovados y mucho más suaves.\nSu alto contenido en Urea disminuye el grosor de las durezas a la vez que hidrata y suaviza con más eficacia, gracias a la mejor penetración de los agentes hidratantes (Glicerina y Vaselina). \nLa Crema Pies Durezas de Neutrogena también es eficaz contra los radicales libres gracias al extracto de Vitis Vinifera, el Palmitato de Vitamina C y la Vitamina E (o Tocoferol). Combinada con el exfoliante se convierte en el tratamiento intensivo más eficaz, que además se absorbe rápidamente sin manchar y sin dejar sensación de grasa.\nLos pies quedan totalmente renovados usando el exfoliante una vez por semana"}],"id":"InformacionGeneral","type":"STRING"},{"children":[{"id":"es_ES","type":"STRING","value":"Aplicar el exfoliante sobre la piel mojada y masajear. Exfolia la piel áspera y gruesa, las durezas se reducen y los pies quedan intensamente hidratados y suaves con resultados visibles desde el primer uso."},{"id":"ca_ES","type":"STRING","value":"Aplicar l'exfoliant sobre la pell molla i fer massatges. Exfolia la pell aspra i gruixuda, les durícies es redueixen i els peus queden intensament hidratats i suaus, amb resultats visibles des del primer ús."}],"id":"Consejos","type":"STRING"}],"id":"/Alimentacion ISS","type":"SPEC"}],"id_Ext":"1147569101","entryContainerID":"6639","link":[{"idExt":"1067904123","hierarchyId":"