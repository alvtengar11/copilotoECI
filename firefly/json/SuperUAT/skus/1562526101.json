	"specificAttribs": [
		{
			"id": "/Vinos ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "NotaCata",
					"type": "STRING",
					"children": [
						{
							"id": "es_ES",
							"type": "STRING",
							"value": "Vino de color amarillo pajizo claro y brillante. Aparecen aromas de flor de fruta y melocotón blanco. En boca aparecen las notas de melocotón y albaricoques sobre una elegante fusión de texturas finas. Destaca su final cítrico, limpio, largo y elegante"
						},
						{
							"id": "ca_ES",
							"type": "STRING",
							"value": "Vi de color groc pallós clar i brillant. Apareixen aromes de flor de fruita i préssec blanc. En boca apareixen les notes de préssec i albercocs sobre una elegant fusió de textures fines. Destaca el seu final cítric, net, llarg i elegant"
						}
					]
				},
				{
					"id": "GastronomiaPlatosRecomendados",
					"type": "STRING",
					"children": [
						{
							"id": "ca_ES",
							"type": "STRING",
							"value": "Tota mena de peixos i mariscos, amanides tèbies i formatges cremosos. També és bon acompanyant d'arrossos amb peix i de tapes gastronòmiques."
						},
						{
							"id": "es_ES",
							"type": "STRING",
							"value": "Todo tipo de pescados y mariscos, ensaladas tibias y quesos cremosos. También es buen acompañante de arroces con pescado y de tapeo gastronómico."
						}
					]
				}
			]
		}
	],
