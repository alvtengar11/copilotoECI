	"specificAttribs": [
		{
			"id": "/Vinos ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "NotaCata",
					"type": "STRING",
					"children": [
						{
							"id": "es_ES",
							"type": "STRING",
							"value": "Color amarillo pálido con reflejos verdosos.\nIntenso aroma con notas varietales de moscatel que recuerdan\na jazmín, cítricos sutiles a piel de naranja y tropicales. Ligero\nfondo herbal que aporta frescura y elegancia. La boca es untuosa,\nequilibrada y fresca, con una persistencia larga y muy agradable."
						},
						{
							"id": "ca_ES",
							"type": "STRING",
							"value": "Color groc pàl·lid amb reflexos verdosos.\nIntensa aroma amb notes varietals de moscatell que recorden\na gessamí, cítrics subtils a pell de taronja i tropicals. Lleuger\nfons d'herbes que aporta frescor i elegància. La boca és untuosa,\nequilibrada i fresca, amb una persistència llarga i molt agradable."
						}
					]
				},
				{
					"id": "GastronomiaPlatosRecomendados",
					"type": "STRING",
					"children": [
						{
							"id": "ca_ES",
							"type": "STRING",
							"value": "Acompanyant aperitius, arrossos, pastes i\npeix."
						},
						{
							"id": "es_ES",
							"type": "STRING",
							"value": "Acompañando aperitivos, arroces, pastas y\npescados."
						}
					]
				}
			]
		}
