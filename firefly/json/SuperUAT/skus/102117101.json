	"specificAttribs": [
		{
			"id": "/Vinos ISS",
			"type": "SPEC",
			"children": [
				{
					"id": "NotaCata",
					"type": "STRING",
					"children": [
						{
							"id": "es_ES",
							"type": "STRING",
							"value": "Amarillo pajizo con destellos verdosos. Burbuja fina y potente.\nBuena intensidad aromática. Aromas afrutados de manzana\ny cítricos. Recuerdos de panadería y monte bajo.\nBuena estructura en boca, amplio, vivo y con\nmuy buena acidez. Las sensaciones retronasales\nson limpias, frescas y persistentes"
						},
						{
							"id": "ca_ES",
							"type": "STRING",
							"value": "Groc pallós amb esclats verdosos. Bombolla fina i potent.\nBona intensitat aromàtica. Aromes afruitades de poma\ni cítrics. Records de fleca i muntanya baixa.\nBona estructura en boca, ampli, viu i amb\nmolt bona acidesa. Les sensacions retronasals\nsón netes, fresques i persistents"
						}
					]
				},
				{
					"id": "GastronomiaPlatosRecomendados",
					"type": "STRING",
					"children": [
						{
							"id": "ca_ES",
							"type": "STRING",
							"value": "Acompanyar amb fumats\ni marisc"
						},
						{
							"id": "es_ES",
							"type": "STRING",
							"value": "Acompañar con ahumados\ny mariscos"
						}
					]
				}
			]
		}
	],
