":"25202","id_Ext":"27850190","id":"Crianza","type":"LOOKUP_TABLE","value":"00001"},{"id":"ZonaGeograficaEnum","type":"STRING_ENUMERATION","value":"La Rioja"},{"idExt":"47066190","featureGroupID":"25203","id_Ext":"47066190","id":"TipoVino","type":"LOOKUP_TABLE","value":"00001"},{"id":"DenominacionEnum","type":"STRING_ENUMERATION","value":"Rioja, Calificada"},{"id":"TipoVinoEnum","type":"STRING_ENUMERATION","value":"Vino Tinto"},{"id":"CrianzaEnum","type":"STRING_ENUMERATION","value":"joven"},{"idExt":"27891190","featureGroupID":"25204","id_Ext":"27891190","id":"DenominacionOrigen","type":"LOOKUP_TABLE","value":"00038"},{"id":"ZonaGeografica","type":"STRING","value":"00013"},{"ocurrence":0,"children":[{"idExt":"46949190","featureGroupID":"25207","id_Ext":"46949190","id":"TipoUva","type":"LOOKUP_TABLE","value":"00034"},{"id":"TipoUvaEnum","type":"STRING_ENUMERATION","value":"Tempranillo"},{"id":"Porcentaje","type":"NUMBER","value":"100.0"}],"id":"TipoUva","type":"GROUPING"},{"idExt":"27000190","featureGroupID":"25206","id_Ext":"27000190","id":"Bodega","type":"LOOKUP_TABLE","value":"00136"},{"id":"BodegaEnum","type":"STRING_ENUMERATION","value":"Solar Viejo"},{"children":[{"id":"en_GB","type":"STRING","value":"High intensity colour dominated by ruby red with violet iridescence. Explosion of red berries, strawberry and raspberry aromas which are so typical of the Rioja Alavesa region. Lightly swirling the glass produces a bouquet where ripe fruits with creamy touches dominate. On the palate, it has medium acidity and great liveliness accompanied by a carbonic note that highlights its youth. Smooth and agreeable tannins that tempt one to drink. Fruity, medium intensity aftertaste."},{"id":"es_ES","type":"STRING","value":"Color de alta intensidad dominado por rojo rubí con irisaciones violáceas. Explosión de aromas a frutos rojos, fresas, frambuesas tan características de la\nzona de Rioja Alavesa. Tras una leve agitación dominan los aromas de fruta madura con toques lácticos. En boca, acidez media y gran viveza acompañada de un punto de carbónico que resalta su juventud. Tanino suave y agradable que invita a beber. Post-gusto afrutado de media intensidad."},{"id":"ca_ES","type":"STRING","value":"Color d'alta intensitat dominat pel vermell robí amb irisacions violàcies. Explosió d'aromes a fruites vermelles, maduixes, gerds tan característics de la\nzona de la Rioja Alabesa. Després d'una lleu agitació dominen les aromes de fruita madura amb tocs làctics. A la boca, acidesa mitjana i gran vivor acompanyada d'un punt de carbònic que fa ressaltar la seva joventut. Taní suau i agradable que convida a beure. Postgust afruitat de mitjana intensitat."}],"id":"NotaCata","type":"STRING"},{"id":"GraduacionAlcoholica","type":"NUMBER","value":"14.06"},{"children":[{"id":"Minimo","type":"INTEGER","value":"13"},{"id":"Maximo","type":"INTEGER","value":"14"}],"id":"TemperaturaDeServicio","type":"GROUPING"},{"children":[{"id":"en_GB","type":"STRING","value":"Rice dishes, pasta, any kind of tapas or bar snacks, mild cheeses and cold meats."},{"id":"ca_ES","type":"STRING","value":"Arrossos, pasta, qualsevol tipus de tapa, formatges suaus i embotits."},{"id":"es_ES","type":"STRING","value":"Arroces, pasta, cualquier tipo de tapas o pinchos, quesos suaves y embutidos."}],"id":"GastronomiaPlatosRecomendados","type":"STRING"},{"idExt":"39874190","featureGroupID":"28802","id_Ext":"39874190","id":"Pais","type":"LOOKUP_TABLE","value":"00001"}],"id":"/Vinos ISS","type":"SPEC"}],"id_Ext":"103087101","entryContainerID":"6639","link":[{"idExt":"8561123","hierarchyId":"6809","id_Ext":"8561123","categoryId":"010009"},{"idExt":"8578123","hierarchyId":"6809","id_Ext":"8578123","categoryId":"010036"},{"idExt":"8563123","hierarchyId":"6809","id_Ext":"8563123","categoryId":"010011"},{"idExt":"8577123","hierarchyId":"6809","id_Ext":"8577123","categoryId":"010029"},{"idExt":"8557123","hierarchyId":"6809","id_Ext":"8557123","categoryId":"010005"},{"idExt":"8568123","hier