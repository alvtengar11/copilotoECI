              ]
            },
            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "Líquidos derramados são escoados do teclado por isso não é preciso preocupar-se com o seu investimento com derramamentos acidentais."
                }
              ]
            }
          ]
        },
        {
          "id": "DescripcionLargaDelProducto",
