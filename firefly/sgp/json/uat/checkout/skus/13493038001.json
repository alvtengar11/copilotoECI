            {
              "id": "TituloPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "type": "STRING",
                  "value": "PERFIL FINO"
                }
              ]
            },
            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "O teclado tem um perfil fino que acrescenta um elegante aspecto à sua secretária e ao mesmo tempo mantém as suas mãos numa posição neutra mais confortável."
