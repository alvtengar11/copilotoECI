                  "value": "Simplicidade Plug-and-Play"
                }
              ]
            },
            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "O Logitech Mouse M90 é simples de configurar e usar. Não é necessário instalar software para usar. E como tem fio, você pode simplesmente conectar o cabo a uma porta USB e usá-lo imediatamente."
                }
              ]
            }
          ]
        },
