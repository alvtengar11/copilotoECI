        {
          "id": "DescripcionLargaDelProducto",
          "ocurrence": 0,
          "type": "GROUPING",
          "children": [
            {
              "id": "TituloPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "es_ES",
                  "type": "STRING",
                  "value": "Ratón con cable para Gaming Logitech G403 HERO"
                }
              ]
            },
            {
              "id": "DescripcionPrincipal",
              "type": "STRING",
              "children": [
                {
                  "id": "pt_PT",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "O G403 aparece com a próxima geração do sensor HERO 16K . Prepare-se para um mouse com o próximo rastreamento de nível 1: 1, faixa de sensibilidade máxima de 100 a 16.000 dpi e sem suavização, aceleração ou filtros."
                },
                {
                  "id": "pt_PT",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "Equipado com o sensor Hero: G403 aparece com a próxima geração do sensor HERO 16K. Prepare-se para um mouse com o próximo rastreamento de nível 1: 1, faixa de sensibilidade máxima de 100 a 16.000 dpi e sem suavização, aceleração ou filtros."
                },
                {
                  "id": "pt_PT",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "Sensor Hero 16K: Apresentamos o sensor HERO 16K da próxima geração, nosso sensor mais avançado, com rastreamento 1: 1, mais de 400 IPS e uma sensibilidade máxima de 100-16.000 dpi. E também, sem suavização, aceleração ou filtros."
                },
                {
                  "id": "es_ES",
                  "ocurrence": 0,
                  "type": "STRING",
                  "value": "El ratón G403 cuenta con el sensor HERO 16K de próxima generación. Prepárate para un ratón con seguimiento 1:1 de próximo nivel, rango de sensibilidad máxima de 100 a 16.000 dpi y sin suavizado, aceleración ni filtros"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 1,
                  "type": "STRING",
                  "value": "La iluminación RGB de espectro completo determinada por el juego responde a la acción de juego, al audio y al color de la pantalla y se sincroniza con todos los dispositivos y accesorios G"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 2,
                  "type": "STRING",
                  "value": "G403 es ligero, con un diseño cómodo, para amoldarse a tu mano y con recubrimiento de goma para mayor control"
                },
                {
                  "id": "es_ES",
                  "ocurrence": 3,
                  "type": "STRING",
                  "value": "Con un tiempo de respuesta de 1 ms, G403 es hasta 8 veces más rápido que los ratones estándar no diseñados específicamente para gaming. Por eso ofrece clics y movimientos prácticamente instantáneos"
                }
              ]
            }
