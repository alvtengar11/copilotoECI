          "children": [
            {
              "id": "es_ES",
              "ocurrence": 0,
              "type": "STRING",
              "value": "El Beladur es un material sintético de altísima calidad que ofrece mayor resistencia a impactos y rayaduras. Con un aspecto muy natural a la vista y agradable al tacto, es inalterable a lo largo del tiempo. Además, tiene la posibilidad de lacarse."
            }
          ]
        },
        {
          "id": "ConvieneSaber",
          "type": "STRING",
          "children": [
            {
              "id": "es_ES",
              "ocurrence": 0,
              "type": "STRING",
              "value": "Este mueble se fabrica en España."
            },
            {
              "id": "es_ES",
              "ocurrence": 1,
              "type": "STRING",
              "value": "Los objetos decorativos no están incluidos en el precio."
            },
            {
              "id": "es_ES",
              "ocurrence": 2,
              "type": "STRING",
              "value": "Incluye herrajes para pared de ladrillo (no pladur)."
            }
          ]
        },
