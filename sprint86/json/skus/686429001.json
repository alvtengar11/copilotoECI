20121113112637"},{"id_Ext":"14528906011","hierarchyId":"997","categoryId":"20161018025934"},{"id_Ext":"12114197011","hierarchyId":"997","categoryId":"20160510113808"},{"id_Ext":"11914485011","hierarchyId":"997","categoryId":"20160411123133"},{"id_Ext":"3017011","hierarchyId":"997","categoryId":"20121121051702"},{"id_Ext":"3283110022","hierarchyId":"5004","categoryId":"9909542325"}],"unlink":[],"specificAttribs":[{"id":"/Videojuegos_ISS","type":"SPEC","children":[{"id":"CaracteristicasGenerales","type":"GROUPING","children":[{"id":"CaracteristicasDelJuego","ocurrence":0,"type":"GROUPING","children":[{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"El multijugador por excelencia llega a Nintendo 3DS. El multijugador por excelencia como siempre con partidas multijugador con hasta ocho participantes en red inalámbrica local o Internet."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Vuelven las carreras más competidas del mundo del videojuego: esta vez por tierra... mar y aire. Las caras más conocidas del universo Mario y algunos nuevos vuelven a darse cita en los circuitos, pero esta vez también surcarán los cielos gracias un ala delta o encontrarán atajos por debajo del agua."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Más armas, 16 nuevos circuitos y los mejores recorridos clásicos rediseñados en los que podrás conducir usando los controles de siempre o agarrando y moviendo la consola como si fuera un volante de verdad para guiar tu kart en primera persona. Además, podrás crear tu propio estilo personalizando tu vehículo o compitiendo con tu propio Mii. Y, si quieres, competir en un completo entorno 3D real."},{"id":"pt_PT","ocurrence":0,"type":"STRING","value":"O multiplayer por excelência chega à Nintendo 3DS. Partidas com até 8 jogadores em rede sem fios ou em ligação à internet."},{"id":"pt_PT","ocurrence":1,"type":"STRING","value":"Aqui regressam as corridas mais competitivas do mundo dos videojogos. E desta vez por Terra, Mar e Ar! As caras mais conhecidas do Universo Mario voltam aos circuitos, mas desta vez cruzarão igualmente os céus graças à Asa Delta e encontrarão atalhos debaixo de água."},{"id":"pt_PT","ocurrence":2,"type":"STRING","value":"Mais armas, 16 novas pistas e os melhores tours clássicos redesenhados que poderás concluir usando os controlos de sempre ou agarrando e movendo a consola como se fosse um volante para guiar o Kart em primeira pessoa. Além disto, poderás criar o teu próprio estilo personalizando o teu veículo ou competindo com o teu próprio Mii."}]}]},{"id":"CaracteristicasDelJuego","ocurrence":1,"type":"GROUPING","children":[{"id":"Titular","type":"STRING","children":[{"id":"es_ES","type":"STRING","value":"Características:"}]},{"id":"CaracteristicasDelJuego","type":"STRING","children":[{"id":"es_ES","ocurrence":0,"type":"STRING","value":"Corre en los mejores circuitos clásicos rediseñados para que las carreras sean también por mar y aire además de 16 trazados completamente nuevos: los personajes y las armas de siempre... y muchos que no has visto hasta ahora."},{"id":"es_ES","ocurrence":1,"type":"STRING","value":"Juega con controles clásicos o moviendo la consola igual que moverías un volante y con una vista en primera persona de la carrera."},{"id":"es_ES","ocurrence":2,"type":"STRING","value":"Sumérgete, si usas la opción en 3D del juego, en carreras más realistas."},{"id":"es_ES","ocurrence":3,"type":"STRING","value":"Multijugador inalámbrico y on line con hasta ocho jugadores."},{"id":"es_ES","ocurrence":4,"type":"STRING","value":"Personaliza tu experiencia: diseña tu kart y usa tu propio Mii como conductor."},{"id":"es_ES","ocurrence":5,"type":"STRING","value":"Mario Kart es la licencia de más éxito del universo Mario: la que más vende y la que más gente y más heterogénea junta alrededor de una consola."},{"id":"es_ES","ocurrence":6,"type":"STRING","value":"Mario Kart es el juego más 'contagioso' de Nintendo: la obsesión de cualquier comprador del juego es que los que le rodean también se lo compren para competir con ellos en multijugador."},{"id":"es_ES","ocurrence":7,"type":"STRING","value":"La nueva opción de pilotar moviendo la consola como si fuera un volante crea un camino hacia Nintendo 3DS para todos los usuarios de Mario Kart Wii."},{"id":"es_ES","ocurrence":8,"type":"STRING","value":"Por primera vez en la serie los karts podrán ir por debajo del agua y planear por el aire."},{"id":"es_ES","ocurrence":9,"type":"STRING","value":"Elige entre los personajes clásicos y otros nuevos como Metal Mario. Juega en primera persona moviendo la consola como si fuera un volante."}]}]},{"id":"Plataforma","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"462","id_Ext":"350499090","value":"Nintendo 3DS"},{"id":"Desarrolladores","type":"LOOKUP_TABLE","featureGroupID":"460","id_Ext":"390875090","value":"Nintendo"},{"id":"Distribuidores","type":"LOOKUP_TABLE","featureGroupID":"461","id_Ext":"390876090","value":"Nintendo"},{"id":"Pegi","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"468","id_Ext":"374330090","value":"3+"},{"id":"Genero","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"464","id_Ext":"2160330090","value":"Conducción"},{"id":"Subgenero","ocurrence":0,"type":"LOOKUP_TABLE","featureGroupID":"470","id_Ext":"372303090","value":"Coches"},{"id":"SoporteDigital","type":"LOOKUP_TABLE","featureGroupID":"147","id_Ext":"350504090","value":"Tarjeta NDS"}]},{"id":"RepositoryModificationControl","type":"FLAG","value":"false"},{"id":"IdMensajeAnterior","type":"NUMBER","value":"138084170"}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"DespublicadoPorMargen","type":"FLAG","value":"false"},{"id":"DespublicadoPorStock","type":"FLAG","value":"false"},{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20150625_123618"},{"id":"MotivoPubDesWWW","type":"LOOKUP_TABLE","featureGroupID":"10110","id_Ext":"23376