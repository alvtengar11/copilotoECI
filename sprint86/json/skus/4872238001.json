							"children": [
								{
									"id": "es_ES",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Color anaranjado mucho más  intenso por los bordes. Buena infiltración grasa. Olor penetrante e intenso y agradable característico de este tipo de productos. Se percibe aroma a ahumado del pimentón."
								},
								{
									"id": "es_ES",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Textura jugosa debido a la infiltración grasa que presenta. Sabor intenso y fuertemente persistente. Notas dulces. Sabor carne madura. Sabor persistente en boca."
								},
								{
									"id": "en_GB",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Orange colour, much more intense at the edges. Well-marbled fat. Pervasive, appetising aroma characteristic of this type of product. There is a noticeable aroma of smoked paprika."
								},
								{
									"id": "en_GB",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Juicy texture thanks to the marbled fat. Intense, long-lasting flavour. Sweet notes. Mature meat flavour. Lingering flavour in the mouth."
								},
								{
									"id": "fr_FR",
									"ocurrence": 0,
									"type": "STRING",
									"value": "Couleur orangée beaucoup plus intense vers les bords. Bonne infiltration graisseuse. Odeur pénétrante et intense, une caractéristique agréable de ce type de produits. Arôme évoquant le paprika fumé."
								},
								{
									"id": "fr_FR",
									"ocurrence": 1,
									"type": "STRING",
									"value": "Texture juteuse grâce à son infiltration graisseuse. Goût intense et très persistant. Quelques notes de douceur. Saveur de viande mûre. Goût persistant en bouche."
								}
							]
						}
