 fruits and liquorice, characteristic of a well ripened tempranillo grape. It is well-balanced on the palate, with a light hint of freshness, rounded, persistent and with a lingering finish. Elegance and balance between fruit and wood."}]},{"id":"GraduacionAlcoholica","type":"NUMBER","value":"13.0"},{"id":"DenominacionOrigen","type":"LOOKUP_TABLE","featureGroupID":"25204","id_Ext":"27891190","value":"00038"},{"id":"TiempoCrianza","type":"GROUPING","children":[{"id":"TiempoBarrica","type":"INTEGER","value":"12"},{"id":"TiempoBotella","type":"INTEGER","value":"6"},{"id":"TipoBarrica","type":"STRING","children":[{"id":"en_GB","type":"STRING","value":"Bordeaux barrique American oak barrel"},{"id":"ca_ES","type":"STRING","value":"Bóta bordelesa de roure americà"},{"id":"es_ES","type":"STRING","value":"Barrica bordelesa de roble americano"}]}]}]},{"id":"Publicacion","type":"GROUPING","children":[{"id":"PublicadoEnum","type":"STRING_ENUMERATION","value":"Publicar"},{"id":"Excepciones","type":"GROUPING","children":[{"id":"Region","ocurrence":0,"type":"GROUPING","children":[{"id":"FechaDesde","type":"DATE","value":"20140526_044344"},{"id":"CodigoRegion","type":"LOOKUP_TABLE","featureGroupID":"6619","id_Ext":"26867190","value":"CANARIAS"},{"id":"PublicadoEnum","type":"STRING_ENUMERATION","value":"Publicar"}]}]},{"id":"FechaDesde","type":"DATE","value":"20140526_044344"}]}]}],"stores":[{"id":"/Fechas_WWW_ISS","type":"SPEC","children":[{"id":"Fechas","type":"GROUPING","children":[{"id":"FechaDePublicacionWWW","type":"DATE","value":"20140526_044344"},{"id":"FechaDespublicacionWWW","type":"DATE","value":"29991230_000001"}]}]}],"prices":[{"productId":"001018703100109   ","centerId":"0001","regularPrice":"06.60","avaliable":"true","startDate":"20140516","catalogPrice":"06.60"},{"productId":"001018703100109   ","centerId":"0002","regularPrice":"06.60","avaliable":"true","startDate":"20140516","catalogPrice":"06.60"},{"productId":"001018703100109   ","centerId":"0003","regularPrice":