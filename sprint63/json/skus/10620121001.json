					"children": [
						{
							"id": "Descripcion",
							"ocurrence": 0,
							"type": "STRING",
							"value": "Silla de Auto Sirona M2 I-Size Princess Pink para Grupo 0+/1, en morado."
						},
						{
							"id": "Descripcion",
							"ocurrence": 1,
							"type": "STRING",
							"value": "La Sirona M2-I Size, cumple los requisitos de la nueva normativa europea 'I-Size' para las Sillas de coche, en la que los menores de 15 meses viajan en sentido contrario a la marcha."
						},
						{
							"id": "Descripcion",
							"ocurrence": 2,
							"type": "STRING",
							"value": "Cybex recomienda prolongar el tiempo durante el cual el niño viaja en sentido contrario a la marcha en la Sirona M2 I-Size hasta, aproximadamente, los 105 cm. de altura (4 años, aprox.)."
						},
						{
							"id": "Descripcion",
							"ocurrence": 3,
							"type": "STRING",
							"value": "La Sirona M2 I-Size también puede utilizarse en coches sin homologación i-Size."
						},
						{
							"id": "Descripcion",
							"ocurrence": 4,
							"type": "STRING",
							"value": "El ingenioso diseño de la Silla permite que hasta los niños más grandes tengan espacio suficiente para sentarse de manera confortable."
						},
						{
							"id": "Descripcion",
							"ocurrence": 5,
