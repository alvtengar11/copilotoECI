    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here

if(product.match(/(.js_LTC.json)/i))

	{
	 store = "LTC"
	
	}

else 
	if(product.match(/(.js_ECI_PORTUGAL.json)/i))
	{
	 store = "ECI_PORTUGAL"
	}		
	else
			{
			store = "ECI"
			}
if (product.match(/(BO_product)/i))
				{
				channel = "products"
				}
else 
	if(product.match(/(BRI_product)/i))
	{
	 channel = "productsBricor"
	}
	else 
		if(product.match(/(CAT_product)/i))
		{
		 channel = "CAT"
		}
		else 
			if(product.match(/(EXP_product)/i))

			{
		 	channel = "productsExpress"
			}
			else 
				if(product.match(/(GOU_product)/i))
				{
		 		channel = "Gourmet"
				}
				else 
					if(product.match(/(HIP_product)/i))
					{
		 			channel = "productsHipercor"
					}
						else 
							if(product.match(/(NON_product)/i))
							{
		 					channel = "productsNonValid"
							}
							else 
								if(product.match(/(POR_product)/i))
								{
		 						channel = "productsProtugal"
								}
								else 
									if(product.match(/(PRI_product)/i))
									{
		 							channel = "productsPrimeriti"
									}

									else 
										if(product.match(/(RND_product)/i))
										{
		 								channel = "productsRND"
										}
										else 
											if(product.match(/(STL_ID)/i))
											{
		 									channel = "Sterling ID"
											}
											else 
												if(product.match(/(STL_MKP)/i))
												{
		 										channel = "Sterling Marketplace"
												}
												else 
													if(product.match(/(STL_PGC)/i))
													{
		 											channel = "Sterling PGC"
													}
													else 
														if(product.match(/(STL_PG_)/i))
														{
		 												channel = "Sterling PG"
														}
														else 
															if(product.match(/(STL_TP)/i))
															{
		 													channel = "Sterling TP"
															}
															else 
																if(product.match(/(STL_productMKPSTL)/i))
																{
		 														channel = "Sterling Marketplace"
																}
																	else 
																		if(product.match(/(tdigital)/i))
																		{
		 																channel = "Sterling Digital"
																		}
																		else 
																			if(product.match(/(STL_productedp)/i))
																			{
		 																	channel = "Sterling EDP"
																			}
																			else 
																				if(product.match(/(STL_producttextbook)/i))
																				{
		 																		channel = "Sterling Text Book"
																				}
																				else 
																					if(product.match(/(STL_productvpr)/i))
																					{
		 																			channel = "Sterling VPR"
																					}
																					else 
																						if(product.match(/(STL_product)/i))
																						{
		 																				channel = "productsSterling"
																						}
																						else 
																							if(product.match(/(MKP_product)/i))
																							{
		 																					channel = "productsMKP"	
																							}
																							else
																							{
		 																					channel = "productsUniforms"																						}
</jsScript_script>
      </jsScript>
    </jsScripts>
